@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Navigation

@code {
    private bool _isMobileSidebarOpen = false;

    private void ToggleMobileSidebar()
    {
        _isMobileSidebarOpen = !_isMobileSidebarOpen;
    }

    private void HandleLogout()
    {
        Auth.Logout();
        Navigation.NavigateTo("/");
    }

    private bool IsActive(string href)
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var target = href.TrimStart('/');

        if (string.IsNullOrEmpty(target))
        {
            return string.IsNullOrEmpty(relative) || relative.Equals("trabajador", StringComparison.OrdinalIgnoreCase);
        }

        return relative.StartsWith(target, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsPedidosActive =>
        IsActive("/trabajador")
        && !IsActive("/trabajador/productos")
        && !IsActive("/trabajador/registrar-venta")
        && !IsActive("/trabajador/devoluciones")
        && !IsActive("/trabajador/perfil");
}

<RoleGate RequiredRole="trabajador">
<div class="d-flex flex-column min-vh-100 bg-background text-foreground">

    <!-- Mobile Menu Toggle Button (Floating) -->
    <button type="button" @onclick="ToggleMobileSidebar" class="btn d-lg-none position-fixed z-3 d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; left: 15px; top: 10px; border-radius: var(--radius); background-color: #004d26; border-color: #004d26;">
        <i class="fas fa-bars text-white" style="font-size: 1rem;"></i>
    </button>

    <!-- Sidebar - Desktop (Fixed) -->
    <aside class="d-none d-lg-flex flex-column position-fixed top-0 bottom-0 start-0 z-2 text-white shadow-sm" style="width: 280px; background-color: #004d26 !important; color: #F4FFF8 !important;">
        <!-- Sidebar Brand -->
        <div class="p-4 border-bottom" style="border-color: rgba(255,255,255,0.12) !important;">
            <a href="/trabajador" class="d-flex align-items-center gap-3 text-decoration-none text-white">
                <div class="d-flex align-items-center justify-content-center rounded flex-shrink-0" style="width: 42px; height: 42px; background: rgba(255,255,255,0.15);">
                    <i class="fa-solid fa-cart-shopping text-white" style="font-size: 1.2rem;"></i>
                </div>
                <div>
                    <h1 class="font-bold m-0 leading-none" style="font-family: 'Outfit', sans-serif; font-size: 1.15rem;">Shiligama</h1>
                    <p class="text-xs m-0" style="opacity: 0.7; color: #c8edd8;">Panel de Trabajador</p>
                </div>
            </a>
        </div>

        <!-- Sidebar Navigation -->
        <nav class="flex-grow-1 p-3 overflow-y-auto d-flex flex-column gap-1">
            <a href="/trabajador" class="trab-sidebar-link d-flex align-items-center gap-3 px-3 py-3 rounded text-decoration-none @(IsPedidosActive ? "active" : "")">
                <i class="fa-solid fa-clipboard-list" style="width: 20px; text-align: center; font-size: 1rem;"></i>
                Pedidos
            </a>
            <a href="/trabajador/productos" class="trab-sidebar-link d-flex align-items-center gap-3 px-3 py-3 rounded text-decoration-none @(IsActive("/trabajador/productos") ? "active" : "")">
                <i class="fa-solid fa-box" style="width: 20px; text-align: center; font-size: 1rem;"></i>
                Productos
            </a>
            <a href="/trabajador/registrar-venta" class="trab-sidebar-link d-flex align-items-center gap-3 px-3 py-3 rounded text-decoration-none @(IsActive("/trabajador/registrar-venta") ? "active" : "")">
                <i class="fa-solid fa-credit-card" style="width: 20px; text-align: center; font-size: 1rem;"></i>
                Registrar Venta
            </a>
            <a href="/trabajador/devoluciones" class="trab-sidebar-link d-flex align-items-center gap-3 px-3 py-3 rounded text-decoration-none @(IsActive("/trabajador/devoluciones") ? "active" : "")">
                <i class="fa-solid fa-rotate-left" style="width: 20px; text-align: center; font-size: 1rem;"></i>
                Devoluciones
            </a>
        </nav>


    </aside>

    <!-- Mobile Navigation Drawer -->
    @if (_isMobileSidebarOpen)
    {
        <div class="sheet-backdrop z-3" @onclick="ToggleMobileSidebar"></div>
        <div class="sheet-panel show text-white p-0 d-flex flex-column justify-between z-3" style="width: 270px; background-color: #004d26 !important;">
            <div>
                <!-- Brand Mobile Header -->
                <div class="p-4 border-bottom d-flex align-items-center justify-content-between" style="border-color: rgba(255,255,255,0.12) !important;">
                    <a href="/trabajador" @onclick="ToggleMobileSidebar" class="d-flex align-items-center gap-3 text-decoration-none text-white">
                        <div class="d-flex align-items-center justify-content-center rounded" style="width: 40px; height: 40px; background: rgba(255,255,255,0.15);">
                            <i class="fa-solid fa-cart-shopping text-white" style="font-size: 1.1rem;"></i>
                        </div>
                        <div>
                            <h1 class="font-bold m-0 leading-none" style="font-family: 'Outfit', sans-serif; font-size: 1.15rem;">Shiligama</h1>
                            <p class="text-xs m-0" style="opacity: 0.7; color: #c8edd8;">Panel de Trabajador</p>
                        </div>
                    </a>
                    <button type="button" class="btn-close btn-close-white" @onclick="ToggleMobileSidebar"></button>
                </div>

                <!-- Navigation List Mobile -->
                <nav class="p-3 d-flex flex-column gap-1 overflow-y-auto" style="max-height: calc(100vh - 160px);">
                    <a href="/trabajador" @onclick="ToggleMobileSidebar" class="trab-sidebar-link d-flex align-items-center gap-3 px-3 py-2.5 rounded text-decoration-none @(IsPedidosActive ? "active" : "")">
                        <i class="fa-solid fa-clipboard-list" style="width: 20px; text-align: center; font-size: 1rem;"></i>
                        Pedidos
                    </a>
                    <a href="/trabajador/productos" @onclick="ToggleMobileSidebar" class="trab-sidebar-link d-flex align-items-center gap-3 px-3 py-2.5 rounded text-decoration-none @(IsActive("/trabajador/productos") ? "active" : "")">
                        <i class="fa-solid fa-box" style="width: 20px; text-align: center; font-size: 1rem;"></i>
                        Productos
                    </a>
                    <a href="/trabajador/registrar-venta" @onclick="ToggleMobileSidebar" class="trab-sidebar-link d-flex align-items-center gap-3 px-3 py-2.5 rounded text-decoration-none @(IsActive("/trabajador/registrar-venta") ? "active" : "")">
                        <i class="fa-solid fa-credit-card" style="width: 20px; text-align: center; font-size: 1rem;"></i>
                        Registrar Venta
                    </a>
                    <a href="/trabajador/devoluciones" @onclick="ToggleMobileSidebar" class="trab-sidebar-link d-flex align-items-center gap-3 px-3 py-2.5 rounded text-decoration-none @(IsActive("/trabajador/devoluciones") ? "active" : "")">
                        <i class="fa-solid fa-rotate-left" style="width: 20px; text-align: center; font-size: 1rem;"></i>
                        Devoluciones
                    </a>
                </nav>
            </div>


        </div>
    }

    <!-- Content Workspace -->
    <div class="flex-grow-1 d-flex flex-column" style="padding-left: 0px; padding-left: 280px; max-width: 100%;">

        <!-- Top Bar Header -->
        <header class="sticky-top bg-card border-bottom py-3 px-3 px-lg-4 border-color-default" style="z-index: 1; backdrop-filter: blur(8px); background-color: rgba(var(--bs-body-bg-rgb), 0.95);">
            <div class="d-flex align-items-center justify-content-between gap-3">
                <!-- Mobile Spacer left (for float button) -->
                <div class="d-lg-none" style="width: 48px;"></div>

                <!-- Search bar filter mock -->
                <div class="flex-grow-1 max-w-md" style="max-width: 400px;">
                    <div class="position-relative w-100"></div>
                </div>

                <!-- Right items -->
                <div class="d-flex align-items-center gap-3">

                    <!-- Theme Selector -->
                    <ThemeSelector />

                    <!-- User drop menu -->
                    <div class="dropdown">
                            <button class="btn btn-secondary p-0 d-flex align-items-center justify-content-center border-0 shadow-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false"  style="width: 40px; height: 40px; border-radius: var(--radius); background-color: var(--secondary);" title="Menú de Usuario">
                            <i class="fa-solid fa-user text-foreground" style="font-size: 1.1rem;"></i>
                        </button>
                       
                        <ul class="dropdown-menu dropdown-menu-end border shadow-lg p-2" style="width: 220px; border-radius: var(--radius);">
                            <li class="px-3 py-2 border-bottom border-color-default mb-1">
                                <p class="text-sm font-semibold text-foreground m-0">@(Auth.CurrentUser?.Name ?? "Trabajador")</p>
                                <p class="text-xs text-muted-foreground m-0 text-truncate">@(Auth.CurrentUser?.Email ?? "trabajador@shiligama.com")</p>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center text-foreground py-2" href="/trabajador/perfil" style="border-radius: var(--radius);">
                                    <i class="fa-solid fa-user me-2 text-muted-foreground" style="font-size: 0.9rem; width: 16px; text-align: center;"></i>
                                    Mi Perfil
                                </a>
                            </li>

                            <li><hr class="dropdown-divider border-color-default"></li>
                            <li>
                                <button type="button" @onclick="HandleLogout" class="dropdown-item d-flex align-items-center text-danger py-2" style="border-radius: var(--radius);">
                                    <Icons Name="LogOut" Class="w-4 h-4 me-2" />
                                    Cerrar Sesión
                                </button>
                            </li>
                        </ul>
                    </div>

                </div>
            </div>
        </header>

        <!-- Main Body Content -->
        <main class="flex-grow-1 p-3 p-md-4 app-page" style="max-width: 100%;">
            @Body
        </main>
    </div>
</div>


</RoleGate>

<style>
    /* Desktop aside custom scroll */
    aside nav::-webkit-scrollbar {
        width: 4px;
    }

    /* Sidebar link base */
    .trab-sidebar-link {
        color: rgba(255, 255, 255, 0.75);
        transition: background-color 0.18s ease, color 0.18s ease;
    }

    .trab-sidebar-link:hover {
        background-color: rgba(255, 255, 255, 0.09) !important;
        color: #ffffff !important;
    }

    .trab-sidebar-link.active {
        background-color: rgba(255, 255, 255, 0.16) !important;
        color: #ffffff !important;
        font-weight: 600;
    }

    @@media (max-width: 991.98px) {
        div.flex-grow-1 {
            padding-left: 0px !important;
        }
    }
</style>
