@page "/Error"
@using System.Diagnostics

<PageTitle>Error — Shiligama</PageTitle>

<div class="container-xl py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <h1 class="h3 text-danger fw-bold mb-2">Algo salió mal</h1>
            <p class="text-muted-foreground mb-4">
                Ocurrió un error al procesar tu solicitud. Si el problema continúa, intenta de nuevo más tarde.
            </p>

            @if (ShowRequestId)
            {
                <p class="small text-muted-foreground">
                    <strong>ID de solicitud:</strong>
                    <code class="user-select-all">@RequestId</code>
                </p>
            }

            <a href="/catalogo" class="btn btn-primary mt-2">Volver al catálogo</a>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
