@page "/trabajador/registrar-venta"
@layout TrabajadorLayout
@inject ProductService ProductSvc
@inject SalesService SalesSvc

@code {
    private List<Product> _products = new();
    private string _searchQuery = "";
    private List<CartItem> _posCart = new();
    private string _customerName = "";
    private string _payMethod = "efectivo";
    private string _invoiceType = "ninguno";
    private bool _success = false;
    private string _receiptId = "";
    private bool _isModalOpen = false;
    private string _modalSearch = "";
    private Product? _selectedProduct = null;

    private decimal Igv       => Subtotal * 0.18m;
    private decimal SubtotalSinIgv => Subtotal / 1.18m;

    protected override void OnInitialized()
    {
        _products = ProductSvc.GetProducts();
    }

    private IEnumerable<Product> FilteredProducts => _products.Where(p =>
        string.IsNullOrEmpty(_searchQuery) ||
        p.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
        p.Category.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
    );

    private IEnumerable<Product> ModalProducts => _products.Where(p =>
        string.IsNullOrEmpty(_modalSearch) ||
        p.Name.Contains(_modalSearch, StringComparison.OrdinalIgnoreCase) ||
        p.Category.Contains(_modalSearch, StringComparison.OrdinalIgnoreCase)
    );

    private void OpenModal()  { _isModalOpen = true; _modalSearch = ""; _selectedProduct = null; }
    private void CloseModal() => _isModalOpen = false;

    private void SelectProduct(Product p) => _selectedProduct = p;

    private void AddSelectedToCart()
    {
        if (_selectedProduct == null) return;
        AddToCart(_selectedProduct);
        CloseModal();
    }

    private void AddToCart(Product p)
    {
        if (p.Stock == 0) return;
        var existing = _posCart.FirstOrDefault(i => i.Id == p.Id);
        if (existing != null)
        {
            if (existing.Quantity < p.Stock) existing.Quantity++;
        }
        else
        {
            _posCart.Add(new CartItem { Id = p.Id, Name = p.Name, Price = p.Price, Quantity = 1, Image = p.Image });
        }
    }

    private void RemoveFromCart(int productId)
    {
        var item = _posCart.FirstOrDefault(i => i.Id == productId);
        if (item != null) _posCart.Remove(item);
    }

    private void ChangeQty(int productId, int delta)
    {
        var item = _posCart.FirstOrDefault(i => i.Id == productId);
        if (item != null)
        {
            var prod = _products.FirstOrDefault(p => p.Id == productId);
            if (prod != null)
            {
                item.Quantity = Math.Clamp(item.Quantity + delta, 1, prod.Stock);
            }
        }
    }

    private decimal Subtotal => _posCart.Sum(i => i.Price * i.Quantity);
    private decimal Total    => Subtotal;

    private async Task ProcessSale()
    {
        if (!_posCart.Any()) return;
        _receiptId = $"VTA-{(SalesSvc.GetSales().Count + 1):D3}";
        SalesSvc.AddPresencialSale(_customerName, _posCart, Total, _payMethod, _invoiceType);
        foreach (var item in _posCart)
        {
            var p = _products.FirstOrDefault(pr => pr.Id == item.Id);
            if (p != null) p.Stock = Math.Max(0, p.Stock - item.Quantity);
        }
        _success = true;
        await Task.Delay(100);
    }

    private void ResetPOS()
    {
        _posCart.Clear();
        _customerName = "";
        _payMethod = "efectivo";
        _invoiceType = "ninguno";
        _success = false;
        _receiptId = "";
    }
}

<PageTitle>POS Caja Rápida – Shiligama</PageTitle>

<div class="container-fluid py-2">
    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">
                <i class="fas fa-cash-register me-2 text-primary"></i>Registrar Venta
            </h1>
            <p class="text-muted-foreground small mt-1 mb-0">Registra una nueva venta presencial</p>
        </div>
        <span class="badge bg-primary py-2 px-3" style="font-size:0.85rem;border-radius:var(--radius);">
            @($"VTA-{(SalesSvc.GetSales().Count + 1):D3}")
        </span>
    </div>
    @if (_success)
    {
        <div class="row justify-content-center py-4 fade-in">
            <div class="col-md-6 text-center">
                <div class="card p-5 d-flex flex-column align-items-center gap-3">
                    <div class="d-flex align-items-center justify-content-center bg-success text-white rounded-circle mb-2" style="width:72px; height:72px;">
                        <Icons Name="Check" style="width:36px; height:36px;" />
                    </div>
                    <h2 class="fs-4 fw-bold text-foreground">¡Venta Registrada Exitosamente!</h2>
                    <p class="text-muted-foreground small">Comprobante ID: <strong class="text-primary">@_receiptId</strong></p>
                    
                    <!-- simulated printed receipt card -->
                    <div class="card p-4 text-start w-100 bg-muted border-0 font-monospace text-xs mt-3" style="max-width:360px; font-size:0.8rem; line-height:1.4;">
                        <div class="text-center border-bottom border-dashed pb-2 mb-2">
                            <h4 class="fw-bold fs-6 m-0">SHILIGAMA MINIMARKET</h4>
                            <p class="text-xs text-muted-foreground m-0">Av. Larco 123, Trujillo</p>
                            <p class="text-xs text-muted-foreground m-0">RUC: 20123456789</p>
                        </div>
                        <p class="m-0"><strong>Fecha:</strong> @DateTime.Now.ToString("g")</p>
                        <p class="m-0"><strong>Nro Venta:</strong> @_receiptId</p>
                        <p class="m-0"><strong>Cliente:</strong> @(string.IsNullOrEmpty(_customerName) ? "Público General" : _customerName)</p>
                        <p class="m-0 border-bottom border-dashed pb-1 mb-2"><strong>Pago:</strong> @PayLabel(_payMethod) / Comprobante: @ComprobanteLabel(_invoiceType)</p>
                        
                        <div class="border-bottom border-dashed pb-1 mb-2">
                            @foreach (var item in _posCart)
                            {
                                <div class="d-flex justify-content-between">
                                    <span>@item.Name.PadRight(18).Substring(0,18) x@item.Quantity</span>
                                    <span>S/. @((item.Price * item.Quantity).ToString("0.00"))</span>
                                </div>
                            }
                        </div>
                        <div class="d-flex justify-content-between fw-bold fs-6 pt-1">
                            <span>TOTAL</span>
                            <span>S/. @Total.ToString("0.00")</span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 w-100 justify-content-center mt-3">
                        <button @onclick="ResetPOS" class="btn btn-primary px-4 py-2" style="border-radius: var(--radius);">
                            Nueva Venta
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Product selection column -->
            <div class="col-lg-7">
                <div class="d-flex flex-column gap-3">
                    <!-- Search header -->
                    <div class="card p-3">
                        <div class="position-relative">
                            <Icons Name="Search" Class="position-absolute top-50 translate-middle-y text-muted-foreground" style="left:14px;width:16px;height:16px;" />
                            <input type="search" @bind="_searchQuery" @bind:event="oninput" class="form-control text-foreground" placeholder="Buscar por producto o categoría..." style="padding-left:40px;" />
                        </div>
                    </div>

                    <!-- Products Grid -->
                    <div class="row g-3" style="max-height: calc(100vh - 220px); overflow-y: auto; padding: 2px;">
                        @foreach (var prod in FilteredProducts)
                        {
                            <div class="col-6 col-sm-4 col-md-3">
                                <div class="card h-100 d-flex flex-column cursor-pointer border border-color-default hover-shadow"
                                     @onclick="@(() => AddToCart(prod))"
                                     style="opacity: @(prod.Stock == 0 ? "0.6" : "1"); transition: transform .15s, box-shadow .15s;">
                                    <div class="position-relative">
                                        <img src="@prod.Image" class="w-100 object-fit-cover rounded-top" style="height:90px;" onerror="this.src='https://placehold.co/100x100/e8f5e9/1A6B3C?text=🛒'" />
                                        @if (prod.Stock < 10 && prod.Stock > 0)
                                        {
                                            <span class="badge bg-warning text-dark position-absolute bottom-0 end-0 m-1" style="font-size:0.65rem;">Stock: @prod.Stock</span>
                                        }
                                        else if (prod.Stock == 0)
                                        {
                                            <span class="badge bg-danger position-absolute bottom-0 end-0 m-1" style="font-size:0.65rem;">Sin Stock</span>
                                        }
                                    </div>
                                    <div class="p-2 d-flex flex-column flex-grow-1">
                                        <p class="text-xs fw-semibold text-foreground mb-1 text-line-clamp-2" style="font-size: 0.8rem; line-height: 1.25;">@prod.Name</p>
                                        <span class="fw-bold text-primary text-xs mt-auto">S/. @prod.Price.ToString("0.00")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Checkout Cart column -->
            <div class="col-lg-5">
                <div class="card p-4 d-flex flex-column gap-3 sticky-top" style="top:5rem; max-height:calc(100vh - 120px); overflow-y:auto;">
                    <div class="d-flex align-items-center justify-content-between mb-1 pb-2 border-bottom">
                        <h2 class="fs-5 fw-bold text-foreground mb-0">Cola de Cobro</h2>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-primary rounded-pill">@_posCart.Sum(i => i.Quantity) items</span>
                            <button class="btn btn-primary btn-sm d-flex align-items-center gap-1" @onclick="OpenModal" style="border-radius:var(--radius);font-size:0.78rem;">
                                <i class="fas fa-plus"></i> Producto
                            </button>
                        </div>
                    </div>

                    <!-- Cart items inside POS -->
                    <div class="d-flex flex-column gap-2 overflow-y-auto pr-1" style="max-height: 200px;">
                        @if (!_posCart.Any())
                        {
                            <p class="text-muted-foreground text-center py-4 small">Selecciona productos para iniciar el cobro</p>
                        }
                        else
                        {
                            @foreach (var item in _posCart)
                            {
                                <div class="d-flex align-items-center justify-content-between gap-3 p-2 bg-muted rounded-3" style="font-size: 0.85rem;">
                                    <div class="flex-grow-1 overflow-hidden">
                                        <p class="fw-semibold text-foreground m-0 text-truncate">@item.Name</p>
                                        <p class="text-xs text-muted-foreground m-0">S/. @item.Price.ToString("0.00") c/u</p>
                                    </div>
                                    <div class="d-flex align-items-center gap-1.5">
                                        <button @onclick="@(() => ChangeQty(item.Id, -1))" class="btn btn-outline-secondary btn-xs rounded-circle d-flex align-items-center justify-content-center" style="width:24px; height:24px; padding:0;">−</button>
                                        <span class="fw-medium text-foreground px-1 text-xs">@item.Quantity</span>
                                        <button @onclick="@(() => ChangeQty(item.Id, 1))" class="btn btn-outline-secondary btn-xs rounded-circle d-flex align-items-center justify-content-center" style="width:24px; height:24px; padding:0;">+</button>
                                        <button @onclick="@(() => RemoveFromCart(item.Id))" class="btn btn-link text-danger p-0 border-0 ms-2" style="font-size:0.85rem;">✕</button>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <!-- Client Info -->
                    <div>
                        <label class="form-label small fw-semibold text-foreground mb-1">Cliente (Opcional)</label>
                        <input type="text" @bind="_customerName" class="form-control form-control-sm text-foreground" placeholder="Público General" />
                    </div>

                    <!-- Document type selection -->
                    <div>
                        <label class="form-label small fw-semibold text-foreground mb-1">Comprobante</label>
                        <div class="d-flex gap-1">
                            @foreach (var inv in new[] { ("ninguno","Ticket"), ("boleta","Boleta"), ("factura","Factura") })
                            {
                                <button type="button" @onclick="@(() => _invoiceType = inv.Item1)" class="btn flex-fill btn-sm border @(_invoiceType == inv.Item1 ? "btn-primary" : "btn-secondary text-foreground")" style="border-radius: var(--radius); font-size: 0.75rem;">
                                    @inv.Item2
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Payment selector -->
                    <div>
                        <label class="form-label small fw-semibold text-foreground mb-1">Método de Pago</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <button type="button" @onclick='@(() => _payMethod="efectivo")' class="payment-btn @(_payMethod=="efectivo"?"active":"")">
                                <i class="fas fa-money-bill-wave"></i> Efectivo
                            </button>
                            <button type="button" @onclick='@(() => _payMethod="yape")' class="payment-btn @(_payMethod=="yape"?"active":"")">
                                <i class="fas fa-mobile-alt"></i> Yape
                            </button>
                            <button type="button" @onclick='@(() => _payMethod="plin")' class="payment-btn @(_payMethod=="plin"?"active":"")">
                                <i class="fas fa-mobile-alt"></i> Plin
                            </button>
                            <button type="button" @onclick='@(() => _payMethod="tarjeta")' class="payment-btn @(_payMethod=="tarjeta"?"active":"")">
                                <i class="fas fa-credit-card"></i> Tarjeta
                            </button>
                        </div>
                    </div>

                    <hr class="border-color-default my-1" />

                    <!-- Resumen con IGV -->
                    <div class="d-flex flex-column gap-1">
                        <div class="d-flex justify-content-between text-muted-foreground small">
                            <span>Subtotal (sin IGV)</span>
                            <span>S/. @SubtotalSinIgv.ToString("0.00")</span>
                        </div>
                        <div class="d-flex justify-content-between text-muted-foreground small">
                            <span>IGV (18%)</span>
                            <span>S/. @Igv.ToString("0.00")</span>
                        </div>
                        <hr class="border-color-default my-1" />
                        <div class="d-flex justify-content-between align-items-center fw-bold text-foreground">
                            <span class="fs-6">Total a Pagar</span>
                            <span class="fs-4 text-primary">S/. @Total.ToString("0.00")</span>
                        </div>
                    </div>

                    <button @onclick="ProcessSale" disabled="@(!_posCart.Any())" class="btn btn-primary w-100 fw-bold py-2 mt-1 d-flex align-items-center justify-content-center gap-2" style="border-radius:var(--radius);">
                        <i class="fas fa-check-circle"></i> Confirmar Venta
                    </button>
                    <button class="btn btn-secondary w-100 btn-sm d-flex align-items-center justify-content-center gap-2" style="border-radius:var(--radius);">
                        <i class="fas fa-file-invoice"></i> Generar Boleta
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal Agregar Producto -->
@if (_isModalOpen)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-container" @onclick:stopPropagation>
            <div class="p-4 border-bottom border-color-default d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="fw-bold text-foreground m-0"><i class="fas fa-search me-2"></i>Agregar Producto</h5>
                    <p class="text-muted-foreground small m-0">Busca por nombre o categoría</p>
                </div>
                <button class="btn btn-ghost p-1" @onclick="CloseModal" style="border-radius:50%;">
                    <i class="fas fa-times text-muted-foreground"></i>
                </button>
            </div>
            <div class="p-3">
                <div class="position-relative">
                    <i class="fas fa-search position-absolute top-50 translate-middle-y text-muted-foreground" style="left:12px;font-size:0.85rem;"></i>
                    <input type="search" @bind="_modalSearch" @bind:event="oninput"
                           class="form-control text-foreground"
                           placeholder="Buscar producto..."
                           style="padding-left:36px;"
                           autofocus />
                </div>
            </div>
            <div class="modal-body-scroll">
                @foreach (var prod in ModalProducts.Take(20))
                {
                    <div class="product-row-select @(_selectedProduct?.Id == prod.Id ? "selected" : "")"
                         @onclick="@(() => SelectProduct(prod))">
                        <div class="d-flex align-items-center gap-3">
                            <img src="@prod.Image" class="rounded-2 object-fit-cover flex-shrink-0"
                                 style="width:40px;height:40px;"
                                 onerror="this.src='https://placehold.co/40/e8f5e9/1A6B3C?text=P'" />
                            <div>
                                <div class="fw-semibold text-foreground small">@prod.Name</div>
                                <div class="text-muted-foreground" style="font-size:0.75rem;">
                                    Stock: @prod.Stock ud. — S/. @prod.Price.ToString("0.00")
                                </div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-bold text-primary small">S/. @prod.Price.ToString("0.00")</span>
                            @if (prod.Stock == 0)
                            {
                                <span class="badge bg-danger" style="font-size:0.65rem;">Sin stock</span>
                            }
                        </div>
                    </div>
                }
                @if (!ModalProducts.Any())
                {
                    <p class="text-muted-foreground text-center py-4 small">No se encontraron productos</p>
                }
            </div>
            <div class="p-3 border-top border-color-default d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="CloseModal" style="border-radius:var(--radius);">Cancelar</button>
                <button class="btn btn-primary fw-semibold" @onclick="AddSelectedToCart" disabled="@(_selectedProduct == null || _selectedProduct.Stock == 0)" style="border-radius:var(--radius);">
                    <i class="fas fa-plus me-1"></i>Agregar al cobro
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string PayLabel(string method) => method.ToUpper() switch
    {
        "EFECTIVO" => "EFECTIVO",
        "TARJETA" => "TARJETA CR/DB",
        "YAPE" => "YAPE",
        "PLIN" => "PLIN",
        _ => method
    };

    private string ComprobanteLabel(string comp) => comp.ToUpper() switch
    {
        "BOLETA" => "BOLETA DE VENTA",
        "FACTURA" => "FACTURA",
        _ => "TICKET DE VENTA"
    };
}
