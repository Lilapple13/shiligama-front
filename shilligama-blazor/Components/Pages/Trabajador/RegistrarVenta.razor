@page "/trabajador/registrar-venta"
@layout TrabajadorLayout
@inject ProductService ProductSvc
@inject SalesService SalesSvc

@code {
    private List<Product> _products = new();
    private List<CartItem> _posCart = new();
    
    // Modal state
    private bool _isModalOpen = false;
    private string _modalSearch = "";
    private Product? _selectedProduct = null;
    private int _selectedQuantity = 1;
    
    // POS state
    private string _customerName = "";
    private string _payMethod = "efectivo";
    private string _invoiceType = "boleta";
    private bool _success = false;
    private string _receiptId = "";
    private bool _showBoletaModal = false;

    // Financial calculations
    private decimal Subtotal => _posCart.Sum(i => i.Price * i.Quantity);
    private decimal SubtotalSinIgv => Subtotal / 1.18m;
    private decimal Igv => Subtotal - SubtotalSinIgv;
    private decimal Total => Subtotal;

    protected override void OnInitialized()
    {
        _products = ProductSvc.GetProducts();
    }

    private IEnumerable<Product> ModalProducts => _products.Where(p =>
        string.IsNullOrEmpty(_modalSearch) ||
        p.Name.Contains(_modalSearch, StringComparison.OrdinalIgnoreCase) ||
        p.Category.Contains(_modalSearch, StringComparison.OrdinalIgnoreCase)
    );

    private void OpenModal()  
    { 
        _isModalOpen = true; 
        _modalSearch = ""; 
        _selectedProduct = null; 
        _selectedQuantity = 1;
    }
    
    private void CloseModal() => _isModalOpen = false;

    private void SelectProduct(Product p) 
    {
        _selectedProduct = p;
        _selectedQuantity = 1; // Reset quantity on new selection
    }

    private void UpdateSelectedQuantity(int delta)
    {
        if (_selectedProduct != null)
        {
            _selectedQuantity = Math.Clamp(_selectedQuantity + delta, 1, _selectedProduct.Stock);
        }
    }

    private void AddSelectedToCart()
    {
        if (_selectedProduct == null || _selectedQuantity <= 0) return;
        
        var existing = _posCart.FirstOrDefault(i => i.Id == _selectedProduct.Id);
        if (existing != null)
        {
            existing.Quantity = Math.Min(existing.Quantity + _selectedQuantity, _selectedProduct.Stock);
        }
        else
        {
            _posCart.Add(new CartItem 
            { 
                Id = _selectedProduct.Id, 
                Name = _selectedProduct.Name, 
                Price = _selectedProduct.Price, 
                Quantity = _selectedQuantity, 
                Image = _selectedProduct.Image 
            });
        }
        CloseModal();
    }

    private void RemoveFromCart(int productId)
    {
        var item = _posCart.FirstOrDefault(i => i.Id == productId);
        if (item != null) _posCart.Remove(item);
    }

    private async Task ProcessSale(string type)
    {
        if (!_posCart.Any()) return;
        _invoiceType = type;
        
        _receiptId = $"VTA-{(SalesSvc.GetSales().Count + 1):D4}";
        SalesSvc.AddPresencialSale(_customerName, _posCart, Total, _payMethod, _invoiceType);
        
        foreach (var item in _posCart)
        {
            var p = _products.FirstOrDefault(pr => pr.Id == item.Id);
            if (p != null) p.Stock = Math.Max(0, p.Stock - item.Quantity);
        }
        
        _success = true;
        _showBoletaModal = false;
        await Task.Delay(100);
    }

    private void OpenBoletaModal()
    {
        if (!_posCart.Any()) return;
        _receiptId = $"VTA-{(SalesSvc.GetSales().Count + 1):D4}";
        _showBoletaModal = true;
    }

    private void CloseBoletaModal() => _showBoletaModal = false;

    private void ResetPOS()
    {
        _posCart.Clear();
        _customerName = "";
        _payMethod = "efectivo";
        _invoiceType = "boleta";
        _success = false;
        _receiptId = "";
    }
}

<PageTitle>Registrar Venta – Shiligama</PageTitle>

@if (_success)
{
    <div class="container-fluid py-4 fade-in h-100 bg-slate-50 d-flex align-items-center justify-content-center">
        <div class="card p-5 d-flex flex-column align-items-center gap-3 shadow-sm border-0" style="border-radius: var(--radius); max-width: 500px; width: 100%;">
            <div class="d-flex align-items-center justify-content-center bg-success text-white rounded-circle mb-2" style="width:72px; height:72px;">
                <Icons Name="Check" style="width:36px; height:36px;" />
            </div>
            <h2 class="fs-4 fw-bold text-foreground text-center">¡Venta Registrada Exitosamente!</h2>
            <p class="text-muted-foreground small text-center">Transacción procesada bajo el ID: <strong class="text-primary">@_receiptId</strong></p>
            
            <div class="w-100 bg-muted rounded p-3 text-start mt-2">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted-foreground small">Total Pagado:</span>
                    <span class="fw-bold text-primary">S/. @Total.ToString("0.00")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted-foreground small">Método:</span>
                    <span class="fw-medium text-foreground text-capitalize">@_payMethod</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted-foreground small">Comprobante:</span>
                    <span class="fw-medium text-foreground text-capitalize">@_invoiceType</span>
                </div>
            </div>

            <div class="d-flex gap-2 w-100 justify-content-center mt-4">
                <button @onclick="ResetPOS" class="btn btn-primary px-4 py-2 w-100" style="border-radius: var(--radius); font-weight: 600;">
                    Registrar Nueva Venta
                </button>
            </div>
        </div>
    </div>
}
else
{
    <div class="bg-slate-50 min-vh-100 w-100 p-4">
        
        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="page-title mb-0">Registrar Venta</h1>
                <p class="page-subtitle" style="font-size: 0.85rem;">Registra una nueva venta presencial</p>
            </div>
            <div class="bg-card border border-color-default px-4 py-2 fw-bold text-foreground d-flex align-items-center" style="border-radius: 0.6rem; font-size: 1.25rem; font-family: monospace; letter-spacing: 0.75px;">
                @($"VTA-{(SalesSvc.GetSales().Count + 1):D4}")
            </div>
        </div>

        <div class="d-flex flex-column gap-3">
            
            <!-- Bloque Superior: Líneas de Venta -->
            <div class="card bg-card border border-color-default shadow-sm w-100" style="border-radius: 1rem;">
                <!-- Card Header -->
                <div class="p-4 border-bottom border-color-default d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-foreground" style="font-size: 1.05rem;">Líneas de Venta</h5>
                    <button class="btn btn-primary btn-sm d-flex align-items-center gap-2 fw-semibold" @onclick="OpenModal" style="border-radius: var(--radius);">
                        <i class="fas fa-plus"></i> Agregar Producto
                    </button>
                </div>

                <!-- Card Body -->
                <div class="p-0">
                    @if (!_posCart.Any())
                    {
                        <!-- Empty State -->
                        <div class="d-flex flex-column align-items-center justify-content-center py-5 text-center" style="min-height: 250px;">
                            <i class="fas fa-receipt text-muted-foreground opacity-50 mb-3" style="font-size: 3.5rem;"></i>
                            <h6 class="text-foreground fw-semibold mb-1">No hay productos agregados</h6>
                            <p class="page-subtitle mb-0">Haz clic en "Agregar Producto" para comenzar</p>
                        </div>
                    }
                    else
                    {
                        <!-- Products Table -->
                        <div class="table-responsive">
                            <table class="table table-borderless align-middle mb-0">
                                <thead class="border-bottom border-color-default table-head-muted">
                                    <tr>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing: .05em; width: 15%;">Código</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing: .05em; width: 35%;">Nombre</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing: .05em; width: 15%;">Cantidad</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing: .05em; width: 15%;">Precio Unit.</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing: .05em; width: 15%;">Subtotal</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing: .05em; width: 5%;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in _posCart)
                                    {
                                        <tr class="border-bottom border-color-default animate-fade-in" style="background-color: var(--card);">
                                            <td class="px-4 py-3 text-muted-foreground small fw-medium">@item.Id.ToString("D4")</td>
                                            <td class="px-4 py-3 fw-bold text-foreground small">@item.Name</td>
                                            <td class="px-4 py-3 text-center text-foreground fw-semibold small">@item.Quantity</td>
                                            <td class="px-4 py-3 text-end text-muted-foreground small">S/ @item.Price.ToString("0.00")</td>
                                            <td class="px-4 py-3 text-end text-foreground fw-bold small">S/ @((item.Price * item.Quantity).ToString("0.00"))</td>
                                            <td class="px-4 py-3 text-center">
                                                <button class="btn btn-link text-danger p-0 m-0 text-decoration-none hover-opacity" @onclick="@(() => RemoveFromCart(item.Id))" title="Eliminar">
                                                    <i class="far fa-trash-alt"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="row g-3">
                <!-- Bloque Inferior Izquierdo: Resumen -->
                <div class="col-12 col-md-5 col-lg-4">
                    <div class="card bg-card border border-color-default shadow-sm w-100 h-100" style="border-radius: 1rem;">
                        <div class="p-4 border-bottom border-color-default">
                            <h5 class="m-0 fw-bold text-foreground" style="font-size: 1.05rem;">Resumen</h5>
                        </div>
                        <div class="p-4 d-flex flex-column justify-content-between h-100">
                            <div class="d-flex flex-column gap-3 mb-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted-foreground small">Subtotal</span>
                                    <span class="fw-medium text-foreground small">S/ @SubtotalSinIgv.ToString("0.00")</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted-foreground small">IGV (18%)</span>
                                    <span class="fw-medium text-foreground small">S/ @Igv.ToString("0.00")</span>
                                </div>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-color-default mt-auto">
                                <span class="fw-bold text-foreground" style="font-size: 1.1rem;">Total</span>
                                <span class="fw-bold text-primary" style="font-size: 1.25rem;">S/ @Total.ToString("0.00")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bloque Inferior Derecho: Método de Pago -->
                <div class="col-12 col-md-7 col-lg-8">
                    <div class="card bg-card border border-color-default shadow-sm w-100 h-100" style="border-radius: 1rem;">
                        <div class="p-4 border-bottom border-color-default">
                            <h5 class="m-0 fw-bold text-foreground" style="font-size: 1.05rem;">Método de Pago</h5>
                        </div>
                        <div class="p-4 d-flex align-items-center">
                            <div class="d-flex gap-3 flex-wrap w-100">
                                <button type="button" @onclick='@(() => _payMethod="efectivo")' class="btn payment-method-btn flex-grow-1 @(_payMethod=="efectivo"?"active":"")">
                                    <i class="fas fa-money-bill-wave"></i> Efectivo
                                </button>
                                <button type="button" @onclick='@(() => _payMethod="yape")' class="btn payment-method-btn flex-grow-1 @(_payMethod=="yape"?"active":"")">
                                    <i class="fas fa-mobile-alt"></i> Yape
                                </button>
                                <button type="button" @onclick='@(() => _payMethod="plin")' class="btn payment-method-btn flex-grow-1 @(_payMethod=="plin"?"active":"")">
                                    <i class="fas fa-mobile-alt"></i> Plin
                                </button>
                                <button type="button" @onclick='@(() => _payMethod="tarjeta")' class="btn payment-method-btn flex-grow-1 @(_payMethod=="tarjeta"?"active":"")">
                                    <i class="fas fa-credit-card"></i> Tarjeta
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Footer Buttons -->
            @if (_posCart.Any())
            {
                <div class="d-flex justify-content-end gap-3 mt-3 animate-fade-in pb-4">
                    <button class="btn btn-primary fw-semibold d-flex align-items-center gap-2 px-4 shadow-sm" @onclick="OpenBoletaModal" style="border-radius: var(--radius); height: 44px;">
                        <i class="fas fa-receipt"></i> Generar Boleta
                    </button>
                </div>
            }

        </div>
    </div>
}

<!-- Modal Agregar Producto -->
@if (_isModalOpen)
{
    <div class="modal-overlay d-flex align-items-center justify-content-center" style="background-color: rgba(0,0,0,0.55); position: fixed; inset: 0; z-index: 1050;" @onclick="CloseModal">
        <div class="bg-card shadow-lg d-flex flex-column animate-fade-in" style="width: 100%; max-width: 500px; border-radius: 1rem; max-height: 90vh; overflow: hidden;" @onclick:stopPropagation>
            
            <!-- Modal Header -->
            <div class="p-4 d-flex justify-content-between align-items-start pb-3">
                <div>
                    <h5 class="fw-bold text-foreground mb-1" style="font-size: 1.15rem;">Agregar Producto</h5>
                    <p class="text-muted-foreground small m-0" style="font-size: 0.85rem;">Busca por nombre o código de barras</p>
                </div>
                <button class="btn btn-link text-muted-foreground p-0 m-0 text-decoration-none" style="font-size: 1.2rem;" @onclick="CloseModal">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <!-- Modal Search Input -->
            <div class="px-4 pb-3">
                <div class="position-relative">
                    <i class="fas fa-search position-absolute text-muted-foreground" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 0.9rem;"></i>
                    <input type="search" @bind="_modalSearch" @bind:event="oninput"
                           class="form-control text-foreground w-100"
                           placeholder="Buscar producto..."
                           style="padding-left: 40px; border-radius: 0.5rem; height: 42px; font-size: 0.9rem;"
                           autofocus />
                </div>
            </div>

            <!-- Modal Results List (Scrollable) -->
            <div class="overflow-y-auto px-4 pb-2 border-bottom border-color-default" style="max-height: 300px;">
                <div class="d-flex flex-column gap-2">
                    @foreach (var prod in ModalProducts.Take(15))
                    {
                        bool isSelected = _selectedProduct?.Id == prod.Id;
                        <div class="p-3 d-flex justify-content-between align-items-center cursor-pointer border @(isSelected ? "product-picker-selected" : "")" 
                             style="border-radius: 0.5rem; transition: all 0.2s;"
                             @onclick="@(() => SelectProduct(prod))">
                            
                            <div class="d-flex flex-column">
                                <span class="fw-bold text-foreground" style="font-size: 0.9rem;">@prod.Name</span>
                                <span class="text-muted-foreground" style="font-size: 0.75rem;">Código: @prod.Id | Stock: @prod.Stock</span>
                            </div>
                            <span class="fw-bold text-foreground" style="font-size: 0.95rem;">S/ @prod.Price.ToString("0.00")</span>
                        </div>
                    }
                    @if (!ModalProducts.Any())
                    {
                        <div class="text-center py-4">
                            <p class="text-muted-foreground small m-0">No se encontraron productos coincidentes.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Modal Footer Form -->
            <div class="p-4 bg-card mt-auto border-top border-color-default">
                <div class="p-3 mb-4 pos-summary-box" style="border-radius: 0.5rem;">
                    
                    <div class="d-flex justify-content-between mb-2 align-items-center">
                        <span class="text-muted-foreground small">Producto seleccionado</span>
                        <span class="fw-bold text-foreground small">@(_selectedProduct?.Name ?? "-")</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-2 align-items-center">
                        <span class="text-muted-foreground small">Código</span>
                        <span class="fw-medium text-foreground small">@(_selectedProduct?.Id.ToString() ?? "-")</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3 align-items-center">
                        <span class="text-muted-foreground small">Precio unitario</span>
                        <span class="fw-medium text-foreground small">@(_selectedProduct != null ? $"S/ {_selectedProduct.Price.ToString("0.00")}" : "-")</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted-foreground small">Cantidad</span>
                        <div class="input-group" style="width: 100px;">
                            <input type="number" class="form-control form-control-sm text-center fw-medium bg-card" @bind="_selectedQuantity" @bind:event="oninput" min="1" max="@(_selectedProduct?.Stock ?? 1)" disabled="@(_selectedProduct == null)" style="border-radius: 0.375rem;" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center pt-2 border-top" style="border-color: rgba(6, 68, 32, 0.1) !important;">
                        <span class="fw-bold text-foreground small">Subtotal</span>
                        <span class="fw-bold text-primary" style="font-size: 1.1rem;">
                            @(_selectedProduct != null ? $"S/ {(_selectedProduct.Price * _selectedQuantity).ToString("0.00")}" : "S/ 0.00")
                        </span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <button class="btn btn-white border px-4" @onclick="CloseModal" style="border-radius: 0.5rem; font-weight: 500; font-size: 0.9rem; border-color: #dee2e6;">Cancelar</button>
                    <button class="btn btn-primary px-4 fw-semibold" @onclick="AddSelectedToCart" disabled="@(_selectedProduct == null)" style="border-radius: var(--radius);">Agregar Línea</button>
                </div>
            </div>

        </div>
    </div>
}

<style>
    .bg-slate-50 {
        background-color: #f8f9fa !important;
    }
    
    .payment-method-btn {
        background-color: var(--card);
        border: 1px solid var(--border);
        color: var(--foreground);
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        font-size: 0.95rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.2s ease;
        min-height: 56px;
        flex: 1 1 0px;
        min-width: 100px;
    }

    .payment-method-btn:hover {
        background-color: var(--secondary);
        border-color: var(--border);
    }

    .payment-method-btn.active {
        background-color: color-mix(in srgb, var(--primary) 10%, var(--card));
        border-color: var(--primary);
        color: var(--primary);
        font-weight: 600;
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 15%, transparent);
    }

    .pos-summary-box {
        background-color: color-mix(in srgb, var(--primary) 6%, var(--card));
