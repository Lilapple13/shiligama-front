</style>

<!-- Modal Boleta Simulada -->
@if (_showBoletaModal)
{
    <div class="detail-modal-overlay" @onclick="CloseBoletaModal">
        <div style="max-width: 420px; width: 100%; background: transparent;" @onclick:stopPropagation>

            <!-- Ticket Receipt -->
            <div class="boleta-ticket">
                <!-- Ticket Header -->
                <div class="boleta-header">
                    <div class="boleta-logo">🛒</div>
                    <div class="boleta-brand">SHILIGAMA S.A.C.</div>
                    <div class="boleta-ruc">RUC: 20784918239</div>
                    <div class="boleta-address">Av. Los Frutales 215, Lima, Perú</div>
                    <div class="boleta-divider">- - - - - - - - - - - - - - - - - - - -</div>
                    <div class="boleta-type">BOLETA DE VENTA ELECTRÓNICA</div>
                    <div class="boleta-id">@_receiptId</div>
                    <div class="boleta-date">@DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")</div>
                    <div class="boleta-divider">- - - - - - - - - - - - - - - - - - - -</div>
                </div>

                <!-- Customer -->
                <div class="boleta-customer">
                    <span class="boleta-label">CLIENTE:</span>
                    <span class="boleta-val">@(string.IsNullOrEmpty(_customerName) ? "Consumidor Final" : _customerName)</span>
                </div>
                <div class="boleta-customer">
                    <span class="boleta-label">PAGO:</span>
                    <span class="boleta-val text-capitalize">@_payMethod</span>
                </div>
                <div class="boleta-divider mt-2">- - - - - - - - - - - - - - - - - - - -</div>

                <!-- Products -->
                <div class="boleta-products-header">
                    <span>DESCRIPCIÓN</span>
                    <span>CANT.</span>
                    <span class="text-end">TOTAL</span>
                </div>
                <div class="boleta-divider mb-2">- - - - - - - - - - - - - - - - - - - -</div>

                @foreach (var item in _posCart)
                {
                    <div class="boleta-product-row">
                        <span class="boleta-product-name">@item.Name</span>
                        <span class="boleta-product-qty">@item.Quantity</span>
                        <span class="boleta-product-total">S/ @((item.Price * item.Quantity).ToString("0.00"))</span>
                    </div>
                    <div class="boleta-product-unitprice">S/ @item.Price.ToString("0.00") c/u</div>
                }

                <div class="boleta-divider mt-2">- - - - - - - - - - - - - - - - - - - -</div>

                <!-- Totals -->
                <div class="boleta-totals">
                    <div class="boleta-total-row">
                        <span>SUBTOTAL (sin IGV)</span>
                        <span>S/ @SubtotalSinIgv.ToString("0.00")</span>
                    </div>
                    <div class="boleta-total-row">
                        <span>IGV (18%)</span>
                        <span>S/ @Igv.ToString("0.00")</span>
                    </div>
                    <div class="boleta-divider">- - - - - - - - - - - - - - - - - - - -</div>
                    <div class="boleta-total-row boleta-grand-total">
                        <span>TOTAL</span>
                        <span>S/ @Total.ToString("0.00")</span>
                    </div>
                </div>

                <div class="boleta-divider mt-2 mb-3">- - - - - - - - - - - - - - - - - - - -</div>
                <div class="boleta-footer-msg">Gracias por su preferencia</div>
                <div class="boleta-footer-msg" style="font-size: 0.7rem; margin-top: 2px; opacity: 0.6;">www.shiligama.pe</div>

                <div class="boleta-divider mt-3">- - - - - - - - - - - - - - - - - - - -</div>

                <!-- Confirm Button -->
                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-outline-secondary flex-shrink-0" @onclick="CloseBoletaModal" style="border-radius: var(--radius); font-size: 0.85rem;">
                        <i class="fas fa-times me-1"></i>Cancelar
                    </button>
                    <button class="btn btn-success fw-bold flex-grow-1" @onclick='@(() => ProcessSale("boleta"))' style="border-radius: var(--radius); font-size: 0.9rem;">
                        <i class="fas fa-check-circle me-2"></i>Confirmar Venta
                    </button>
                </div>
            </div>

        </div>
    </div>
}

