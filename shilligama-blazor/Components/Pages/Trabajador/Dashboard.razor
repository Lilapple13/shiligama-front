@page "/trabajador"
@layout TrabajadorLayout
@inject SalesService SalesSvc

@code {
    private List<Order> _allOrders = new();
    private string _searchTerm = "";
    private string _selectedFilter = "todos";
    private Order? _detailOrder = null;
    private bool _showDetailModal = false;

    private int _currentPage = 1;
    private int _pageSize = 6;

    protected override void OnInitialized() => RefreshList();

    private void RefreshList()
    {
        _allOrders = SalesSvc.GetRecentOrders();
    }

    private IEnumerable<Order> FilteredOrders => _allOrders.Where(o =>
    {
        bool matchSearch = string.IsNullOrEmpty(_searchTerm) ||
            o.Id.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
            o.Customer.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase);

        bool matchFilter = _selectedFilter switch
        {
            "pendiente"   => o.Status == "pendiente",
            "preparando"  => o.Status == "preparando",
            "en_camino"   => o.Status == "en_camino",
            "entregado"   => o.Status == "entregado",
            "cancelado"   => o.Status == "cancelado",
            _             => true
        };
        return matchSearch && matchFilter;
    });

    private int CountByStatus(string s)  => _allOrders.Count(o => o.Status == s);
    private void SetFilter(string f)
    {
        _selectedFilter = f;
        _currentPage = 1;
    }

    private void UpdateStatus(string id, string newStatus)
    {
        SalesSvc.UpdateOrderStatus(id, newStatus);
        RefreshList();
        if (_detailOrder?.Id == id)
            _detailOrder = _allOrders.FirstOrDefault(o => o.Id == id);
    }

    private void VerDetalle(Order o) { _detailOrder = o; _showDetailModal = true; }
    private void CloseModal()        => _showDetailModal = false;
    private void ClearSearch()       { _searchTerm = ""; _currentPage = 1; }

    private void SiguienteAccion(Order o)
    {
        var next = o.Status switch
        {
            "pendiente"  => "preparando",
            "preparando" => "en_camino",
            "en_camino"  => "entregado",
            _ => ""
        };
        if (!string.IsNullOrEmpty(next)) UpdateStatus(o.Id, next);
    }

    private void CancelarOrder(Order o) => UpdateStatus(o.Id, "cancelado");

    private string GetStatusLabel(string s) => s switch
    {
        "pendiente"  => "Pendiente",
        "preparando" => "En preparación",
        "en_camino"  => "Listo para entrega",
        "entregado"  => "Entregado",
        "cancelado"  => "Cancelado",
        _            => s
    };

    private string GetStatusBadgeClass(string s) => s switch
    {
        "pendiente"  => "status-badge status-pendiente",
        "preparando" => "status-badge status-preparando",
        "en_camino"  => "status-badge status-en_camino",
        "entregado"  => "status-badge status-entregado",
        "cancelado"  => "status-badge status-cancelado",
        _            => "status-badge bg-secondary text-foreground"
    };

    private string GetLeftBorderClass(string s) => s switch
    {
        "pendiente"  => "border-left-pendiente",
        "preparando" => "border-left-preparando",
        "en_camino"  => "border-left-listo",
        "entregado"  => "border-left-entregado",
        "cancelado"  => "border-left-cancelado",
        _            => ""
    };

    private string GetElapsedTime(DateTime date)
    {
        var diff = DateTime.Now - date;
        if (diff.TotalMinutes < 1) return "Hace unos segundos";
        if (diff.TotalMinutes < 60) return $"Hace {Math.Floor(diff.TotalMinutes)} min";
        if (diff.TotalHours < 24) return $"Hace {Math.Floor(diff.TotalHours)} h";
        return $"Hace {Math.Floor(diff.TotalDays)} días";
    }

    private string GetNextActionLabel(string s) => s switch
    {
        "pendiente"  => "Iniciar Preparación",
        "preparando" => "Marcar listo",
        "en_camino"  => "Marcar entregado",
        _            => ""
    };

    private int TotalPages(int totalCount) => (int)Math.Ceiling((double)totalCount / _pageSize);

    private void SetPage(int p) => _currentPage = p;

    private void NextPage(int totalCount)
    {
        if (_currentPage < TotalPages(totalCount)) _currentPage++;
    }

    private void PrevPage()
    {
        if (_currentPage > 1) _currentPage--;
    }

    private IEnumerable<Order> PaginatedOrders(IEnumerable<Order> filtered)
    {
        int total = filtered.Count();
        int maxPages = TotalPages(total);
        if (_currentPage > maxPages && maxPages > 0)
        {
            _currentPage = maxPages;
        }
        else if (maxPages == 0)
        {
            _currentPage = 1;
        }
        return filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    }
}

<PageTitle>Gestión de Pedidos – Shiligama</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Métricas -->
    <div class="row g-3">
        <div class="col-6 col-xl-3">
            <div class="worker-kpi-card kpi-pendiente">
                <div class="metric-kpi-icon kpi-icon-pending">
                    <i class="fas fa-clock"></i>
                </div>
                <div>
                    <div class="metric-kpi-value text-foreground">@CountByStatus("pendiente")</div>
                    <div class="metric-kpi-label">Pendientes</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="worker-kpi-card kpi-preparando">
                <div class="metric-kpi-icon kpi-icon-preparing">
                    <i class="fas fa-box-open"></i>
                </div>
                <div>
                    <div class="metric-kpi-value text-foreground">@CountByStatus("preparando")</div>
                    <div class="metric-kpi-label">En preparación</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="worker-kpi-card kpi-encamino">
                <div class="metric-kpi-icon kpi-icon-primary">
                    <i class="fas fa-truck"></i>
                </div>
                <div>
                    <div class="metric-kpi-value text-foreground">@CountByStatus("en_camino")</div>
                    <div class="metric-kpi-label">En camino</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="worker-kpi-card kpi-entregado">
                <div class="metric-kpi-icon kpi-icon-purple">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div>
                    <div class="metric-kpi-value text-foreground">@CountByStatus("entregado")</div>
                    <div class="metric-kpi-label">Entregados hoy</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Encabezado Listado de pedidos -->
    <div class="mt-2 mb-1">
        <h2 class="page-title page-title-lg mb-0">Listado de pedidos</h2>
        <p class="page-subtitle mb-0">Visualiza y gestiona las solicitudes en tiempo real</p>
    </div>

    <!-- Búsqueda + Filtros -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 bg-card p-3 border border-color-default shadow-sm" style="border-radius: var(--radius);">
        <div class="filter-pills flex-grow-1">
            <button class="filter-pill @(_selectedFilter=="todos"?"active":"")"      @onclick='@(()=>SetFilter("todos"))'>
                Todos (@_allOrders.Count)
            </button>
            <button class="filter-pill @(_selectedFilter=="pendiente"?"active":"")"  @onclick='@(()=>SetFilter("pendiente"))'>
                <i class="fas fa-clock me-1"></i>Pendientes (@CountByStatus("pendiente"))
            </button>
            <button class="filter-pill @(_selectedFilter=="preparando"?"active":"")" @onclick='@(()=>SetFilter("preparando"))'>
                <i class="fas fa-box-open me-1"></i>En preparación (@CountByStatus("preparando"))
            </button>
            <button class="filter-pill @(_selectedFilter=="en_camino"?"active":"")"  @onclick='@(()=>SetFilter("en_camino"))'>
                <i class="fas fa-truck me-1"></i>Listos para entrega (@CountByStatus("en_camino"))
            </button>
            <button class="filter-pill @(_selectedFilter=="entregado"?"active":"")"  @onclick='@(()=>SetFilter("entregado"))'>
                <i class="fas fa-check-circle me-1"></i>Entregados (@CountByStatus("entregado"))
            </button>
            <button class="filter-pill @(_selectedFilter=="cancelado"?"active":"")"  @onclick='@(()=>SetFilter("cancelado"))'>
                <i class="fas fa-times me-1"></i>Cancelados (@CountByStatus("cancelado"))
            </button>
        </div>

        <div class="d-flex align-items-center gap-2" style="max-width: 420px; width: 100%;">
            <div class="position-relative flex-grow-1">
                <i class="fas fa-search position-absolute top-50 translate-middle-y text-muted-foreground" style="left:14px;font-size:0.85rem;"></i>
                <input type="search" @bind="_searchTerm" @bind:event="oninput"
                       class="form-control text-foreground"
                       placeholder="Buscar por # orden o cliente..."
                       style="padding-left:38px; padding-top: 0.45rem; padding-bottom: 0.45rem;" />
            </div>
            <button class="btn btn-secondary btn-sm d-flex align-items-center gap-2 flex-shrink-0" @onclick="ClearSearch" style="border-radius:var(--radius); padding: 0.45rem 0.9rem; font-weight: 500;">
                <i class="fas fa-times-circle"></i> Limpiar
            </button>
        </div>
    </div>

    <!-- Grid de Pedidos -->
    @if (!FilteredOrders.Any())
    {
        <div class="card p-5 text-center">
            <i class="fas fa-clipboard-list text-muted-foreground mb-3" style="font-size:2.5rem;"></i>
            <h3 class="text-foreground fw-semibold fs-5">Sin pedidos</h3>
            <p class="text-muted-foreground small m-0">No hay pedidos que coincidan con los filtros seleccionados.</p>
        </div>
    }
    else
    {
        <div class="orders-grid">
            @foreach (var order in PaginatedOrders(FilteredOrders))
            {
                <div class="custom-order-card @GetLeftBorderClass(order.Status)">
                    <!-- Fila 1 (Cabecera) -->
                    <div class="d-flex justify-content-between align-items-center w-100">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-bold text-foreground text-sm" style="font-size: 0.88rem;">@order.Id</span>
                            <span class="@GetStatusBadgeClass(order.Status)">
                                @GetStatusLabel(order.Status)
                            </span>
                        </div>
                        
                        @if (order.DeliveryMethod?.ToLower() == "delivery")
                        {
                            <span class="badge channel-online"><i class="fas fa-truck me-2"></i> Delivery</span>
                        }
                        else
                        {
                            <span class="badge channel-store"><i class="fas fa-store me-2"></i> Recojo</span>
                        }
                    </div>

                    <!-- Fila 2 (Tiempo transcurrido) -->
                    <div class="text-muted-foreground small d-flex align-items-center gap-2" style="font-size: 0.76rem;">
                        <i class="far fa-clock text-muted-foreground" style="font-size: 0.8rem;"></i>
                        <span>@GetElapsedTime(order.Date)</span>
                    </div>

                    <!-- Fila 3 (Bloque de Datos del Cliente - Caja gris contenedora) -->
                    <div class="p-3 my-1 order-info-box">
                        <div class="fw-bold text-foreground text-sm" style="font-size: 0.85rem;">@order.Customer</div>
                        <div class="text-muted-foreground text-xs mt-1.5 d-flex align-items-center gap-2" style="font-size: 0.76rem;">
                            <i class="fas fa-phone-alt" style="color: #6c757d; font-size: 0.72rem;"></i>
                            <span>987 654 321</span>
                        </div>
                        @if (order.DeliveryMethod?.ToLower() == "delivery" && !string.IsNullOrEmpty(order.Address))
                        {
                            <div class="text-muted-foreground text-xs mt-2 d-flex align-items-start gap-2" style="font-size: 0.76rem; line-height: 1.3;">
                                <i class="fas fa-map-marker-alt mt-0.5" style="color: #6c757d; font-size: 0.75rem;"></i>
                                <span>@order.Address</span>
                            </div>
                        }
                    </div>

                    <!-- Fila 4 (Resumen de Compra) -->
                    <div class="d-flex justify-content-between align-items-center py-1">
                        <span class="text-muted-foreground" style="font-size: 0.78rem;">@order.Items @(order.Items == 1 ? "producto" : "productos")</span>
                        <span class="price-display" style="font-size: 1.22rem;">S/. @order.Total.ToString("0.00")</span>
                    </div>

                    <!-- Fila 5 (Método y Estado de Pago) -->
                    <div class="d-flex gap-1.5 py-1">
                        @switch (order.PaymentMethod?.ToLower())
                        {
                            case "yape":
                                <span class="badge text-white" style="background: #6f42c1; font-size: 0.7rem; padding: 0.25rem 0.5rem; font-weight: 600;">Yape</span>
                                <span class="badge bg-success-subtle text-success" style="font-size: 0.7rem; padding: 0.25rem 0.5rem; border: 1px solid rgba(25, 135, 84, 0.2); font-weight: 600;">Pagado</span>
                                break;
                            case "plin":
                                <span class="badge text-white" style="background: #0dcaf0; font-size: 0.7rem; padding: 0.25rem 0.5rem; font-weight: 600;">Plin</span>
                                <span class="badge bg-success-subtle text-success" style="font-size: 0.7rem; padding: 0.25rem 0.5rem; border: 1px solid rgba(25, 135, 84, 0.2); font-weight: 600;">Pagado</span>
                                break;
                            case "tarjeta":
                                <span class="badge text-white" style="background: #0d6efd; font-size: 0.7rem; padding: 0.25rem 0.5rem; font-weight: 600;">Tarjeta</span>
                                <span class="badge bg-success-subtle text-success" style="font-size: 0.7rem; padding: 0.25rem 0.5rem; border: 1px solid rgba(25, 135, 84, 0.2); font-weight: 600;">Pagado</span>
                                break;
                            default:
                                <span class="badge text-white" style="background: #198754; font-size: 0.7rem; padding: 0.25rem 0.5rem; font-weight: 600;">Efectivo</span>
                                <span class="badge bg-warning-subtle text-warning" style="font-size: 0.7rem; padding: 0.25rem 0.5rem; border: 1px solid rgba(255, 193, 7, 0.2); color: #856404 !important; font-weight: 600;">Pago pendiente</span>
                                break;
                        }
                    </div>

                    <!-- Fila 6 (Botonera de Acción) -->
                    <div class="d-flex gap-2 align-items-center mt-2 w-100">
                        @if (order.Status == "entregado" || order.Status == "cancelado")
                        {
                            <!-- El botón "👁 Ver detalle" se expande para ocupar todo el ancho de la tarjeta -->
                            <button class="btn btn-surface btn-sm w-100 py-2 d-flex align-items-center justify-content-center gap-2" @onclick="@(() => VerDetalle(order))">
                                <i class="fas fa-eye" style="font-size: 0.78rem;"></i> Ver detalle
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-surface btn-sm py-2 px-3 d-flex align-items-center justify-content-center gap-2" @onclick="@(() => VerDetalle(order))">
                                <i class="fas fa-eye" style="font-size: 0.78rem;"></i> Ver detalle
                            </button>
                            
                            @if (order.Status == "pendiente")
                            {
                                <button class="btn btn-primary btn-sm py-2 px-3 flex-grow-1 d-flex align-items-center justify-content-between gap-2 fw-semibold" @onclick="@(() => SiguienteAccion(order))" style="border-radius: var(--radius); font-size: 0.8rem;">
                                    <span class="d-flex align-items-center gap-2"><i class="fas fa-utensils" style="font-size: 0.78rem;"></i> Iniciar preparación</span>
                                    <i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i>
                                </button>
                                <button class="btn btn-light btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center flex-shrink-0" @onclick="@(() => CancelarOrder(order))" style="width: 36px; height: 36px; border: 1px solid #fee2e2; color: #dc3545; background: #fff;" title="Cancelar Pedido">
                                    <i class="fas fa-times" style="font-size: 0.78rem;"></i>
                                </button>
                            }
                            else if (order.Status == "preparando")
                            {
                                <button class="btn btn-primary btn-sm py-2 px-3 flex-grow-1 d-flex align-items-center justify-content-between gap-2 fw-semibold" @onclick="@(() => SiguienteAccion(order))" style="border-radius: var(--radius); font-size: 0.8rem;">
                                    <span class="d-flex align-items-center gap-2"><i class="fas fa-box-open" style="font-size: 0.78rem;"></i> Marcar listo</span>
                                    <i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i>
                                </button>
                                <button class="btn btn-light btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center flex-shrink-0" @onclick="@(() => CancelarOrder(order))" style="width: 36px; height: 36px; border: 1px solid #fee2e2; color: #dc3545; background: #fff;" title="Cancelar Pedido">
                                    <i class="fas fa-times" style="font-size: 0.78rem;"></i>
                                </button>
                            }
                            else if (order.Status == "en_camino") // Listo para entrega
                            {
                                <button class="btn btn-primary btn-sm py-2 px-3 flex-grow-1 d-flex align-items-center justify-content-center gap-2 fw-semibold" @onclick="@(() => SiguienteAccion(order))" style="border-radius: var(--radius); font-size: 0.8rem;">
                                    <i class="fas fa-check-circle" style="font-size: 0.82rem;"></i> Marcar entregado
                                </button>
                            }
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Paginación Premium -->
        @if (TotalPages(FilteredOrders.Count()) > 1)
        {
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-4 pt-3 border-top border-color-default animate-fade-in">
                <span class="text-muted-foreground" style="font-size: 0.82rem;">
                    Mostrando pedidos <strong>@((_currentPage - 1) * _pageSize + 1)</strong> a <strong>@(Math.Min(_currentPage * _pageSize, FilteredOrders.Count()))</strong> de un total de <strong>@FilteredOrders.Count()</strong>
                </span>
                
                <nav class="d-flex align-items-center gap-1.5">
                    <button class="pagination-nav-btn" @onclick="PrevPage" disabled="@(_currentPage == 1)">
                        <i class="fas fa-chevron-left" style="font-size: 0.72rem;"></i> Anterior
                    </button>
                    
                    @for (int i = 1; i <= TotalPages(FilteredOrders.Count()); i++)
                    {
                        var pageNumber = i;
                        <button class="pagination-num-btn @(pageNumber == _currentPage ? "active" : "")" @onclick="@(() => SetPage(pageNumber))">
                            @pageNumber
                        </button>
                    }
                    
                    <button class="pagination-nav-btn" @onclick="@(() => NextPage(FilteredOrders.Count()))" disabled="@(_currentPage == TotalPages(FilteredOrders.Count()))">
                        Siguiente <i class="fas fa-chevron-right" style="font-size: 0.72rem;"></i>
                    </button>
                </nav>
            </div>
        }
    }
</div>

<!-- Modal Detalle de Pedido -->
@if (_showDetailModal && _detailOrder != null)
{
    <div class="detail-modal-overlay" @onclick="CloseModal">
        <div class="detail-modal-container" @onclick:stopPropagation>

            <!-- ── Header del Modal ── -->
            <div class="detail-modal-header">
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex align-items-center gap-2">
                        <span class="page-title font-display" style="font-size:1.1rem;">@_detailOrder.Id</span>
                        <span class="@GetStatusBadgeClass(_detailOrder.Status)">@GetStatusLabel(_detailOrder.Status)</span>
                    </div>
                    <span class="text-muted-foreground" style="font-size:0.78rem;">
                        <i class="far fa-calendar-alt me-1"></i>@_detailOrder.Date.ToString("dd/MM/yyyy") &nbsp;·&nbsp;
                        <i class="far fa-clock me-1"></i>@_detailOrder.Date.ToString("HH:mm")
                    </span>
                </div>
                <button class="detail-modal-close" @onclick="CloseModal">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <!-- ── Cuerpo con scroll ── -->
            <div class="detail-modal-body">

                <!-- Bloque: Info del Cliente -->
                <div class="detail-section">
                    <div class="detail-section-title"><i class="fas fa-user me-2"></i>Datos del Cliente</div>
                    <div class="detail-info-grid">
                        <div class="detail-info-row">
                            <span class="detail-label">Nombre</span>
                            <span class="detail-value fw-semibold">@_detailOrder.Customer</span>
                        </div>
                        <div class="detail-info-row">
                            <span class="detail-label">Canal</span>
                            <span class="detail-value">
                                <i class="fas @(_detailOrder.Channel=="Online"?"fa-globe":"fa-store") me-1 text-primary"></i>@_detailOrder.Channel
                            </span>
                        </div>
                        <div class="detail-info-row">
                            <span class="detail-label">Teléfono</span>
                            <span class="detail-value"><i class="fas fa-phone-alt me-1" style="color:#6c757d;"></i>987 654 321</span>
                        </div>
                    </div>
                </div>

                <!-- Bloque: Tipo de Envío -->
                <div class="detail-section">
                    <div class="detail-section-title">
                        @if (_detailOrder.DeliveryMethod?.ToLower() == "delivery")
                        {
                            <i class="fas fa-truck me-2" style="color:#0d6efd;"></i>
                        }
                        else
                        {
                            <i class="fas fa-store me-2" style="color:#198754;"></i>
                        }
                        Tipo de Envío
                    </div>
                    <div class="detail-info-grid">
                        <div class="detail-info-row">
                            <span class="detail-label">Método</span>
                            @if (_detailOrder.DeliveryMethod?.ToLower() == "delivery")
                            {
                                <span class="badge" style="background:#e3f2fd;color:#0d6efd;font-size:0.73rem;font-weight:600;border-radius:9999px;padding:4px 11px;">
                                    <i class="fas fa-truck me-1"></i>Delivery
                                </span>
                            }
                            else
                            {
                                <span class="badge" style="background:#e8f5e9;color:#198754;font-size:0.73rem;font-weight:600;border-radius:9999px;padding:4px 11px;">
                                    <i class="fas fa-store me-1"></i>Recojo en tienda
                                </span>
                            }
                        </div>
                        @if (_detailOrder.DeliveryMethod?.ToLower() == "delivery" && !string.IsNullOrEmpty(_detailOrder.Address))
                        {
                            <div class="detail-info-row">
                                <span class="detail-label">Dirección</span>
                                <span class="detail-value"><i class="fas fa-map-marker-alt me-1" style="color:#dc3545;"></i>@_detailOrder.Address</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Bloque: Lista de Productos -->
                <div class="detail-section">
                    <div class="detail-section-title"><i class="fas fa-shopping-basket me-2"></i>Productos del Pedido</div>
                    @if (_detailOrder.Products != null && _detailOrder.Products.Any())
                    {
                        <div class="detail-products-list">
                            @foreach (var product in _detailOrder.Products)
                            {
                                <div class="detail-product-row">
                                    <div class="detail-product-qty">x@product.Quantity</div>
                                    <div class="detail-product-name">@product.Name</div>
                                    <div class="detail-product-price">S/. @((product.Price * product.Quantity).ToString("0.00"))</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted-foreground small m-0">Sin detalle de productos disponible.</p>
                    }
                </div>

                <!-- Bloque: Resumen de Totales -->
                <div class="detail-section">
                    <div class="detail-section-title"><i class="fas fa-receipt me-2"></i>Resumen de Pago</div>
                    <div class="detail-totals-block">
                        <div class="detail-totals-row">
                            <span class="detail-label">Subtotal</span>
                            <span class="detail-value">S/. @_detailOrder.Subtotal.ToString("0.00")</span>
                        </div>
                        <div class="detail-totals-row">
                            <span class="detail-label">Costo de envío</span>
                            @if (_detailOrder.DeliveryFee == 0)
                            {
                                <span class="detail-value" style="color:#198754;font-weight:600;">Gratis</span>
                            }
                            else
                            {
                                <span class="detail-value">S/. @_detailOrder.DeliveryFee.ToString("0.00")</span>
                            }
                        </div>
                        <div class="detail-totals-divider"></div>
                        <div class="detail-totals-row total-final">
                            <span>Total</span>
                            <span class="text-primary fw-bold" style="font-size:1.15rem;">S/. @_detailOrder.Total.ToString("0.00")</span>
                        </div>
                        <!-- Método de pago -->
                        <div class="detail-payment-method mt-2">
                            <span class="detail-label">Método de pago</span>
                            <div class="d-flex gap-2 mt-1">
                                @switch (_detailOrder.PaymentMethod?.ToLower())
                                {
                                    case "yape":
                                        <span class="badge text-white" style="background:#6f42c1;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-mobile-alt me-1"></i>Yape</span>
                                        <span class="badge" style="background:#e8f5e9;color:#198754;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-check-circle me-1"></i>Pagado</span>
                                        break;
                                    case "plin":
                                        <span class="badge text-white" style="background:#0dcaf0;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-mobile-alt me-1"></i>Plin</span>
                                        <span class="badge" style="background:#e8f5e9;color:#198754;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-check-circle me-1"></i>Pagado</span>
                                        break;
                                    case "tarjeta":
                                        <span class="badge text-white" style="background:#0d6efd;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-credit-card me-1"></i>Tarjeta</span>
                                        <span class="badge" style="background:#e8f5e9;color:#198754;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-check-circle me-1"></i>Pagado</span>
                                        break;
                                    default:
                                        <span class="badge text-white" style="background:#198754;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-money-bill-wave me-1"></i>Efectivo</span>
                                        <span class="badge" style="background:#fff3e0;color:#b25e00;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-clock me-1"></i>Pago al recibir</span>
                                        break;
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bloque: Timeline del Pedido -->
                <div class="detail-section">
                    <div class="detail-section-title"><i class="fas fa-history me-2"></i>Historial del Pedido</div>
                    <div class="detail-timeline">
                        @if (_detailOrder.TimelinePedidoRecibido.HasValue)
                        {
                            <div class="timeline-step done">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">Pedido recibido</span>
                                    <span class="timeline-time">@_detailOrder.TimelinePedidoRecibido.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                        @if (_detailOrder.TimelineEnPreparacion.HasValue)
                        {
                            <div class="timeline-step done">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">En preparación</span>
                                    <span class="timeline-time">@_detailOrder.TimelineEnPreparacion.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                        @if (_detailOrder.TimelineListo.HasValue)
                        {
                            <div class="timeline-step done">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">Listo para entrega</span>
                                    <span class="timeline-time">@_detailOrder.TimelineListo.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                        @if (_detailOrder.TimelineEnCamino.HasValue)
                        {
                            <div class="timeline-step done">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">En camino</span>
                                    <span class="timeline-time">@_detailOrder.TimelineEnCamino.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                        @if (_detailOrder.TimelineEntregado.HasValue)
                        {
                            <div class="timeline-step done success">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">Entregado</span>
                                    <span class="timeline-time">@_detailOrder.TimelineEntregado.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                        @if (_detailOrder.TimelineCancelado.HasValue)
                        {
                            <div class="timeline-step cancelled">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">Cancelado</span>
                                    <span class="timeline-time">@_detailOrder.TimelineCancelado.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

            </div><!-- /modal-body -->

            <!-- ── Footer del Modal ── -->
            <div class="detail-modal-footer">
                <button class="btn btn-outline-secondary fw-medium" @onclick="CloseModal" style="border-radius:var(--radius); min-width: 90px;">
                    <i class="fas fa-times me-1"></i>Cerrar
                </button>
                @if (!string.IsNullOrEmpty(GetNextActionLabel(_detailOrder.Status)))
                {
                    <button class="btn btn-primary fw-semibold" @onclick="@(() => { SiguienteAccion(_detailOrder); CloseModal(); })" style="border-radius: var(--radius); min-width: 160px;">
                        <i class="fas fa-arrow-right me-2"></i>@GetNextActionLabel(_detailOrder.Status)
                    </button>
                }
            </div>

        </div>
    </div>
}

