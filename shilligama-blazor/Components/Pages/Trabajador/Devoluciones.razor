    .badge-reason-danado  { background-color: #fff8e1 !important; color: #e65100 !important; }
    .badge-reason-error   { background-color: #e8f5e9 !important; color: var(--primary) !important; }
    .badge-reason-otro    { background-color: #f3e5f5 !important; color: #7b1fa2 !important; }

    .dark .badge-reason-vencido { background-color: rgba(220,53,69,0.2) !important; color: #ef5350 !important; }
    .dark .badge-reason-danado  { background-color: rgba(255,193,7,0.2) !important;  color: #fbbf24 !important; }
    .dark .badge-reason-error   { background-color: rgba(25,135,84,0.2) !important;  color: var(--primary) !important; }
    .dark .badge-reason-otro    { background-color: rgba(124,58,237,0.2) !important; color: #a78bfa !important; }

    /* Table row hover */
    .dev-table-row { transition: background-color 0.15s ease; }
