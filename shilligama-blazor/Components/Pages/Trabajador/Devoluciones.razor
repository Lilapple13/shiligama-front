@page "/trabajador/devoluciones"
@layout TrabajadorLayout
@inject ReturnsService ReturnsSvc
@inject ProductService ProductSvc
@inject SalesService SalesSvc
@inject AuthService Auth

@code {
    private List<Return> _returns = new();
    private List<Product> _products = new();
    private string _search = "";
    private string _motivoFilter = "";

    // Modal state
    private bool _showModal = false;
    private bool _isEditing = false;
    private string _editingId = "";

    // Form fields
    private string _formProductName = "";
    private int _formQuantity = 0;
    private string _formReason = "";
    private DateTime _formDate = DateTime.Now;
    private string _formObservations = "";

    // Order-based search for returns
    private string _orderSearch = "";
    private Order? _selectedOrder = null;
    private Dictionary<string, (bool Selected, int Qty)> _returnSelections = new();

    private IEnumerable<Order> DeliveredOrders => SalesSvc.GetRecentOrders()
        .Where(o => o.Status == "entregado" &&
            (string.IsNullOrEmpty(_orderSearch) ||
             o.Id.Contains(_orderSearch, StringComparison.OrdinalIgnoreCase) ||
             o.Customer.Contains(_orderSearch, StringComparison.OrdinalIgnoreCase)))
        .Take(8);

    private void SelectOrder(Order o)
    {
        _selectedOrder = o;
        _returnSelections = o.Products?.ToDictionary(
            p => p.Name,
            p => (Selected: false, Qty: 1)) ?? new();
    }

    // Delete confirmation
    private bool _showDeleteConfirm = false;
    private string _deleteTargetId = "";
    private string _deleteTargetName = "";

    // Dropdown actions
    private string _openDropdownId = "";

    protected override void OnInitialized()
    {
        _returns = ReturnsSvc.GetReturns();
        _products = ProductSvc.GetProducts();
    }

    private IEnumerable<Return> Filtered => _returns
        .Where(r =>
            (string.IsNullOrEmpty(_search) ||
             r.Product.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             r.ProductCode.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             r.RegisteredBy.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(_motivoFilter) || r.Reason.Equals(_motivoFilter, StringComparison.OrdinalIgnoreCase))
        )
        .OrderByDescending(r => r.Date);

    // KPI Calculations
    private int DevolucionesEsteMes => _returns.Count(r => r.Date.Month == DateTime.Now.Month && r.Date.Year == DateTime.Now.Year);
    private decimal TotalMermas => _returns.Sum(r => r.Amount);
    private (string Name, int Qty) ProductoMasDevuelto
    {
        get
        {
            var grouped = _returns.GroupBy(r => r.Product)
                .Select(g => new { Name = g.Key, TotalQty = g.Sum(x => x.Quantity) })
                .OrderByDescending(x => x.TotalQty)
                .FirstOrDefault();
            return grouped != null ? (grouped.Name, grouped.TotalQty) : ("N/A", 0);
        }
    }

    // Modal actions
    private void OpenCreate()
    {
        _isEditing = false;
        _editingId = "";
        _formProductName = "";
        _formQuantity = 0;
        _formReason = "";
        _formDate = DateTime.Now;
        _formObservations = "";
        _orderSearch = "";
        _selectedOrder = null;
        _returnSelections = new();
        _showModal = true;
        _openDropdownId = "";
    }

    private void OpenEdit(Return r)
    {
        _isEditing = true;
        _editingId = r.Id;
        _formProductName = r.Product;
        _formQuantity = r.Quantity;
        _formReason = r.Reason;
        _formDate = r.Date;
        _formObservations = r.Observations;
        _showModal = true;
        _openDropdownId = "";
    }

    private void CloseModal()
    {
        _showModal = false;
    }

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(_formReason))
            return;

        if (!_isEditing)
        {
            // Register returns for each selected product
            if (_selectedOrder == null) return;
            bool anySelected = _returnSelections.Any(kv => kv.Value.Selected && kv.Value.Qty > 0);
            if (!anySelected) return;

            foreach (var kv in _returnSelections.Where(kv => kv.Value.Selected && kv.Value.Qty > 0))
            {
                var prod = _products.FirstOrDefault(p => p.Name.Equals(kv.Key, StringComparison.OrdinalIgnoreCase));
                string productCode = prod != null ? $"PROD-{prod.Id:D3}" : "PROD-GEN";
                decimal amount = prod != null ? prod.Price * kv.Value.Qty : 10.00m * kv.Value.Qty;
                var newReturn = new Return
                {
                    Product = kv.Key,
                    ProductCode = productCode,
                    Quantity = kv.Value.Qty,
                    Reason = _formReason,
                    RegisteredBy = Auth.CurrentUser?.Name ?? "Carlos Mendoza",
                    Amount = amount,
                    Observations = _formObservations
                };
                ReturnsSvc.AddReturn(newReturn);
            }
        }
        else
        {
            // Editing: simple single-product update
            if (string.IsNullOrWhiteSpace(_formProductName) || _formQuantity <= 0) return;
            var prod = _products.FirstOrDefault(p => p.Name.Equals(_formProductName, StringComparison.OrdinalIgnoreCase));
            string productCode = prod != null ? $"PROD-{prod.Id:D3}" : "PROD-GEN";
            decimal amount = prod != null ? prod.Price * _formQuantity : 10.00m * _formQuantity;
            var existing = ReturnsSvc.GetReturnById(_editingId);
            if (existing != null)
            {
                existing.Product = _formProductName;
                existing.ProductCode = productCode;
                existing.Quantity = _formQuantity;
                existing.Reason = _formReason;
                existing.Amount = amount;
                existing.Observations = _formObservations;
                ReturnsSvc.UpdateReturn(existing);
            }
        }

        _returns = ReturnsSvc.GetReturns();
        _showModal = false;
    }

    // Delete actions
    private void OpenDeleteConfirm(Return r)
    {
        _deleteTargetId = r.Id;
        _deleteTargetName = r.Product;
        _showDeleteConfirm = true;
        _openDropdownId = "";
    }

    private void ConfirmDelete()
    {
        ReturnsSvc.DeleteReturn(_deleteTargetId);
        _returns = ReturnsSvc.GetReturns();
        _showDeleteConfirm = false;
        _deleteTargetId = "";
    }

    private void CancelDelete()
    {
        _showDeleteConfirm = false;
        _deleteTargetId = "";
    }

    // Dropdown
    private void ToggleDropdown(string id)
    {
        _openDropdownId = _openDropdownId == id ? "" : id;
    }

    private string GetReasonBadgeClass(string reason) => reason.ToLower() switch
    {
        "vencido" => "badge-reason-vencido",
        "dañado" => "badge-reason-danado",
        "error de pedido" => "badge-reason-error",
        _ => "badge-reason-otro"
    };

    private string GetReasonIcon(string reason) => reason.ToLower() switch
    {
        "vencido" => "fas fa-calendar-times",
        "dañado" => "fas fa-exclamation-triangle",
        "error de pedido" => "fas fa-exchange-alt",
        _ => "fas fa-question-circle"
    };
}

<PageTitle>Devoluciones – Shiligama</PageTitle>

<div class="bg-slate-50 min-vh-100 w-100 p-4">

    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="page-title mb-0">Devoluciones</h1>
            <p class="page-subtitle" style="font-size: 0.85rem;">Gestiona las devoluciones que has registrado</p>
        </div>
        <button @onclick="OpenCreate" class="btn btn-primary d-flex align-items-center gap-2 fw-semibold px-4" style="border-radius: var(--radius); height: 42px;">
            <i class="fas fa-plus"></i> Registrar Devolución
        </button>
    </div>

    <div class="d-flex flex-column gap-3">

        <!-- KPI Cards -->
        <div class="row g-3">
            <!-- Devoluciones este mes -->
            <div class="col-12 col-md-4">
                <div class="worker-kpi-card kpi-dev-month">
                    <div class="metric-kpi-icon kpi-icon-success">
                        <i class="fas fa-sync-alt"></i>
                    </div>
                    <div>
                        <div class="metric-kpi-value text-foreground">@DevolucionesEsteMes</div>
                        <div class="metric-kpi-label">Devoluciones este mes</div>
                    </div>
                </div>
            </div>
            <!-- Total Mermas -->
            <div class="col-12 col-md-4">
                <div class="worker-kpi-card kpi-dev-mermas">
                    <div class="metric-kpi-icon kpi-icon-danger">
                        <i class="fas fa-arrow-down"></i>
                    </div>
                    <div>
                        <div class="metric-kpi-value text-danger">S/. @TotalMermas.ToString("0.00")</div>
                        <div class="metric-kpi-label">Total Mermas (pérdida)</div>
                    </div>
                </div>
            </div>
            <!-- Producto más devuelto -->
            <div class="col-12 col-md-4">
                <div class="worker-kpi-card kpi-dev-most">
                    <div class="metric-kpi-icon kpi-icon-warning">
                        <i class="fas fa-box-open"></i>
                    </div>
                    <div>
                        <div class="metric-kpi-value text-foreground" style="font-size: 1.25rem; line-height: 1.2; max-width: 220px; word-wrap: break-word;">@ProductoMasDevuelto.Name</div>
                        <div class="metric-kpi-label">Más devuelto (@ProductoMasDevuelto.Qty und)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="card bg-card border border-color-default shadow-sm" style="border-radius: 1rem;">
            <div class="p-3 d-flex align-items-center gap-2 flex-wrap">
                <div class="position-relative flex-grow-1" style="min-width: 200px;">
                    <i class="fas fa-search position-absolute text-muted-foreground" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 0.85rem;"></i>
                    <input type="search" @bind="_search" @bind:event="oninput"
                           class="form-control text-foreground"
                           placeholder="Buscar por producto, código o responsable..."
                           style="padding-left: 40px; height: 42px; border-radius: 0.5rem;" />
                </div>
                <select @bind="_motivoFilter" class="form-select text-foreground" style="max-width: 220px; height: 42px; border-radius: 0.5rem;">
                    <option value="">Todos los motivos</option>
                    <option value="Vencido">Vencido</option>
                    <option value="Dañado">Dañado / Roto</option>
                    <option value="Error de pedido">Error de pedido</option>
                </select>
            </div>
        </div>

        <!-- Table: Registro de Devoluciones -->
        <div class="card bg-card border border-color-default shadow-sm overflow-hidden" style="border-radius: 1rem;">
            <div class="p-4 border-bottom border-color-default">
                <h5 class="m-0 fw-bold text-foreground" style="font-size: 1.05rem;">Registro de Devoluciones</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-borderless align-middle mb-0">
                    <thead class="border-bottom border-color-default table-head-muted">
                        <tr>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing: .05em;">Fecha</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing: .05em;">Producto</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing: .05em;">Cantidad</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing: .05em;">Motivo</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing: .05em;">Registrado por</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing: .05em;">Monto</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing: .05em;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dev in Filtered)
                        {
                            <tr class="border-bottom border-color-default dev-table-row">
                                <td class="px-4 py-3 text-foreground small">@dev.Date.ToString("dd MMM yyyy")</td>
                                <td class="px-4 py-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <div>
                                            <span class="fw-semibold text-foreground small d-block">@dev.Product</span>
                                            <span class="text-muted-foreground" style="font-size: 0.72rem;">@dev.ProductCode</span>
                                        </div>
                                        <i class="far fa-question-circle text-muted-foreground" style="font-size: 0.7rem; opacity: 0.5;" title="@dev.Observations"></i>
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-center text-foreground small fw-medium">@dev.Quantity</td>
                                <td class="px-4 py-3">
                                    <span class="badge @GetReasonBadgeClass(dev.Reason) d-inline-flex align-items-center gap-1" style="border-radius: 0.4rem; padding: 0.35rem 0.65rem; font-size: 0.75rem; font-weight: 500;">
                                        <i class="@GetReasonIcon(dev.Reason)" style="font-size: 0.65rem;"></i> @dev.Reason
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-muted-foreground small">@dev.RegisteredBy</td>
                                <td class="px-4 py-3 text-end fw-semibold small" style="color: #c62828;">-S/. @dev.Amount.ToString("0.00")</td>
                                <td class="px-4 py-3 text-center position-relative">
                                    <button class="btn btn-link text-muted-foreground p-0 text-decoration-none" @onclick="@(() => ToggleDropdown(dev.Id))" @onclick:stopPropagation style="font-size: 1.2rem; letter-spacing: 2px;">
                                        •••
                                    </button>
                                    @if (_openDropdownId == dev.Id)
                                    {
                                        <div class="position-absolute bg-card shadow-lg border border-color-default d-flex flex-column animate-fade-in" style="right: 20px; top: 100%; z-index: 100; border-radius: 0.5rem; min-width: 140px; overflow: hidden;">
                                            <button class="btn btn-link text-start text-foreground text-decoration-none px-3 py-2 d-flex align-items-center gap-2 dropdown-action-btn" @onclick="@(() => OpenEdit(dev))" style="font-size: 0.85rem;">
                                                <i class="fas fa-pen" style="font-size: 0.75rem; color: #6b7280;"></i> Editar
                                            </button>
                                            <button class="btn btn-link text-start text-danger text-decoration-none px-3 py-2 d-flex align-items-center gap-2 dropdown-action-btn" @onclick="@(() => OpenDeleteConfirm(dev))" style="font-size: 0.85rem;">
                                                <i class="fas fa-trash-alt" style="font-size: 0.75rem;"></i> Eliminar
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Filtered.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="fas fa-undo-alt text-muted-foreground opacity-25 mb-2" style="font-size: 2.5rem;"></i>
                                    <p class="text-muted-foreground small m-0 mt-2">No se encontraron registros de devoluciones</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- ═══════════════════════════════════════════════════ -->
<!-- Modal: Registrar / Editar Devolución              -->
<!-- ═══════════════════════════════════════════════════ -->
@if (_showModal)
{
    <div class="d-flex align-items-center justify-content-center" style="position: fixed; inset: 0; z-index: 1050; background-color: rgba(0,0,0,0.55);" @onclick="CloseModal">
        <div class="bg-card shadow-lg d-flex flex-column animate-fade-in" style="width: 100%; max-width: 500px; border-radius: 1rem; overflow: hidden;" @onclick:stopPropagation>

            <!-- Modal Header -->
            <div class="p-4 pb-2 d-flex justify-content-between align-items-start">
                <div>
                    <h5 class="fw-bold text-foreground mb-1" style="font-size: 1.15rem;">@(_isEditing ? "Editar Devolución" : "Registrar Devolución")</h5>
                    <p class="text-muted-foreground small m-0" style="font-size: 0.85rem;">Ingresa los datos de la devolución o merma</p>
                </div>
                <button class="btn btn-link text-muted-foreground p-0 m-0 text-decoration-none" style="font-size: 1.2rem;" @onclick="CloseModal">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <!-- Modal Body -->
            <div class="p-4 pt-3 d-flex flex-column gap-3" style="max-height: 70vh; overflow-y: auto;">

                @if (!_isEditing)
                {
                    <!-- Order Search -->
                    <div>
                        <label class="form-label small fw-semibold text-foreground mb-1">
                            Pedido entregado <span class="text-danger">*</span>
                        </label>
                        <div class="position-relative">
                            <i class="fas fa-search position-absolute text-muted-foreground" style="left:12px; top:50%; transform:translateY(-50%); font-size:0.85rem;"></i>
                            <input type="search" @bind="_orderSearch" @bind:event="oninput"
                                   class="form-control text-foreground"
                                   placeholder="Buscar por # pedido o cliente..."
                                   style="padding-left:36px; border-radius:0.5rem; height:42px;" />
                        </div>

                        <!-- Order list -->
                        @if (!string.IsNullOrEmpty(_orderSearch) || _selectedOrder != null)
                        {
                            <div class="d-flex flex-column gap-1 mt-2" style="max-height: 160px; overflow-y: auto;">
                                @foreach (var order in DeliveredOrders)
                                {
                                    bool isSelected = _selectedOrder?.Id == order.Id;
                                    <div class="p-2 rounded border cursor-pointer d-flex justify-content-between align-items-center"
                                         style="border-color: @(isSelected ? "var(--primary)" : "var(--border)") !important; background: @(isSelected ? "rgba(26,107,60,0.06)" : "var(--card)"); font-size: 0.82rem; transition: all 0.15s;"
                                         @onclick="@(() => SelectOrder(order))">
                                        <div>
                                            <span class="fw-bold text-foreground">@order.Id</span>
                                            <span class="text-muted-foreground ms-2">@order.Customer</span>
                                        </div>
                                        <span class="text-muted-foreground">@order.Date.ToString("dd/MM/yy")</span>
                                    </div>
                                }
                                @if (!DeliveredOrders.Any())
                                {
                                    <p class="text-muted-foreground small p-2 m-0">No se encontraron pedidos entregados con ese criterio.</p>
                                }
                            </div>
                        }
                    </div>

                    <!-- Selected order products -->
                    @if (_selectedOrder != null && _selectedOrder.Products != null)
                    {
                        <div>
                            <label class="form-label small fw-semibold text-foreground mb-2">
                                <i class="fas fa-shopping-basket me-1 text-primary"></i>
                                Productos del pedido <span class="text-muted-foreground fw-normal">(@_selectedOrder.Id)</span>
                            </label>
                            <div class="d-flex flex-column gap-2">
                                @foreach (var product in _selectedOrder.Products)
                                {
                                    var prodName = product.Name;
                                    var sel = _returnSelections.ContainsKey(prodName) ? _returnSelections[prodName] : (Selected: false, Qty: 1);
                                    <div class="d-flex align-items-center gap-3 p-2 rounded border @(sel.Selected ? "border-success" : "border-color-default")"
                                         style="background: @(sel.Selected ? "rgba(25,135,84,0.05)" : "var(--card)"); border-radius: 0.5rem; transition: all 0.2s;">
                                        <input type="checkbox" class="form-check-input flex-shrink-0" style="width:18px; height:18px;"
                                               checked="@sel.Selected"
                                               @onchange="@((e) => { _returnSelections[prodName] = ((bool)(e.Value ?? false), sel.Qty); StateHasChanged(); })" />
                                        <div class="flex-grow-1">
                                            <span class="fw-semibold text-foreground" style="font-size:0.85rem;">@product.Name</span>
                                            <span class="text-muted-foreground ms-2" style="font-size:0.75rem;">Comprado: @product.Quantity uds.</span>
                                        </div>
                                        @if (sel.Selected)
                                        {
                                            <div class="d-flex align-items-center gap-1">
                                                <label class="text-muted-foreground" style="font-size:0.75rem;">Cant.:</label>
                                                <input type="number"
                                                       class="form-control form-control-sm text-center"
                                                       style="width:64px; border-radius:0.4rem;"
                                                       value="@sel.Qty"
                                                       min="1" max="@product.Quantity"
                                                       @oninput="@((e) => { if(int.TryParse(e.Value?.ToString(), out int v)) _returnSelections[prodName] = (sel.Selected, Math.Clamp(v, 1, product.Quantity)); StateHasChanged(); })" />
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <!-- Edit mode: simple single product -->
                    <div>
                        <label class="form-label small fw-semibold text-foreground mb-1">Producto <span class="text-danger">*</span></label>
                        <select @bind="_formProductName" class="form-select text-foreground" style="border-radius: 0.5rem; height: 42px;">
                            <option value="">Seleccionar producto...</option>
                            @foreach (var prod in _products)
                            {
                                <option value="@prod.Name">@prod.Name</option>
                            }
                        </select>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-semibold text-foreground mb-1">Cantidad <span class="text-danger">*</span></label>
                            <input type="number" @bind="_formQuantity" class="form-control text-foreground" min="0" style="border-radius: 0.5rem; height: 42px;" />
                        </div>
                    </div>
                }

                <!-- Motivo -->
                <div>
                    <label class="form-label small fw-semibold text-foreground mb-1">Motivo <span class="text-danger">*</span></label>
                    <select @bind="_formReason" class="form-select text-foreground" style="border-radius: 0.5rem; height: 42px;">
                        <option value="">Seleccionar</option>
                        <option value="Vencido">Vencido</option>
                        <option value="Dañado">Dañado / Roto</option>
                        <option value="Error de pedido">Error de pedido</option>
                    </select>
                </div>

                <!-- Fecha -->
                <div>
                    <label class="form-label small fw-semibold text-foreground mb-1">Fecha <span class="text-danger">*</span></label>
                    <div class="position-relative">
                        <i class="far fa-calendar-alt position-absolute text-muted-foreground" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 0.9rem;"></i>
                        <input type="date" @bind="_formDate" class="form-control text-foreground" style="padding-left: 40px; border-radius: 0.5rem; height: 42px;" readonly />
                    </div>
                </div>

                <!-- Observaciones -->
                <div>
                    <label class="form-label small fw-semibold text-foreground mb-1">Observaciones</label>
                    <textarea @bind="_formObservations" class="form-control text-foreground" rows="3" placeholder="Detalles adicionales sobre la devolución..." style="border-radius: 0.5rem; resize: vertical;"></textarea>
                </div>
            </div>

            <!-- Modal Footer -->
            <div class="p-4 pt-2 d-flex justify-content-end gap-2">
                <button class="btn btn-white border px-4" @onclick="CloseModal" style="border-radius: 0.5rem; font-weight: 500; font-size: 0.9rem; border-color: #dee2e6; height: 42px;">Cancelar</button>
                <button class="btn btn-primary px-4 fw-semibold" @onclick="Save" style="border-radius: var(--radius); height: 42px;">
                    @(_isEditing ? "Guardar Cambios" : "Registrar Devolución")
                </button>
            </div>
        </div>
    </div>
}

<!-- ═══════════════════════════════════════════════════ -->
<!-- Modal: Confirmar Eliminación                      -->
<!-- ═══════════════════════════════════════════════════ -->
@if (_showDeleteConfirm)
{
    <div class="d-flex align-items-center justify-content-center" style="position: fixed; inset: 0; z-index: 1060; background-color: rgba(0,0,0,0.55);" @onclick="CancelDelete">
        <div class="bg-card shadow-lg d-flex flex-column animate-fade-in text-center" style="width: 100%; max-width: 420px; border-radius: 1rem; overflow: hidden;" @onclick:stopPropagation>
            <div class="p-5 pb-3 d-flex flex-column align-items-center">
                <div class="d-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 56px; height: 56px; background-color: #fdecea; color: #c62828;">
                    <i class="fas fa-exclamation-triangle" style="font-size: 1.5rem;"></i>
                </div>
                <h5 class="fw-bold text-foreground mb-2" style="font-size: 1.1rem;">¿Eliminar esta devolución?</h5>
                <p class="page-subtitle mb-0">Estás a punto de eliminar el registro de <strong class="text-foreground">@_deleteTargetName</strong>. Esta acción no se puede deshacer.</p>
            </div>
            <div class="p-4 pt-2 d-flex justify-content-center gap-2">
                <button class="btn btn-white border px-4" @onclick="CancelDelete" style="border-radius: 0.5rem; font-weight: 500; font-size: 0.9rem; border-color: #dee2e6; height: 42px;">Cancelar</button>
                <button class="btn btn-danger text-white px-4" @onclick="ConfirmDelete" style="border-radius: 0.5rem; font-weight: 600; font-size: 0.9rem; height: 42px;">
                    <i class="fas fa-trash-alt me-1"></i> Sí, eliminar
                </button>
            </div>
        </div>
    </div>
}

