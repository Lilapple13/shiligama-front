    .kpi-dev-mermas { border: 2px solid #c62828; box-shadow: 0 6px 16px rgba(198,40,40,0.12); }
    .kpi-dev-mermas:hover { box-shadow: 0 12px 24px rgba(198,40,40,0.25); border-color: #ef5350; }

    .kpi-dev-most { border: 2px solid #f59e0b; box-shadow: 0 6px 16px rgba(245,158,11,0.12); }
    .kpi-dev-most:hover { box-shadow: 0 12px 24px rgba(245,158,11,0.25); border-color: #fbbf24; }

    .kpi-icon-success { background-color: rgba(26,107,60,0.1); color: var(--primary); }
