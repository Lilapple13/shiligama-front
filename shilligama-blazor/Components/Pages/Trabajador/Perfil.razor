@page "/trabajador/perfil"
@layout TrabajadorLayout
@inject AuthService Auth

@code {
    private bool _isEditing = false;
    private string _email = "carlos.mendoza@shiligama.com";
    private string _phone = "987654321";
    
    // Read-only fields
    private string _firstName = "Carlos";
    private string _lastName = "Mendoza";
    private string _dni = "45678912";
    
    private bool _success = false;

    protected override void OnInitialized()
    {
        if (Auth.CurrentUser != null)
        {
            _email = Auth.CurrentUser.Email;
            var parts = Auth.CurrentUser.Name.Split(' ', System.StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length > 0) _firstName = parts[0];
            if (parts.Length > 1) _lastName = string.Join(' ', parts.Skip(1));
        }
    }

    private void EnableEditing()
    {
        _isEditing = true;
        _success = false;
    }

    private void CancelEditing()
    {
        _isEditing = false;
        // Restore values
        if (Auth.CurrentUser != null)
        {
            _email = Auth.CurrentUser.Email;
        }
    }

    private void SaveProfile()
    {
        if (Auth.CurrentUser != null)
        {
            Auth.CurrentUser.Email = _email;
        }
        _isEditing = false;
        _success = true;
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "CM";
        var parts = name.Split(' ', System.StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
    }
}

<PageTitle>Mi Perfil – Shiligama</PageTitle>

<div class="profile-container d-flex flex-column gap-4 mx-auto py-3">

    @if (_success)
    {
        <div class="alert alert-success alert-dismissible show p-3 d-flex align-items-center gap-3 border-0 shadow-sm alert-banner-success" role="alert">
            <i class="fas fa-check-circle fs-5 text-primary"></i>
            <div class="small fw-semibold">Tus datos de perfil han sido actualizados con éxito.</div>
            <button type="button" class="btn-close" @onclick="@(() => _success = false)" style="font-size: 0.75rem; margin-top: 2px;"></button>
        </div>
    }

    <!-- 1. Visual Top Card -->
    <div class="card bg-white border border-color-default shadow-sm p-4 rounded-4">
        <div class="d-flex align-items-center gap-4">
            <!-- Avatar -->
            <div class="d-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold" style="width: 80px; height: 80px; font-size: 2.2rem; font-family: 'Outfit', sans-serif;">
                @GetInitials(Auth.CurrentUser?.Name ?? $"{_firstName} {_lastName}")
            </div>
            <!-- Details -->
            <div>
                <h2 class="fs-4 fw-bold text-foreground mb-1" style="font-family: 'Outfit', sans-serif; letter-spacing: -0.01em;">
                    @(Auth.CurrentUser?.Name ?? $"{_firstName} {_lastName}")
                </h2>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="badge badge-role">
                        Trabajador
                    </span>
                    <span class="text-muted-foreground" style="font-size: 0.8rem;">
                        Desde junio de 2023
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Personal Information Card -->
    <div class="card bg-white border border-color-default shadow-sm p-4 rounded-4">
        
        <!-- Bottom Card Header -->
        <div class="d-flex align-items-start justify-content-between gap-3 mb-4 flex-wrap">
            <div>
                <h3 class="fw-bold text-foreground mb-1" style="font-family: 'Outfit', sans-serif; font-size: 1.25rem;">
                    Información Personal
                </h3>
                <p class="page-subtitle mb-0">
                    @(_isEditing ? "Edita tu email y teléfono de contacto" : "Tu información de contacto y datos personales")
                </p>
            </div>
            
            <div class="d-flex gap-2">
                @if (!_isEditing)
                {
                    <button @onclick="EnableEditing" class="btn btn-profile-action d-flex align-items-center gap-2">
                        <i class="fas fa-pencil-alt" style="font-size: 0.8rem;"></i> Editar perfil
                    </button>
                }
                else
                {
                    <button @onclick="CancelEditing" class="btn btn-profile-action d-flex align-items-center gap-2">
                        <i class="fas fa-times" style="font-size: 0.85rem;"></i> Cancelar
                    </button>
                    <button @onclick="SaveProfile" class="btn btn-profile-save d-flex align-items-center gap-2 text-white">
                        <i class="fas fa-save" style="font-size: 0.85rem;"></i> Guardar cambios
                    </button>
                }
            </div>
        </div>

        <!-- Bottom Card Body (Fields) -->
        <div class="d-flex flex-column gap-3.5">
            <!-- Correo electrónico -->
            <div class="profile-field-group">
                <label class="profile-field-label">
                    <i class="far fa-envelope"></i> Correo electrónico
                </label>
                @if (_isEditing)
                {
                    <input type="email" @bind="_email" class="form-control text-foreground mt-1" style="border-radius: 0.5rem; height: 42px; border: 1px solid #dee2e6;" />
                }
                else
                {
                    <div class="profile-field-value text-foreground mt-1">@_email</div>
                }
            </div>

            <!-- Teléfono -->
            <div class="profile-field-group mt-1">
                <label class="profile-field-label">
                    <i class="fas fa-phone-alt"></i> Teléfono
                </label>
                @if (_isEditing)
                {
                    <input type="tel" @bind="_phone" class="form-control text-foreground mt-1" style="border-radius: 0.5rem; height: 42px; border: 1px solid #dee2e6;" />
                }
                else
                {
                    <div class="profile-field-value text-foreground mt-1">@_phone</div>
                }
            </div>

            <!-- Divider -->
            <hr class="border-color-default my-4" />

            <!-- Read Only Notice -->
            <div class="text-muted-foreground mb-3" style="font-size: 0.78rem;">
                Los siguientes campos no pueden ser editados. Contacta al administrador para realizar cambios.
            </div>

            <!-- Nombres -->
            <div class="profile-field-group">
                <label class="profile-field-label">
                    <i class="far fa-user"></i> Nombres
                </label>
                <div class="profile-field-value text-foreground mt-1">@_firstName</div>
            </div>

            <!-- Apellidos -->
            <div class="profile-field-group mt-2">
                <label class="profile-field-label">
                    <i class="far fa-user"></i> Apellidos
                </label>
                <div class="profile-field-value text-foreground mt-1">@_lastName</div>
            </div>

            <!-- DNI -->
            <div class="profile-field-group mt-2">
                <label class="profile-field-label">
                    <i class="far fa-id-card"></i> DNI
                </label>
                <div class="profile-field-value text-foreground mt-1">@_dni</div>
            </div>
        </div>

    </div>

</div>

<style>
    .profile-container {
        max-width: 720px;
        width: 100%;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    .btn-profile-action {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        color: #333333;
        font-size: 0.85rem;
        border-radius: 0.5rem;
        font-weight: 500;
        padding: 0.45rem 1rem;
        height: 38px;
        transition: all 0.2s ease;
    }

    .btn-profile-action:hover {
        background-color: #e9ecef;
        border-color: #ced4da;
        color: #111111;
    }

    .btn-profile-save {
        background-color: var(--primary);
        border: 1px solid var(--primary);
        font-size: 0.85rem;
        border-radius: 0.5rem;
        font-weight: 600;
        padding: 0.45rem 1rem;
        height: 38px;
        transition: all 0.2s ease;
    }

    .btn-profile-save:hover {
        background-color: color-mix(in srgb, var(--primary) 85%, black);
        border-color: #053318;
    }

    .profile-field-group {
        display: flex;
        flex-direction: column;
    }

    .profile-field-label {
        font-size: 0.82rem;
        color: #6c757d;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .profile-field-value {
        font-size: 0.95rem;
        color: var(--foreground);
        padding-left: 1.35rem;
    }

    .dark .btn-profile-action {
        background-color: var(--secondary);
        border-color: var(--border);
        color: var(--foreground);
    }
    .dark .btn-profile-action:hover {
        background-color: var(--border);
    }
</style>
