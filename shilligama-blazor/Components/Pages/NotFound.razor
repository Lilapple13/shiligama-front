@page "/not-found"
@layout MainLayout

<PageTitle>Página no encontrada — Shiligama</PageTitle>

<div class="container-xl py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6 text-center">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white mb-4" style="width: 72px; height: 72px;">
                <i class="fas fa-map-signs fs-3"></i>
            </div>
            <h1 class="display-5 fw-bold text-foreground mb-2" style="font-family: 'Outfit', sans-serif;">404</h1>
            <h2 class="h4 fw-semibold text-foreground mb-3">Página no encontrada</h2>
            <p class="text-muted-foreground mb-4">
                La ruta que buscas no existe o fue movida. Revisa la dirección o vuelve al catálogo.
            </p>
            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                <a href="/catalogo" class="btn btn-primary px-4">
                    <i class="fas fa-store me-2"></i>Ir al catálogo
                </a>
                <a href="/" class="btn btn-outline-secondary px-4">
                    Iniciar sesión
                </a>
            </div>
        </div>
    </div>
</div>
