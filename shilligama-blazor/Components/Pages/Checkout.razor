@page "/checkout"
@layout MainLayout
@inject CartService Cart
@inject SalesService SalesSvc
@inject NavigationManager Navigation

@code {
    private string _name = "";
    private string _email = "";
    private string _phone = "";
    private string _address = "";
    private string _payMethod = "efectivo";
    private bool _isLoading = false;
    private bool _success = false;
    private string _orderId = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { await Cart.InitializeAsync(); StateHasChanged(); }
    }

    private decimal Subtotal => Cart.GetSubtotal();
    private decimal Envio => Subtotal > 50 ? 0 : 5;
    private decimal Total => Subtotal + Envio;

    private async Task PlaceOrder()
    {
        _isLoading = true;
        await Task.Delay(1000);
        _orderId = $"ORD-{(SalesSvc.GetRecentOrders().Count + 1):D3}";
        SalesSvc.AddOrder(_name, Cart.GetCartItems().ToList(), Total, "Online");
        await Cart.ClearCartAsync();
        _success = true;
        _isLoading = false;
    }
}

<PageTitle>Checkout – Shiligama</PageTitle>

<div class="container-xl px-3 px-sm-4 py-4" style="max-width: 860px;">

    @if (_success)
    {
        <div class="text-center py-5 fade-in">
            <div class="d-flex align-items-center justify-content-center rounded-circle bg-success mx-auto mb-4"
                 style="width:80px;height:80px;">
                <Icons Name="Check" Class="text-white" style="width:40px;height:40px;" />
            </div>
            <h2 class="fs-3 fw-bold text-foreground mb-2">¡Pedido confirmado!</h2>
            <p class="text-muted-foreground mb-1">Número de orden: <strong class="text-primary">@_orderId</strong></p>
            <p class="text-muted-foreground">Recibirás un correo de confirmación pronto.</p>
            <a href="/catalogo" class="btn btn-primary mt-3" style="border-radius:var(--radius);">
                Seguir comprando
            </a>
        </div>
    }
    else if (!Cart.GetCartItems().Any())
    {
        <div class="text-center py-5">
            <p class="text-muted-foreground">Tu carrito está vacío.</p>
            <a href="/catalogo" class="btn btn-primary" style="border-radius:var(--radius);">Ir al catálogo</a>
        </div>
    }
    else
    {
        <h1 class="fs-3 fw-bold text-foreground mb-4">Finalizar Compra</h1>

        <div class="row g-4">
            <!-- Form -->
            <div class="col-md-7">
                <EditForm Model="this" OnValidSubmit="PlaceOrder" class="d-flex flex-column gap-4">
                    <!-- Contact Info -->
                    <div class="card p-4 d-flex flex-column gap-3">
                        <h2 class="fs-5 fw-semibold text-foreground mb-0">Información de contacto</h2>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Nombre completo</label>
                            <input type="text" @bind="_name" required class="form-control text-foreground" placeholder="Juan Pérez" />
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Correo electrónico</label>
                            <input type="email" @bind="_email" required class="form-control text-foreground" placeholder="tu@correo.com" />
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Teléfono</label>
                            <input type="tel" @bind="_phone" required class="form-control text-foreground" placeholder="+51 999 999 999" />
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Dirección de entrega</label>
                            <textarea @bind="_address" required class="form-control text-foreground" rows="2" placeholder="Av. Los Olivos 123, Lima"></textarea>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div class="card p-4 d-flex flex-column gap-3">
                        <h2 class="fs-5 fw-semibold text-foreground mb-0">Método de pago</h2>
                        @foreach (var method in new[] { ("efectivo","💵 Efectivo"), ("yape","📱 Yape"), ("plin","📱 Plin"), ("tarjeta","💳 Tarjeta de crédito/débito") })
                        {
                            <label class="d-flex align-items-center gap-3 p-3 border rounded-3 cursor-pointer @(_payMethod == method.Item1 ? "border-primary bg-primary bg-opacity-10" : "border-border")"
                                   style="cursor:pointer; transition: all .15s;">
                                <input type="radio" name="payment" value="@method.Item1"
                                       checked="@(_payMethod == method.Item1)"
                                       @onchange="@(() => _payMethod = method.Item1)"
                                       class="form-check-input m-0" />
                                <span class="text-foreground fw-medium small">@method.Item2</span>
                            </label>
                        }
                    </div>

                    <button type="submit" disabled="@_isLoading"
                            class="btn btn-primary w-100 fw-medium fs-6"
                            style="height:50px; border-radius:var(--radius);">
                        @(_isLoading ? "Procesando..." : $"Confirmar pedido — S/. {Total:0.00}")
                    </button>
                </EditForm>
            </div>

            <!-- Order Summary -->
            <div class="col-md-5">
                <div class="card p-4 d-flex flex-column gap-3 sticky-top" style="top:5rem;">
                    <h2 class="fs-5 fw-semibold text-foreground mb-0">Resumen</h2>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var item in Cart.GetCartItems())
                        {
                            <div class="d-flex justify-content-between align-items-center small text-foreground">
                                <span>@item.Name ×@item.Quantity</span>
                                <span>S/. @((item.Price * item.Quantity).ToString("0.00"))</span>
                            </div>
                        }
                    </div>
                    <hr class="border-color-default my-1" />
                    <div class="d-flex justify-content-between small text-foreground">
                        <span>Subtotal</span><span>S/. @Subtotal.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between small text-foreground">
                        <span>Envío</span><span>@(Envio == 0 ? "Gratis" : $"S/. {Envio:0.00}")</span>
                    </div>
                    <hr class="border-color-default my-1" />
                    <div class="d-flex justify-content-between fw-bold text-foreground">
                        <span>Total</span><span>S/. @Total.ToString("0.00")</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
