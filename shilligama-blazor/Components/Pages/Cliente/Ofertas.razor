@page "/ofertas"
@layout MainLayout
@inject ProductService ProductSvc
@inject CartService Cart

@code {
    private List<Product> _promoProducts = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _promoProducts = ProductSvc.GetProducts().Where(p => p.IsPromo || p.OriginalPrice.HasValue).ToList();
        _isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { await Cart.InitializeAsync(); StateHasChanged(); }
    }

    private async Task AddToCart(Product p) => await Cart.AddToCartAsync(p);

    private string GetDiscountPct(Product p) =>
        p.OriginalPrice.HasValue ? $"-{100 - (int)(p.Price / p.OriginalPrice.Value * 100)}%" : "";
}

<PageTitle>Ofertas Especiales – Shiligama</PageTitle>

<div class="bg-background">
    <div class="container-xl px-3 px-sm-4 pt-4">
        <!-- Back Button -->
        <nav class="mb-3">
            <a href="/catalogo" class="text-muted-foreground text-decoration-none small d-inline-flex align-items-center gap-2" style="transition: color 0.2s; font-weight: 500;">
                <i class="fa-solid fa-chevron-left" style="font-size: 0.85rem;"></i> Volver al catálogo
            </a>
        </nav>

        <!-- Jumbotron banner -->
        <div class="p-5 rounded-4 text-white d-flex align-items-center justify-content-between gap-4 position-relative overflow-hidden"
             style="background: linear-gradient(135deg, #7c2d12 0%, #b45309 50%, #f59e0b 100%);">
            <div class="position-absolute rounded-circle" style="width: 250px; height: 250px; background: rgba(255, 255, 255, 0.05); top: -80px; right: -50px;"></div>
            <div class="position-relative z-1 max-w-lg">
                <span class="badge bg-danger mb-2 px-3 py-1.5 uppercase tracking-wider font-semibold" style="border-radius: var(--radius);">Descuentos de Locura</span>
                <h1 class="fw-bold mb-2 fs-2" style="font-family: 'Outfit', sans-serif;">Ahorra en Grande Hoy</h1>
                <p class="mb-0 opacity-90 small">Explora las mejores promociones y precios rebajados en productos seleccionados de nuestro minimarket.</p>
            </div>
            <div class="d-none d-md-block fs-1 position-relative z-1" style="font-size: 4.5rem !important;">🔥</div>
        </div>
    </div>

    <div class="container-xl px-3 px-sm-4 py-5">
        <h2 class="fs-4 fw-bold text-foreground mb-4">Promociones Activas</h2>

        @if (_isLoading)
        {
            <div class="row g-3">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="col-6 col-md-4 col-xl-3">
                        <div class="card p-3" style="height:280px; animation: pulse 1.5s infinite;">
                            <div class="bg-muted rounded mb-2" style="height:140px;"></div>
                            <div class="bg-muted rounded mb-1" style="height:14px; width:70%;"></div>
                            <div class="bg-muted rounded" style="height:12px; width:40%;"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (!_promoProducts.Any())
        {
            <div class="text-center py-5">
                <div class="fs-1 mb-3">🏷️</div>
                <h3 class="text-foreground fw-semibold fs-5">No hay promociones activas</h3>
                <p class="text-muted-foreground text-sm">Vuelve pronto para ver nuestras increíbles ofertas.</p>
                <a href="/catalogo" class="btn btn-primary mt-2" style="border-radius: var(--radius);">
                    Ver catálogo general
                </a>
            </div>
        }
        else
        {
            <div class="row g-3 fade-in">
                @foreach (var product in _promoProducts)
                {
                    <div class="col-6 col-md-4 col-xl-3">
                        <div class="card h-100 d-flex flex-column position-relative overflow-hidden border border-color-default transition-all hover-shadow">
                            <span class="badge bg-danger position-absolute top-0 start-0 m-2 z-1 px-2.5 py-1.5 fw-semibold"
                                  style="border-radius: calc(var(--radius) - 2px); font-size: .75rem;">
                                @GetDiscountPct(product)
                            </span>

                            @if (product.Stock == 0)
                            {
                                <div class="position-absolute top-0 start-0 end-0 bottom-0 d-flex align-items-center justify-content-center z-1"
                                     style="background: rgba(0,0,0,.5); border-radius: var(--radius);">
                                    <span class="badge bg-dark fs-6">Sin stock</span>
                                </div>
                            }

                            <a href="/catalogo/@product.Id" class="text-decoration-none">
                                <img src="@product.Image" alt="@product.Name"
                                     class="w-100 object-fit-cover"
                                     style="height: 160px; border-radius: calc(var(--radius) - 1px) calc(var(--radius) - 1px) 0 0;"
                                     onerror="this.src='https://placehold.co/300x300/e8f5e9/1A6B3C?text=🛒'" />
                            </a>

                            <div class="p-3 d-flex flex-column flex-grow-1">
                                <a href="/catalogo/@product.Id" class="text-decoration-none text-foreground">
                                    <p class="small fw-semibold mb-1 lh-sm text-foreground text-line-clamp-2">
                                        @product.Name
                                    </p>
                                </a>
                                <p class="text-muted-foreground small mb-2 text-truncate">@ProductSvc.GetCategoryName(product.Category)</p>

                                <div class="mt-auto pt-2 d-flex align-items-center justify-content-between">
                                    <div>
                                        <span class="fw-bold text-danger fs-5">S/. @product.Price.ToString("0.00")</span>
                                        @if (product.OriginalPrice.HasValue)
                                        {
                                            <span class="text-decoration-line-through text-muted-foreground ms-1 block-xs" style="font-size: .8rem;">
                                                S/. @product.OriginalPrice.Value.ToString("0.00")
                                            </span>
                                        }
                                    </div>
                                    <button @onclick="@(() => AddToCart(product))"
                                            disabled="@(product.Stock == 0)"
                                            class="btn btn-primary btn-sm px-2 py-1 d-flex align-items-center justify-content-center"
                                            style="border-radius: var(--radius); width: 34px; height: 34px;"
                                            title="Agregar al carrito">
                                        <Icons Name="Plus" Class="w-4 h-4" />
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
