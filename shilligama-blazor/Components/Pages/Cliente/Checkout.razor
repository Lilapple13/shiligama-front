@page "/checkout"
@layout MainLayout
@inject CartService Cart
@inject AuthService Auth
@inject SalesService SalesSvc
@inject AddressService AddressSvc
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

@code {
    [SupplyParameterFromQuery(Name = "delivery")]
    public string? DeliveryParam { get; set; }

    private string _deliveryMethod = "delivery";
    private string _name    = "";
    private string _address = "";
    private string _payMethod = "tarjeta";

    private List<string> _addresses = new();

    private string _cardNumber = "";
    private string _cardName   = "";
    private string _cardExpiry = "";
    private string _cardCvv    = "";

    private decimal _cashAmountField;
    private decimal _cashAmount
    {
        get => _cashAmountField;
        set => _cashAmountField = Math.Round(value, 1, MidpointRounding.AwayFromZero);
    }
    private decimal CashChange => _cashAmount >= Total ? _cashAmount - Total : 0;
    private bool    CashEnough => _cashAmount >= Total;

    private string _yapePhone     = "";
    private string _yapeCode      = "";
    private bool   _yapeConfirmed = false;

    private bool   _isLoading = false;
    private bool   _success   = false;
    private string _orderId   = "";

    private bool _showMapModal = false;
    private bool _addressMenuOpen = false;
    private bool _showLoginRequired;
    private bool _authReady;
    private bool _showLeaveConfirm;
    private string _pendingLeaveUrl = "/carrito";
    private string _pendingAddress = "";
    private DotNetObjectReference<Checkout>? _dotnetRef;
    private DotNetObjectReference<Checkout>? _guardRef;
    private IDisposable? _locationChangingRegistration;
    private bool _guardActive;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Cart.InitializeAsync();
            await Auth.InitializeAsync();
            await AddressSvc.InitializeAsync();
            AddressSvc.OnChange += OnAddressesChanged;
            _addresses = AddressSvc.GetAddresses();

            if (!string.IsNullOrEmpty(DeliveryParam))
                _deliveryMethod = DeliveryParam;

            if (!Auth.IsCliente())
                _showLoginRequired = true;
            else
            {
                _name = Auth.CurrentUser?.Name ?? "";
                if (_deliveryMethod == "delivery" && string.IsNullOrEmpty(_address) && _addresses.Count > 0)
                    _address = _addresses[0];
            }

            _authReady = true;
            UpdateNavigationGuard();
            StateHasChanged();
        }
    }

    private void OnAddressesChanged()
    {
        _addresses = AddressSvc.GetAddresses();
        InvokeAsync(StateHasChanged);
    }

    private bool ShouldGuardNavigation =>
        _authReady && Auth.IsCliente() && !_success && Cart.GetCartItems().Any();

    private void UpdateNavigationGuard()
    {
        var shouldGuard = ShouldGuardNavigation;

        if (shouldGuard && !_guardActive)
        {
            _locationChangingRegistration ??= Navigation.RegisterLocationChangingHandler(OnLocationChangingAsync);
            _guardRef ??= DotNetObjectReference.Create(this);
            _ = JS.InvokeVoidAsync("checkoutGuard.enable", _guardRef);
            _guardActive = true;
        }
        else if (!shouldGuard && _guardActive)
        {
            DisableNavigationGuard();
        }
    }

    private void DisableNavigationGuard()
    {
        _locationChangingRegistration?.Dispose();
        _locationChangingRegistration = null;
        _ = JS.InvokeVoidAsync("checkoutGuard.disable");
        _guardActive = false;
    }

    private ValueTask OnLocationChangingAsync(LocationChangingContext context)
    {
        if (!ShouldGuardNavigation || _showLeaveConfirm)
            return ValueTask.CompletedTask;

        var targetPath = new Uri(context.TargetLocation).AbsolutePath;
        if (targetPath.Equals("/checkout", StringComparison.OrdinalIgnoreCase))
            return ValueTask.CompletedTask;

        context.PreventNavigation();
        _pendingLeaveUrl = new Uri(context.TargetLocation).PathAndQuery;
        _showLeaveConfirm = true;
        _ = InvokeAsync(StateHasChanged);
        return ValueTask.CompletedTask;
    }

    [JSInvokable]
    public void OnBrowserBackAttempt()
    {
        if (!ShouldGuardNavigation) return;

        _pendingLeaveUrl = "/carrito";
        _showLeaveConfirm = true;
        InvokeAsync(StateHasChanged);
    }

    private void AskLeave(string url)
    {
        if (!ShouldGuardNavigation)
        {
            Navigation.NavigateTo(url);
            return;
        }

        _pendingLeaveUrl = url;
        _showLeaveConfirm = true;
    }

    private void CancelLeave()
    {
        _showLeaveConfirm = false;
        _pendingLeaveUrl = "/carrito";
    }

    private void ConfirmLeave()
    {
        _showLeaveConfirm = false;
        var url = _pendingLeaveUrl;
        DisableNavigationGuard();
        Navigation.NavigateTo(url);
    }

    private string CheckoutReturnUrl =>
        $"/checkout?delivery={_deliveryMethod}";

    private decimal Subtotal    => Cart.GetSubtotal();
    private decimal DeliveryFee => _deliveryMethod == "delivery" ? 5m : 0m;
    private decimal Total       => Subtotal + DeliveryFee;

    private bool CanPlaceOrder =>
        (_deliveryMethod != "delivery" || !string.IsNullOrWhiteSpace(_address)) &&
        (_payMethod != "efectivo" || CashEnough) &&
        (_payMethod != "yape" || _yapeConfirmed);

    private string FormatCard(string raw)
    {
        var digits = new string(raw.Where(char.IsDigit).ToArray());
        if (digits.Length > 16) digits = digits[..16];
        var parts = Enumerable.Range(0, (digits.Length + 3) / 4)
                              .Select(i => digits.Substring(i * 4, Math.Min(4, digits.Length - i * 4)));
        return string.Join(" ", parts);
    }

    private void OnCardNumberInput(ChangeEventArgs e)
        => _cardNumber = FormatCard(e.Value?.ToString() ?? "");

    private void OnCardExpiryInput(ChangeEventArgs e)
    {
        var digits = new string((e.Value?.ToString() ?? "").Where(char.IsDigit).ToArray());
        _cardExpiry = digits.Length >= 2
            ? digits[..2] + "/" + digits[2..Math.Min(4, digits.Length)]
            : digits;
    }

    private void OnCashQuick(decimal amount) { _cashAmount = amount; }

    private void ConfirmYape()
    {
        if (_yapeCode.Length >= 4) _yapeConfirmed = true;
    }

    private void ToggleAddressMenu() => _addressMenuOpen = !_addressMenuOpen;

    private void CloseAddressMenu() => _addressMenuOpen = false;

    private void ChooseAddress(string addr)
    {
        _address = addr;
        _addressMenuOpen = false;
    }

    private async Task ChooseAddAddress()
    {
        _addressMenuOpen = false;
        await OpenCheckoutMap();
    }

    private async Task OpenCheckoutMap()
    {
        _addressMenuOpen = false;
        _showMapModal = true;
        _pendingAddress = "";
        StateHasChanged();
        _dotnetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("mapHelpers.initMap", _dotnetRef);
    }

    private async Task CloseCheckoutMap()
    {
        _showMapModal = false;
        _pendingAddress = "";
        await JS.InvokeVoidAsync("mapHelpers.destroyMap");
    }

    private async Task ConfirmMapAddress()
    {
        if (!string.IsNullOrWhiteSpace(_pendingAddress))
        {
            await AddressSvc.AddAddressAsync(_pendingAddress);
            _addresses = AddressSvc.GetAddresses();
            _address = _pendingAddress;
        }
        await CloseCheckoutMap();
    }

    private async Task ClearMapSearch()
    {
        _pendingAddress = "";
        await JS.InvokeVoidAsync("mapHelpers.clearSearchInput");
    }

    [JSInvokable]
    public void OnMapAddressSelected(string address)
    {
        _pendingAddress = address;
        InvokeAsync(StateHasChanged);
    }

    private async Task PlaceOrder()
    {
        _isLoading = true;
        await Task.Delay(800);
        _orderId = $"SHI-2024-{(SalesSvc.GetRecentOrders().Count + 1):D4}";
        SalesSvc.AddOrder(
            _name, Cart.GetCartItems().ToList(),
            Subtotal, DeliveryFee, Total,
            _payMethod, _deliveryMethod, _address);
        await Cart.ClearCartAsync();
        DisableNavigationGuard();
        _success   = true;
        _isLoading = false;
    }

    public void Dispose()
    {
        AddressSvc.OnChange -= OnAddressesChanged;
        DisableNavigationGuard();
        _dotnetRef?.Dispose();
        _guardRef?.Dispose();
    }
}

<PageTitle>Checkout – Shiligama</PageTitle>

<style>
/* Borde de inputs adaptado a dark/light */
.checkout-input-group .input-group-text {
    border: 1.5px solid var(--border);
    border-right: none;
    background-color: var(--secondary);
    color: var(--foreground);
}
.checkout-input-group .form-control {
    border: 1.5px solid var(--border);
    border-left: none;
}
.checkout-input-group .form-control:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 0.2rem color-mix(in srgb, var(--primary) 20%, transparent);
}
.checkout-input-solo {
    border: 1.5px solid var(--border) !important;
}
.checkout-input-solo:focus {
    border-color: var(--primary) !important;
}
.checkout-address-picker {
    position: relative;
}
.checkout-address-trigger {
    width: 100%;
    min-height: 38px;
    padding: 0.4rem 0.65rem;
    font-size: 0.8125rem;
    line-height: 1.35;
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    background: var(--background);
    color: var(--foreground);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
}
.checkout-address-trigger:hover {
    border-color: color-mix(in srgb, var(--primary) 35%, var(--border));
}
.checkout-address-trigger.is-open,
.checkout-address-trigger:focus-visible {
    border-color: var(--primary);
    box-shadow: 0 0 0 0.2rem color-mix(in srgb, var(--primary) 18%, transparent);
    outline: none;
}
.checkout-address-trigger__icon {
    width: 14px;
    font-size: 0.75rem;
    flex-shrink: 0;
    color: var(--primary);
}
.checkout-address-trigger__icon--muted {
    color: var(--muted-foreground);
}
.checkout-address-trigger__chevron {
    font-size: 0.65rem;
    color: var(--muted-foreground);
    transition: transform 0.15s ease;
}
.checkout-address-trigger.is-open .checkout-address-trigger__chevron {
    transform: rotate(180deg);
}
.checkout-address-backdrop {
    position: fixed;
    inset: 0;
    z-index: 1040;
    background: transparent;
}
.checkout-address-menu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    z-index: 1050;
    margin: 0;
    padding: 0.25rem;
    list-style: none;
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    background: var(--card);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    max-height: 210px;
    overflow-y: auto;
}
.checkout-address-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.45rem 0.55rem;
    border: none;
    border-radius: calc(var(--radius) - 2px);
    background: transparent;
    color: var(--foreground);
    font-size: 0.8125rem;
    line-height: 1.35;
    text-align: left;
}
.checkout-address-item:hover {
    background: var(--secondary);
}
.checkout-address-item.is-selected {
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    font-weight: 500;
}
.checkout-address-item__icon {
    width: 14px;
    font-size: 0.75rem;
    flex-shrink: 0;
    text-align: center;
    color: var(--primary);
}
.checkout-address-item--add {
    color: var(--primary);
    font-weight: 500;
}
.checkout-address-item--add .checkout-address-item__icon {
    color: var(--primary);
}
.checkout-address-divider {
    margin: 0.2rem 0.35rem;
    border-color: var(--border);
    opacity: 1;
}
/* QR Yape: fondo blanco siempre (es un código QR real) */
.yape-qr-box {
    border: 2px solid #c4b5fd !important;
    background: white;
    width: 176px;
    height: 176px;
    border-radius: 12px;
    padding: 10px;
    position: relative;
}
/* Efectivo: fondos de la calculadora de vuelto */
.cash-calc-ok    { background: #f0fdf4; border: 2px solid #22c55e; }
.cash-calc-exact { background: var(--bs-primary-bg-subtle); border: 2px solid var(--primary); }
.cash-calc-warn  { background: #fffbeb; border: 2px solid #f59e0b; }
.cash-calc-empty { background: var(--secondary); border: 2px solid var(--border); }
.dark .cash-calc-ok    { background: #052e16; border-color: #22c55e; }
.dark .cash-calc-exact { background: color-mix(in srgb, var(--primary) 15%, transparent); }
.dark .cash-calc-warn  { background: #451a03; border-color: #f59e0b; }
/* Círculo del ícono en calculadora */
.cash-icon-ok   { background: #bbf7d0; }
.cash-icon-warn { background: #fde68a; }
.cash-icon-empty{ background: var(--secondary); }
.dark .cash-icon-ok   { background: var(--brand-green); }
.dark .cash-icon-warn { background: #451a03; }
/* Texto "falta por pagar" */
.cash-text-warn { color: #b45309; }
.dark .cash-text-warn { color: #fbbf24; }
/* Flechas del input numérico más grandes */
.cash-amount-input::-webkit-inner-spin-button,
.cash-amount-input::-webkit-outer-spin-button {
    -webkit-appearance: inner-spin-button !important;
    display: block !important;
    opacity: 1 !important;
    width: 60px;
    height: 100%;
    cursor: pointer;
}
.cash-amount-input {
    -moz-appearance: spinner-textfield !important;
    padding-right: 60px !important;
}
/* Quick amount disabled style */
.cash-quick-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
}
</style>

<LoginRequiredModal @bind-IsOpen="_showLoginRequired" ReturnUrl="@CheckoutReturnUrl" />

@if (_success)
{
    <div class="container py-5 text-center" style="max-width:480px;">
        <div class="d-flex align-items-center justify-content-center rounded-circle bg-success mx-auto mb-4"
             style="width:80px;height:80px;">
            <Icons Name="Check" Class="text-white" style="width:40px;height:40px;" />
        </div>
        <h2 class="fs-3 fw-bold text-foreground mb-2">¡Pedido confirmado!</h2>
        <p class="text-muted-foreground mb-1">Número de orden: <strong class="text-primary">@_orderId</strong></p>
        <p class="text-muted-foreground small">Recibirás una confirmación pronto.</p>
        <a href="/catalogo" class="btn btn-primary mt-3 px-4" style="border-radius:var(--radius);">
            Seguir comprando
        </a>
    </div>
}
else if (!Cart.GetCartItems().Any())
{
    <div class="container py-5 text-center" style="max-width:480px;">
        <p class="text-muted-foreground">Tu carrito está vacío.</p>
        <a href="/catalogo" class="btn btn-primary" style="border-radius:var(--radius);">Ir al catálogo</a>
    </div>
}
else if (_authReady && !Auth.IsCliente())
{
    <div class="container py-5 text-center" style="max-width:480px;">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
             style="width:64px;height:64px;background:color-mix(in srgb, var(--primary) 12%, transparent);">
            <i class="fa-solid fa-lock text-primary" style="font-size:1.5rem;"></i>
        </div>
        <h2 class="fs-5 fw-bold text-foreground mb-2">Inicia sesión para continuar</h2>
        <p class="text-muted-foreground small mb-4">
            Necesitas una cuenta de cliente para completar el checkout.
        </p>
        <a href="/carrito" class="btn btn-outline-secondary" style="border-radius:var(--radius);">
            Volver al carrito
        </a>
    </div>
}
else if (!_authReady)
{
    <div class="container py-5 text-center text-muted-foreground small">Cargando...</div>
}
else
{
    <header class="border-bottom bg-card py-3 sticky-top" style="z-index: 1010;">
        <div class="container-xl px-3 d-flex align-items-center" style="max-width:960px;">
            <button type="button"
                    class="btn btn-link text-muted-foreground text-decoration-none d-flex align-items-center gap-1 small p-0 border-0"
                    @onclick="@(() => AskLeave("/carrito"))">
                <Icons Name="ArrowLeft" style="width:16px;height:16px;" /> Volver al carrito
            </button>
            <div class="mx-auto d-flex align-items-center gap-2">
                <Icons Name="Lock" Class="text-primary" style="width:16px;height:16px;" />
                <h1 class="fs-5 fw-semibold text-foreground mb-0">Pago Seguro</h1>
            </div>
            <div style="width:140px;"></div>
        </div>
    </header>

    <div class="container-xl px-3 py-4" style="max-width:960px;">
        <div class="row g-4">

            <!-- Resumen -->
            <div class="col-lg-5 order-2 order-lg-1">
                <div class="card p-4 border border-border rounded-3">
                    <h2 class="fs-5 fw-semibold text-foreground mb-3">Resumen del Pedido</h2>
                    <div class="d-flex flex-column gap-2 mb-3">
                        @foreach (var item in Cart.GetCartItems())
                        {
                            <div class="d-flex justify-content-between align-items-start small">
                                <div>
                                    <p class="fw-medium text-foreground mb-0">@item.Name</p>
                                    <p class="text-muted-foreground mb-0">Cantidad: @item.Quantity</p>
                                </div>
                                <span class="fw-medium text-foreground ms-2">
                                    S/. @((item.Price * item.Quantity).ToString("0.00"))
                                </span>
                            </div>
                        }
                    </div>
                    <hr class="border-color-default" />
                    <div class="d-flex justify-content-between small text-muted-foreground mb-1">
                        <span>Subtotal (@Cart.GetCartItems().Sum(i => i.Quantity) productos)</span>
                        <span>S/. @Subtotal.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between small text-muted-foreground mb-2">
                        <span>Envío</span>
                        <span>@(DeliveryFee > 0 ? $"S/. {DeliveryFee:0.00}" : "Gratis")</span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold text-foreground pt-2 border-top border-border mb-3">
                        <span>Total a pagar</span>
                        <span class="text-primary">S/. @Total.ToString("0.00")</span>
                    </div>
                    <div class="d-flex align-items-center gap-3 p-3 border border-border rounded-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:40px;height:40px;
                                    background:@(_deliveryMethod == "delivery"
                                        ? "color-mix(in srgb, #3b82f6 15%, transparent)"
                                        : "color-mix(in srgb, #22c55e 15%, transparent)");">
                            <Icons Name="@(_deliveryMethod == "delivery" ? "Truck" : "Store")"
                                   Class="@(_deliveryMethod == "delivery" ? "text-primary" : "text-success")"
                                   style="width:18px;height:18px;" />
                        </div>
                        <div>
                            <p class="fw-medium small mb-0">
                                @(_deliveryMethod == "delivery" ? "Entrega a domicilio" : "Recojo en tienda")
                            </p>
                            @if (_deliveryMethod == "delivery")
                            {
                                <p class="text-muted-foreground mb-0" style="font-size:.72rem;">
                                    Elige la dirección en el desplegable
                                </p>
                            }
                        </div>
                    </div>
                    @if (_deliveryMethod == "delivery")
                    {
                        <div class="mt-3 checkout-address-picker">
                            <label class="form-label small fw-semibold text-foreground mb-2" id="checkout-address-label">
                                <i class="fa-solid fa-location-dot me-1 text-primary" style="font-size:0.75rem;"></i>
                                Dirección de entrega
                            </label>

                            @if (_addressMenuOpen)
                            {
                                <div class="checkout-address-backdrop" @onclick="CloseAddressMenu"></div>
                            }

                            <button type="button"
                                    id="checkout-address"
                                    class="checkout-address-trigger d-flex align-items-center gap-2 @(_addressMenuOpen ? "is-open" : "")"
                                    aria-labelledby="checkout-address-label"
                                    aria-haspopup="listbox"
                                    aria-expanded="@_addressMenuOpen"
                                    @onclick="ToggleAddressMenu">
                                @if (string.IsNullOrWhiteSpace(_address))
                                {
                                    <i class="fa-solid fa-location-dot checkout-address-trigger__icon checkout-address-trigger__icon--muted"></i>
                                    <span class="text-muted-foreground flex-grow-1 text-truncate">Selecciona una dirección</span>
                                }
                                else
                                {
                                    <i class="fa-solid fa-location-dot checkout-address-trigger__icon"></i>
                                    <span class="flex-grow-1 text-truncate">@_address</span>
                                }
                                <i class="fa-solid fa-chevron-down checkout-address-trigger__chevron ms-auto"></i>
                            </button>

                            @if (_addressMenuOpen)
                            {
                                <ul class="checkout-address-menu" role="listbox" aria-label="Direcciones guardadas">
                                    @foreach (var addr in _addresses)
                                    {
                                        <li>
                                            <button type="button"
                                                    role="option"
                                                    aria-selected="@(_address == addr)"
                                                    class="checkout-address-item @(_address == addr ? "is-selected" : "")"
                                                    @onclick="@(() => ChooseAddress(addr))">
                                                <i class="fa-solid fa-location-dot checkout-address-item__icon" aria-hidden="true"></i>
                                                <span class="text-truncate">@addr</span>
                                            </button>
                                        </li>
                                    }
                                    <li><hr class="checkout-address-divider" /></li>
                                    <li>
                                        <button type="button"
                                                class="checkout-address-item checkout-address-item--add"
                                                @onclick="ChooseAddAddress">
                                            <i class="fa-solid fa-plus checkout-address-item__icon" aria-hidden="true"></i>
                                            <span>Agregar otra dirección</span>
                                        </button>
                                    </li>
                                </ul>
                            }

                            @if (string.IsNullOrWhiteSpace(_address))
                            {
                                <p class="text-danger mb-0 mt-2" style="font-size:0.75rem;">Selecciona o agrega una dirección para continuar.</p>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Métodos de pago -->
            <div class="col-lg-7 order-1 order-lg-2">
                <div class="card p-4 border border-border rounded-3">
                    <h2 class="fs-5 fw-bold text-foreground mb-1">Selecciona tu método de pago</h2>
                    <p class="text-muted-foreground small mb-4">
                        Elige cómo deseas pagar tu pedido de forma segura
                    </p>

                    <div class="btn-group w-100 mb-4" role="group">
                        @foreach (var (key, label, icon) in new[] {
                            ("tarjeta","Tarjeta","CreditCard"),
                            ("yape","Yape","Smartphone"),
                            ("efectivo","Efectivo","Banknote")})
                        {
                            <button type="button"
                                    class="btn d-flex align-items-center justify-content-center gap-2
                                           @(_payMethod == key ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="() => _payMethod = key">
                                <Icons Name="@icon" style="width:15px;height:15px;" />
                                <span class="small">@label</span>
                            </button>
                        }
                    </div>

                    @if (_payMethod == "tarjeta")
                    {
                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center justify-content-between pb-3 border-bottom border-border">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-2 d-flex align-items-center justify-content-center"
                                         style="width:32px;height:32px;background:#009EE3;">
                                        <span class="text-white fw-bold small">MP</span>
                                    </div>
                                    <span class="text-muted-foreground small">Procesado por Mercado Pago</span>
                                </div>
                                <div class="d-flex gap-1">
                                    <div class="border rounded d-flex align-items-center justify-content-center"
                                         style="width:44px;height:28px;background:var(--card);">
                                        <span class="fw-bold small" style="color:#1A1F71;font-style:italic;">VISA</span>
                                    </div>
                                    <div class="border rounded d-flex align-items-center justify-content-center"
                                         style="width:44px;height:28px;background:var(--card);">
                                        <div class="d-flex">
                                            <div class="rounded-circle bg-danger" style="width:14px;height:14px;margin-right:-4px;"></div>
                                            <div class="rounded-circle bg-warning" style="width:14px;height:14px;"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <label class="form-label small fw-medium">Número de tarjeta</label>
                                <div class="input-group checkout-input-group">
                                    <span class="input-group-text">
                                        <Icons Name="CreditCard" style="width:16px;height:16px;" />
                                    </span>
                                    <input type="text" class="form-control font-monospace"
                                           placeholder="1234 5678 9012 3456"
                                           maxlength="19" value="@_cardNumber" @oninput="OnCardNumberInput" />
                                </div>
                            </div>
                            <div>
                                <label class="form-label small fw-medium">Nombre del titular</label>
                                <div class="input-group checkout-input-group">
                                    <span class="input-group-text">
                                        <Icons Name="User" style="width:16px;height:16px;" />
                                    </span>
                                    <input type="text" class="form-control text-uppercase"
                                           placeholder="COMO APARECE EN LA TARJETA"
                                           @bind="_cardName" />
                                </div>
                            </div>
                            <div class="row g-3">
                                <div class="col-6">
                                    <label class="form-label small fw-medium">Vencimiento</label>
                                    <div class="input-group checkout-input-group">
                                        <span class="input-group-text">
                                            <Icons Name="Calendar" style="width:16px;height:16px;" />
                                        </span>
                                        <input type="text" class="form-control font-monospace"
                                               placeholder="MM/AA" maxlength="5"
                                               value="@_cardExpiry" @oninput="OnCardExpiryInput" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-medium">CVV</label>
                                    <div class="input-group checkout-input-group">
                                        <span class="input-group-text">
                                            <Icons Name="Lock" style="width:16px;height:16px;" />
                                        </span>
                                        <input type="password" class="form-control font-monospace"
                                               placeholder="•••" maxlength="4" @bind="_cardCvv" />
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex gap-2 p-3 rounded-3 border"
                                 style="background:color-mix(in srgb,var(--primary) 8%,transparent);
                                        border-color:color-mix(in srgb,var(--primary) 30%,transparent)!important;">
                                <Icons Name="Lock" Class="text-primary flex-shrink-0"
                                       style="width:14px;height:14px;margin-top:2px;" />
                                <p class="text-muted-foreground mb-0 small">
                                    Tu información de pago está encriptada y segura.
                                    Nunca almacenamos los datos de tu tarjeta.
                                </p>
                            </div>
                        </div>
                    }

                    @if (_payMethod == "yape")
                    {
                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center gap-3 pb-3 border-bottom border-border">
                                <div class="rounded-3 d-flex align-items-center justify-content-center"
                                     style="width:48px;height:48px;
                                            background:linear-gradient(135deg,#7c3aed,#6d28d9);">
                                    <span class="text-white fw-bold fs-5">Y</span>
                                </div>
                                <div>
                                    <p class="fw-semibold text-foreground mb-0">Paga con Yape</p>
                                    <p class="text-muted-foreground small mb-0">Escanea el QR o ingresa tu número</p>
                                </div>
                            </div>
                            <div class="row g-4">
                                <div class="col-md-6 d-flex flex-column align-items-center gap-2">
                                    <div class="yape-qr-box">
                                        <div style="display:grid;grid-template-columns:repeat(7,1fr);
                                                    gap:2px;width:100%;height:100%;">
                                            @for (int r = 0; r < 49; r++)
                                            {
                                                bool filled = (r % 3 == 0 || r % 7 == 1 || r % 5 == 2);
                                                <div style="background:@(filled ? "#3b0764" : "white");
                                                            border-radius:1px;"></div>
                                            }
                                        </div>
                                        <div class="position-absolute top-50 start-50 translate-middle bg-white rounded-2 p-1">
                                            <div class="rounded-2 d-flex align-items-center justify-content-center"
                                                 style="width:28px;height:28px;
                                                        background:linear-gradient(135deg,#7c3aed,#6d28d9);">
                                                <span class="text-white fw-bold small">Y</span>
                                            </div>
                                        </div>
                                    </div>
                                    <span class="badge bg-primary">S/. @Total.ToString("0.00")</span>
                                    <p class="text-muted-foreground small text-center mb-0">Escanea con tu app Yape</p>
                                </div>
                                <div class="col-md-6 d-flex flex-column gap-3 justify-content-center">
                                    <p class="text-muted-foreground small text-center mb-0">— O confirma manualmente —</p>
                                    <div>
                                        <label class="form-label small fw-medium">Tu número Yape</label>
                                        <div class="input-group checkout-input-group">
                                            <span class="input-group-text">
                                                <Icons Name="Smartphone" style="width:15px;height:15px;" />
                                            </span>
                                            <input type="tel" class="form-control font-monospace"
                                                   placeholder="999 999 999" maxlength="9" @bind="_yapePhone" />
                                        </div>
                                    </div>
                                    <div>
                                        <label class="form-label small fw-medium">Código de confirmación</label>
                                        <div class="input-group checkout-input-group">
                                            <span class="input-group-text">
                                                <Icons Name="Hash" style="width:15px;height:15px;" />
                                            </span>
                                            <input type="text" class="form-control"
                                                   placeholder="Código de tu app Yape" @bind="_yapeCode" />
                                        </div>
                                        <p class="form-text">Encuéntralo en tu app tras escanear el QR</p>
                                    </div>
                                    @if (!_yapeConfirmed)
                                    {
                                        <button class="btn btn-outline-secondary btn-sm"
                                                @onclick="ConfirmYape"
                                                disabled="@(_yapeCode.Length < 4)">
                                            <Icons Name="CheckCircle" style="width:14px;height:14px;" />
                                            Confirmar pago Yape
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="alert alert-success py-2 small mb-0">
                                            <Icons Name="CheckCircle" style="width:14px;height:14px;" />
                                            Pago Yape verificado correctamente
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="alert alert-light border small mb-0"
                                 style="border-color:#c4b5fd!important;">
                                <strong>Instrucciones:</strong> Abre tu app Yape, escanea el código QR
                                y confirma el pago. Luego ingresa el código de confirmación que te da la app.
                            </div>
                        </div>
                    }

                    @if (_payMethod == "efectivo")
                    {
                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center gap-3 pb-3 border-bottom border-border">
                                <div class="rounded-3 d-flex align-items-center justify-content-center"
                                     style="width:48px;height:48px;
                                            background:linear-gradient(135deg,#16a34a,#15803d);">
                                    <Icons Name="Banknote" Class="text-white" style="width:22px;height:22px;" />
                                </div>
                                <div>
                                    <p class="fw-semibold text-foreground mb-0">Pago en Efectivo</p>
                                    <p class="text-muted-foreground small mb-0">Calcula tu vuelto antes de pagar</p>
                                </div>
                            </div>

                            <div class="text-center p-4 rounded-3" style="background:var(--secondary);">
                                <p class="text-muted-foreground small mb-1">Total a pagar</p>
                                <p class="fw-bold text-primary mb-0" style="font-size:2rem;">
                                    S/. @Total.ToString("0.00")
                                </p>
                            </div>

                            <div>
                                <label class="form-label small fw-medium">Monto rápido</label>
                                <div class="d-grid gap-2" style="grid-template-columns:repeat(4,1fr);">
                                    @foreach (var amount in new[] { 20m, 50m, 100m, 200m })
                                    {
                                        <button type="button"
                                                class="btn btn-sm cash-quick-btn @(_cashAmount == amount ? "btn-primary" : "btn-outline-secondary")"
                                                style="height:44px;font-weight:600;"
                                                disabled="@(amount < Total)"
                                                @onclick="() => OnCashQuick(amount)">
                                            S/. @amount
                                        </button>
                                    }
                                </div>
                            </div>

                            <div>
                                <label class="form-label small fw-medium">
                                    O ingresa el monto con el que pagarás
                                </label>
                                <div class="input-group checkout-input-group">
                                    <span class="input-group-text fw-medium">S/.</span>
                                    <input type="number" class="form-control text-center fw-bold fs-5 cash-amount-input"
                                           style="height:52px;"
                                           placeholder="0.00" step="0.1" min="0"
                                           @bind="_cashAmount" @bind:event="oninput" />
                                </div>
                            </div>

                            <div class="p-4 rounded-3
                                @(CashEnough
                                    ? (_cashAmount == Total ? "cash-calc-exact" : "cash-calc-ok")
                                    : _cashAmount > 0 ? "cash-calc-warn" : "cash-calc-empty")">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0
                                        @(CashEnough ? "cash-icon-ok" : _cashAmount > 0 ? "cash-icon-warn" : "cash-icon-empty")"
                                         style="width:44px;height:44px;">
                                        <Icons Name="@(CashEnough ? "Coins" : "Calculator")"
                                               Class="@(CashEnough ? "text-success" : _cashAmount > 0 ? "text-warning" : "text-muted-foreground")"
                                               style="width:20px;height:20px;" />
                                    </div>
                                    <div>
                                        @if (_cashAmount == 0)
                                        {
                                            <p class="text-muted-foreground small mb-0">Tu vuelto</p>
                                            <p class="fw-bold text-muted-foreground mb-0">
                                                Primero selecciona o escribe el monto que pagarás
                                            </p>
                                        }
                                        else if (CashEnough)
                                        {
                                            @if (_cashAmount == Total)
                                            {
                                                <p class="text-primary small fw-medium mb-0">Monto exacto</p>
                                                <p class="fw-bold text-primary mb-0">No hay vuelto</p>
                                            }
                                            else
                                            {
                                                <p class="text-success small fw-medium mb-0">Tu vuelto será</p>
                                                <p class="fw-bold text-success mb-0" style="font-size:1.5rem;">
                                                    S/. @CashChange.ToString("0.00")
                                                </p>
                                            }
                                        }
                                        else
                                        {
                                            <p class="small fw-medium mb-0 cash-text-warn">Falta por pagar</p>
                                            <p class="fw-bold mb-0 cash-text-warn">
                                                S/. @((Total - _cashAmount).ToString("0.00"))
                                            </p>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex gap-2 p-3 rounded-3" style="background:var(--secondary);">
                                <Icons Name="Banknote" Class="text-muted-foreground flex-shrink-0"
                                       style="width:16px;height:16px;margin-top:2px;" />
                                <div class="small">
                                    <p class="fw-medium text-foreground mb-1">Pago contra entrega</p>
                                    <p class="text-muted-foreground mb-0">
                                        El repartidor llevará el vuelto exacto.
                                        Por favor ten el dinero listo para agilizar la entrega.
                                    </p>
                                </div>
                            </div>
                        </div>
                    }

                    <button class="btn btn-primary w-100 fw-semibold mt-4 d-flex align-items-center justify-content-center gap-2"
                            style="height:52px;border-radius:var(--radius);"
                            disabled="@(_isLoading || !CanPlaceOrder)"
                            @onclick="PlaceOrder">
                        @if (_isLoading)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                            <span>Procesando pago...</span>
                        }
                        else
                        {
                            <Icons Name="ShieldCheck" style="width:18px;height:18px;" />
                            <span>Pagar S/. @Total.ToString("0.00")</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ===== Map Modal (Checkout) ===== *@
@if (_showMapModal)
{
    <div style="position: fixed; inset: 0; z-index: 1050; background: rgba(0,0,0,0.5);
                display: flex; align-items: center; justify-content: center;"
         @onclick="CloseCheckoutMap">
        <div style="background: white; border-radius: 16px; width: 90%; max-width: 650px;
                    box-shadow: 0 25px 60px rgba(0,0,0,0.3); overflow: hidden;"
             @onclick:stopPropagation="true">
            <div class="d-flex align-items-center justify-content-between px-4 py-3"
                 style="border-bottom: 1px solid #e5e7eb;">
                <h5 class="fw-bold mb-0" style="font-family: 'Outfit', sans-serif; font-size: 1.1rem; color: #111827;">
                    <i class="fa-solid fa-map-location-dot me-2" style="color: #1A6B3C;"></i>Seleccionar dirección
                </h5>
                <button type="button" @onclick="CloseCheckoutMap"
                        style="background: none; border: none; font-size: 1.3rem; color: #6b7280; cursor: pointer; line-height: 1;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <!-- Buscador de dirección -->
            <div class="px-4 py-2 border-bottom" style="background-color: #f9fafb;">
                <div class="position-relative w-100">
                    <i class="fa-solid fa-magnifying-glass text-muted-foreground position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 0.95rem;"></i>
                    <input type="text" id="map-search-input-checkout" class="form-control text-foreground" style="height: 44px; padding-left: 42px; padding-right: 42px; border-radius: 8px; border: 1px solid #d1d5db; font-size: 0.9rem;" placeholder="Escribe una dirección (ej: Av. Larco 123, Miraflores)..." />
                    <button type="button"
                            @onclick="ClearMapSearch"
                            title="Limpiar búsqueda"
                            style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
                                   background: none; border: none; color: #9ca3af; cursor: pointer;
                                   width: 28px; height: 28px; border-radius: 50%; display: flex;
                                   align-items: center; justify-content: center; line-height: 1;">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            </div>

            <div id="address-map" style="width: 100%; height: 350px;"></div>
            <div class="px-4 py-3" style="border-top: 1px solid #e5e7eb;">
                @if (!string.IsNullOrWhiteSpace(_pendingAddress))
                {
                    <div class="d-flex align-items-start gap-2 mb-3 p-2"
                         style="background: #f0fdf4; border-radius: 8px; border: 1px solid #bbf7d0;">
                        <i class="fa-solid fa-location-dot mt-1" style="color: #1A6B3C; flex-shrink: 0;"></i>
                        <span style="font-size: 0.85rem; color: #374151; word-break: break-word;">@_pendingAddress</span>
                    </div>
                }
                else
                {
                    <p class="text-muted-foreground mb-3" style="font-size: 0.85rem;">
                        <i class="fa-solid fa-hand-pointer me-1"></i> Haz clic en el mapa para seleccionar una dirección
                    </p>
                }
                <div class="d-flex gap-2 justify-content-end">
                    <button type="button" @onclick="CloseCheckoutMap"
                            class="btn btn-outline-secondary px-3 py-2"
                            style="border-radius: 8px; font-size: 0.9rem;">
                        Cancelar
                    </button>
                    <button type="button" @onclick="ConfirmMapAddress"
                            class="btn text-white px-3 py-2 fw-semibold d-flex align-items-center gap-2"
                            style="background-color: #1A6B3C; border-radius: 8px; font-size: 0.9rem; border: none;"
                            disabled="@(string.IsNullOrWhiteSpace(_pendingAddress))">
                        <i class="fa-solid fa-check"></i> Confirmar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showLeaveConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">⚠️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Está seguro que quiere salir?</h5>
                    <p class="text-muted-foreground small mb-4">Si sales ahora, perderás el progreso de tu pago.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button" class="btn btn-outline-secondary" style="border-radius:var(--radius);" @onclick="ConfirmLeave">Salir</button>
                        <button type="button" class="btn btn-primary" style="border-radius:var(--radius);" @onclick="CancelLeave">Continuar con el pago</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}