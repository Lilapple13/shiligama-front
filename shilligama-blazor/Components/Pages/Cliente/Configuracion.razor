@page "/configuracion"
@layout MainLayout
@inject AuthService Auth
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

@code {
    private string _name = "";
    private string _dni = "12345678";
    private string _phone = "987654321";
    private string _phonePrefix = "+51";

    private List<string> _addresses = new()
    {
        "Avenida Universitaria 123",
        "Av Los Olivos 321",
        "Av Los Olivos 432"
    };
    private bool _success = false;
    private bool _showMapModal = false;
    private string _pendingAddress = "";
    private DotNetObjectReference<Configuracion>? _dotnetRef;

    protected override void OnInitialized()
    {
        if (!Auth.IsLoggedIn())
        {
            Navigation.NavigateTo("/");
            return;
        }

        _name = Auth.CurrentUser?.Name ?? "Juan Pérez";
    }

    private string _nameError = "";
    private string _dniError = "";
    private string _phoneError = "";

    private void ValidateName()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _nameError = "El nombre completo es obligatorio.";
        }
        else if (!System.Text.RegularExpressions.Regex.IsMatch(_name.Trim(), @"^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]+$"))
        {
            _nameError = "El nombre completo solo debe contener letras.";
        }
        else
        {
            _nameError = "";
        }
    }

    private void ValidateDni()
    {
        if (_dni != null)
        {
            _dni = new string(_dni.Where(char.IsDigit).ToArray());
        }

        if (string.IsNullOrWhiteSpace(_dni))
        {
            _dniError = "El DNI es obligatorio.";
        }
        else if (_dni.Length != 8)
        {
            _dniError = "El DNI debe contener exactamente 8 números.";
        }
        else
        {
            _dniError = "";
        }
    }

    private void ValidatePhone()
    {
        if (_phone != null)
        {
            _phone = new string(_phone.Where(char.IsDigit).ToArray());
        }

        if (string.IsNullOrWhiteSpace(_phone))
        {
            _phoneError = "El teléfono es obligatorio.";
        }
        else if (_phone.Length != 9)
        {
            _phoneError = "El teléfono debe contener exactamente 9 números.";
        }
        else
        {
            _phoneError = "";
        }
    }

    private async Task SaveChanges()
    {
        ValidateName();
        ValidateDni();
        ValidatePhone();

        if (!string.IsNullOrEmpty(_nameError) || !string.IsNullOrEmpty(_dniError) || !string.IsNullOrEmpty(_phoneError))
        {
            return;
        }

        _success = true;
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);

        _ = Task.Run(async () =>
        {
            await Task.Delay(4500);
            _success = false;
            await InvokeAsync(StateHasChanged);
        });

        StateHasChanged();
    }

    private void DeleteAddress(string addr)
    {
        _addresses.Remove(addr);
    }

    private async Task OpenMapModal()
    {
        _showMapModal = true;
        _pendingAddress = "";
        StateHasChanged();
        _dotnetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("mapHelpers.initMap", _dotnetRef);
    }

    private async Task CloseMapModal()
    {
        _showMapModal = false;
        _pendingAddress = "";
        await JS.InvokeVoidAsync("mapHelpers.destroyMap");
    }

    private async Task ConfirmAddress()
    {
        if (!string.IsNullOrWhiteSpace(_pendingAddress))
        {
            _addresses.Add(_pendingAddress);
        }
        await CloseMapModal();
    }

    [JSInvokable]
    public void OnMapAddressSelected(string address)
    {
        _pendingAddress = address;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _dotnetRef?.Dispose();
    }
}

<PageTitle>Configuración – Shiligama</PageTitle>

<div class="container-xl px-3 px-sm-4 py-4" style="max-width: 680px;">
    <!-- Back Button -->
    <nav class="mb-3">
        <a href="/catalogo" class="text-muted-foreground text-decoration-none small d-inline-flex align-items-center gap-2" style="transition: color 0.2s; font-weight: 500;">
            <i class="fa-solid fa-chevron-left" style="font-size: 0.85rem;"></i> Volver al catálogo
        </a>
    </nav>

    <h1 class="fs-2 fw-bold text-foreground mb-1" style="font-family: 'Outfit', sans-serif; color: #111827 !important;">Configuración</h1>
    <p class="text-muted-foreground small mt-1 mb-4" style="font-size: 0.9rem; color: #4b5563 !important;">Administra tu información personal y preferencias de entrega</p>



    <EditForm Model="this" OnValidSubmit="SaveChanges" class="d-flex flex-column gap-4">
        <!-- 1. Personal Information Card -->
        <div class="card p-4 d-flex flex-column gap-3 shadow-sm" style="border-radius: 12px; border: 1px solid rgba(0,0,0,0.08); background-color: var(--card);">
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background-color: #E8F5E9; flex-shrink: 0;">
                    <i class="fa-regular fa-user" style="color: #1A6B3C; font-size: 1.1rem;"></i>
                </div>
                <div>
                    <h3 class="fw-bold text-foreground mb-0" style="font-size: 1.05rem; font-family: 'Outfit', sans-serif;">Información Personal</h3>
                    <p class="text-muted-foreground small mb-0" style="font-size: 0.8rem;">Tu nombre y documento de identidad</p>
                </div>
            </div>
            
            <div class="row g-3 mt-1">
                <div class="col-md-7">
                    <label class="form-label small fw-medium text-foreground mb-1.5">Nombre completo</label>
                    <input type="text" @bind="_name" @bind:event="oninput" @bind:after="ValidateName" required class="form-control text-foreground @(string.IsNullOrEmpty(_nameError) ? "" : "is-invalid")" style="height: 44px; border-radius: 8px; border: 1px solid #d1d5db;" />
                    @if (!string.IsNullOrEmpty(_nameError))
                    {
                        <div class="text-danger small mt-1"><i class="fa-solid fa-triangle-exclamation me-1"></i>@_nameError</div>
                    }
                </div>
                <div class="col-md-5">
                    <label class="form-label small fw-medium text-foreground mb-1.5">DNI</label>
                    <div class="position-relative">
                        <i class="fa-regular fa-id-card text-muted-foreground position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 0.95rem; z-index: 10;"></i>
                        <input type="text" @bind="_dni" @bind:event="oninput" @bind:after="ValidateDni" maxlength="8" required class="form-control text-foreground @(string.IsNullOrEmpty(_dniError) ? "" : "is-invalid")" style="height: 44px; padding-left: 42px; border-radius: 8px; border: 1px solid #d1d5db;" />
                    </div>
                    @if (!string.IsNullOrEmpty(_dniError))
                    {
                        <div class="text-danger small mt-1"><i class="fa-solid fa-triangle-exclamation me-1"></i>@_dniError</div>
                    }
                </div>
            </div>
        </div>

        <!-- 2. Contact Information Card -->
        <div class="card p-4 d-flex flex-column gap-3 shadow-sm" style="border-radius: 12px; border: 1px solid rgba(0,0,0,0.08); background-color: var(--card);">
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background-color: #E8F5E9; flex-shrink: 0;">
                    <i class="fa-solid fa-phone" style="color: #1A6B3C; font-size: 1.1rem;"></i>
                </div>
                <div>
                    <h3 class="fw-bold text-foreground mb-0" style="font-size: 1.05rem; font-family: 'Outfit', sans-serif;">Contacto</h3>
                    <p class="text-muted-foreground small mb-0" style="font-size: 0.8rem;">Tu número de teléfono para coordinar entregas</p>
                </div>
            </div>
            
            <div class="mt-1">
                <label class="form-label small fw-medium text-foreground mb-1.5">Teléfono</label>
                <div class="input-group">
                    <select @bind="_phonePrefix" class="form-select flex-shrink-0" style="max-width: 120px; height: 44px; border-radius: 8px 0 0 8px; border: 1px solid #d1d5db; background-color: var(--secondary); color: var(--foreground); font-weight: 500;">
                        <option value="+51">🇵🇪 +51</option>
                        <option value="+52">🇲🇽 +52</option>
                        <option value="+54">🇦🇷 +54</option>
                        <option value="+56">🇨🇱 +56</option>
                        <option value="+57">🇨🇴 +57</option>
                        <option value="+58">🇻🇪 +58</option>
                        <option value="+1">🇺🇸 +1</option>
                    </select>
                    <input type="text" @bind="_phone" @bind:event="oninput" @bind:after="ValidatePhone" maxlength="9" required class="form-control text-foreground @(string.IsNullOrEmpty(_phoneError) ? "" : "is-invalid")" style="height: 44px; border-radius: 0 8px 8px 0; border: 1px solid #d1d5db; border-left: none;" placeholder="999999999" />
                </div>
                @if (!string.IsNullOrEmpty(_phoneError))
                {
                    <div class="text-danger small mt-1"><i class="fa-solid fa-triangle-exclamation me-1"></i>@_phoneError</div>
                }
                <div class="form-text text-muted-foreground mt-1.5" style="font-size: 0.75rem;">Usaremos este número para contactarte sobre tus pedidos.</div>
            </div>
        </div>

        <!-- 3. Delivery Address Card -->
        <div class="card p-4 d-flex flex-column gap-3 shadow-sm" style="border-radius: 12px; border: 1px solid rgba(0,0,0,0.08); background-color: var(--card);">
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background-color: #E8F5E9; flex-shrink: 0;">
                    <i class="fa-solid fa-location-dot" style="color: #1A6B3C; font-size: 1.1rem;"></i>
                </div>
                <div>
                    <h3 class="fw-bold text-foreground mb-0" style="font-size: 1.05rem; font-family: 'Outfit', sans-serif;">Dirección de Entrega</h3>
                    <p class="text-muted-foreground small mb-0" style="font-size: 0.8rem;">La dirección donde recibirás tus pedidos</p>
                </div>
            </div>
            
            <div class="mt-1">
                <label class="form-label small fw-medium text-foreground mb-2">Mis direcciones</label>
                @if (_addresses.Count == 0)
                {
                    <div class="d-flex flex-column align-items-center justify-content-center py-4 px-3"
                         style="border-radius: 10px; border: 1px dashed #d1d5db; background-color: #f9fafb;">
                        <i class="fa-solid fa-map-location-dot" style="font-size: 2rem; color: #c4c9d1; margin-bottom: 8px;"></i>
                        <span style="font-size: 0.95rem; color: #6b7280; font-weight: 500;">No hay direcciones registradas</span>
                        <span style="font-size: 0.8rem; color: #9ca3af;">Agrega una dirección para recibir tus pedidos</span>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var addr in _addresses)
                        {
                            <div class="d-flex align-items-center gap-3 px-3 py-2"
                                 style="border-radius: 10px; border: 1px solid #e5e7eb; background-color: #f9fafb;">
                                <i class="fa-solid fa-location-dot" style="color: #1A6B3C; font-size: 0.9rem; flex-shrink: 0;"></i>
                                <span style="font-size: 0.95rem; color: #374151; flex-grow: 1;">@addr</span>
                                <button type="button"
                                        @onclick="@(() => DeleteAddress(addr))"
                                        title="Eliminar dirección"
                                        style="background: none; border: none; padding: 4px 6px; border-radius: 6px;
                                               color: #9ca3af; cursor: pointer; line-height: 1;"
                                        onmouseover="this.style.color='#ef4444';this.style.backgroundColor='#fef2f2';"
                                        onmouseout="this.style.color='#9ca3af';this.style.backgroundColor='transparent';">
                                    <i class="fa-solid fa-trash" style="font-size: 0.8rem;"></i>
                                </button>
                            </div>
                        }
                    </div>
                    <div class="form-text text-muted-foreground mt-2" style="font-size: 0.75rem;">Estas son las direcciones disponibles para recibir tus pedidos.</div>
                }

                <!-- Agregar Dirección button -->
                <button type="button" @onclick="OpenMapModal"
                        class="btn d-flex align-items-center gap-2 mt-3 px-3 py-2"
                        style="border: 2px dashed #1A6B3C; border-radius: 10px; background: transparent;
                               color: #1A6B3C; font-weight: 600; font-size: 0.9rem; transition: all 0.2s;"
                        onmouseover="this.style.backgroundColor='#f0fdf4';"
                        onmouseout="this.style.backgroundColor='transparent';">
                    <i class="fa-solid fa-plus"></i> Agregar Dirección
                </button>
            </div>
        </div>

        <!-- Bottom Save Bar -->
        <div class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-3 mt-2 mb-4">
            <span class="text-muted-foreground" style="font-size: 0.85rem;">Los cambios se guardarán automáticamente en tu perfil.</span>
            <button type="submit" class="btn text-white px-4 py-2.5 fw-semibold d-flex align-items-center justify-content-center gap-2 w-100 w-sm-auto" style="background-color: #1A6B3C; border-radius: 8px; font-size: 0.95rem; border: none; transition: background-color 0.2s;">
                <i class="fa-solid fa-floppy-disk"></i> Guardar cambios
            </button>
        </div>
    </EditForm>
</div>

@* ===== Map Modal ===== *@
@if (_showMapModal)
{
    <div style="position: fixed; inset: 0; z-index: 1050; background: rgba(0,0,0,0.5);
                display: flex; align-items: center; justify-content: center;"
         @onclick="CloseMapModal">
        <div style="background: white; border-radius: 16px; width: 90%; max-width: 650px;
                    box-shadow: 0 25px 60px rgba(0,0,0,0.3); overflow: hidden;"
             @onclick:stopPropagation="true">
            <!-- Modal header -->
            <div class="d-flex align-items-center justify-content-between px-4 py-3"
                 style="border-bottom: 1px solid #e5e7eb;">
                <h5 class="fw-bold mb-0" style="font-family: 'Outfit', sans-serif; font-size: 1.1rem; color: #111827;">
                    <i class="fa-solid fa-map-location-dot me-2" style="color: #1A6B3C;"></i>Seleccionar dirección
                </h5>
                <button type="button" @onclick="CloseMapModal"
                        style="background: none; border: none; font-size: 1.3rem; color: #6b7280; cursor: pointer; line-height: 1;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <!-- Buscador de dirección -->
            <div class="px-4 py-2 border-bottom" style="background-color: #f9fafb;">
                <div class="position-relative w-100">
                    <i class="fa-solid fa-magnifying-glass text-muted-foreground position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 0.95rem;"></i>
                    <input type="text" id="map-search-input" class="form-control text-foreground" style="height: 44px; padding-left: 42px; border-radius: 8px; border: 1px solid #d1d5db; font-size: 0.9rem;" placeholder="Escribe una dirección (ej: Av. Larco 123, Miraflores)..." />
                </div>
            </div>

            <!-- Map -->
            <div id="address-map" style="width: 100%; height: 350px;"></div>

            <!-- Selected address preview + confirm -->
            <div class="px-4 py-3" style="border-top: 1px solid #e5e7eb;">
                @if (!string.IsNullOrWhiteSpace(_pendingAddress))
                {
                    <div class="d-flex align-items-start gap-2 mb-3 p-2"
                         style="background: #f0fdf4; border-radius: 8px; border: 1px solid #bbf7d0;">
                        <i class="fa-solid fa-location-dot mt-1" style="color: #1A6B3C; flex-shrink: 0;"></i>
                        <span style="font-size: 0.85rem; color: #374151; word-break: break-word;">@_pendingAddress</span>
                    </div>
                }
                else
                {
                    <p class="text-muted-foreground mb-3" style="font-size: 0.85rem;">
                        <i class="fa-solid fa-hand-pointer me-1"></i> Haz clic en el mapa para seleccionar una dirección
                    </p>
                }
                <div class="d-flex gap-2 justify-content-end">
                    <button type="button" @onclick="CloseMapModal"
                            class="btn btn-outline-secondary px-3 py-2"
                            style="border-radius: 8px; font-size: 0.9rem;">
                        Cancelar
                    </button>
                    <button type="button" @onclick="ConfirmAddress"
                            class="btn text-white px-3 py-2 fw-semibold d-flex align-items-center gap-2"
                            style="background-color: #1A6B3C; border-radius: 8px; font-size: 0.9rem; border: none;"
                            disabled="@(string.IsNullOrWhiteSpace(_pendingAddress))">
                        <i class="fa-solid fa-check"></i> Confirmar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_success)
{
    <div class="success-toast"
         style="position: fixed; bottom: 28px; right: 28px; z-index: 99999;
                display: flex; align-items: flex-start; gap: 14px;
                background: #ffffff; color: #111827;
                border: 1.5px solid #d1fae5;
                border-radius: 16px;
                padding: 16px 18px;
                min-width: 300px; max-width: 360px;
                box-shadow: 0 8px 32px rgba(0,0,0,0.18), 0 2px 8px rgba(22,163,74,0.12);">

        <div style="width:42px;height:42px;border-radius:50%;background:#16a34a;
                    display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                 fill="none" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </div>

        <div style="flex:1;min-width:0;">
            <p style="margin:0 0 4px 0;font-weight:700;font-size:0.95rem;color:#111827;">¡Cambios guardados!</p>
            <p style="margin:0;font-size:0.78rem;color:#6b7280;line-height:1.4;">
                Tus datos de perfil se actualizaron correctamente.
            </p>
        </div>

        <button type="button"
                style="background:none;border:none;cursor:pointer;padding:2px;color:#9ca3af;flex-shrink:0;
                       font-size:1.1rem;line-height:1;margin-top:-2px;"
                @onclick="() => _success = false">✕</button>
    </div>
}

<style>
@@keyframes toastSlideIn {
    from { transform: translateX(120%); opacity: 0; }
    to   { transform: translateX(0);   opacity: 1; }
}
.success-toast {
    animation: toastSlideIn 0.35s cubic-bezier(.21,1.02,.73,1) forwards;
}
</style>
