@page "/admin/personal"
@layout AdminLayout
@inject StaffService StaffSvc
@inject AuthService Auth

@code {
    private List<Staff> _staff = new();
    private string _search = "";
    private string _roleFilter = "";
    private string _estadoFilter = "";

    // Paginación
    private int _pageSize = 8;
    private int _currentPage = 1;

    // Modal crear/editar
    private bool _showModal = false;
    private bool _isEditing = false;
    private Staff _form = new();
    private string? _dniError;
    private string? _telError;

    // ID del admin actual (no puede cambiar su propio rol, pero sí activo/inactivo)
    private string AdminId => "STF-001";
    private string _originalRol = "";

    // Confirmaciones
    private bool _showSaveConfirm   = false;
    private bool _showDeleteConfirm = false;
    private bool _showToggleConfirm = false;
    private bool _showSavedToast    = false;
    private bool _showDeletedToast  = false;
    private bool _showToggledToast  = false;
    private string? _pendingDeleteId;
    private string? _pendingToggleId;
    private System.Threading.CancellationTokenSource? _undoCts;
    private bool _undoAvailable = false;
    private Staff? _deletedBackup;
    // Undo para toggle de estado
    private bool _undoToggleAvailable = false;
    private string? _toggledId;
    private string? _toggledPrevState;
    private System.Threading.CancellationTokenSource? _undoToggleCts;

    protected override void OnInitialized() => _staff = StaffSvc.GetStaff();

    private IEnumerable<Staff> Filtered => _staff.Where(s =>
        (string.IsNullOrEmpty(_search) ||
         s.Nombre.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         s.Dni.Contains(_search) ||
         s.Correo.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_roleFilter)   || s.Rol.Equals(_roleFilter, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_estadoFilter) || s.Estado.Equals(_estadoFilter, StringComparison.OrdinalIgnoreCase))
    );

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)_pageSize));
    private IEnumerable<Staff> Paged => Filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    private void OnFilterChange() { _currentPage = 1; }
    private void GoToPage(int p)  { if (p >= 1 && p <= TotalPages) _currentPage = p; }

    private void OpenCreate()
    {
        _form = new Staff { Estado = "activo", Rol = "trabajador" };
        _isEditing = false; _dniError = null; _telError = null;
        _showModal = true;
    }

    private void OpenEdit(Staff s)
    {
        _form = new Staff
        {
            Id = s.Id, Nombre = s.Nombre, Dni = s.Dni, Rol = s.Rol,
            Telefono = s.Telefono, Correo = s.Correo, Avatar = s.Avatar,
            FechaIngreso = s.FechaIngreso, Estado = s.Estado
        };
        _originalRol = s.Rol;
        _isEditing = true; _dniError = null; _telError = null;
        _showModal = true;
    }

    private void TrySubmit()
    {
        _dniError = null; _telError = null;
        if (_form.Dni.Length != 8 || !_form.Dni.All(char.IsDigit))
            _dniError = "El DNI debe tener exactamente 8 dígitos numéricos.";
        if (_form.Telefono.Length != 9 || !_form.Telefono.All(char.IsDigit))
            _telError = "El celular debe tener exactamente 9 dígitos numéricos.";
        if (_dniError != null || _telError != null) return;
        _showSaveConfirm = true;
    }

    private async Task ConfirmSave()
    {
        // Proteger rol del admin principal: no importa si el select fue manipulado
        if (_isEditing && _form.Id == AdminId)
            _form.Rol = _originalRol;
        if (_isEditing) StaffSvc.UpdateStaff(_form);
        else StaffSvc.AddStaff(_form);
        _staff = StaffSvc.GetStaff();
        _showModal = false; _showSaveConfirm = false;
        _showSavedToast = true; StateHasChanged();
        await Task.Delay(3000); _showSavedToast = false; StateHasChanged();
    }
    private void CancelSave() => _showSaveConfirm = false;

    // Toggle estado
    private void AskToggle(string id) { _pendingToggleId = id; _showToggleConfirm = true; }
    private void CancelToggle()       { _showToggleConfirm = false; _pendingToggleId = null; }
    private async Task ConfirmToggle()
    {
        if (_pendingToggleId == null) return;
        // Guardar estado previo para undo
        var prev = _staff.FirstOrDefault(s => s.Id == _pendingToggleId);
        _toggledId = _pendingToggleId;
        _toggledPrevState = prev?.Estado;
        StaffSvc.ToggleStatus(_pendingToggleId);
        _staff = StaffSvc.GetStaff();
        _showToggleConfirm = false; _pendingToggleId = null;
        _showToggledToast = true; _undoToggleAvailable = true; StateHasChanged();
        _undoToggleCts?.Cancel();
        _undoToggleCts = new System.Threading.CancellationTokenSource();
        try
        {
            await Task.Delay(5000, _undoToggleCts.Token);
            _showToggledToast = false; _undoToggleAvailable = false; StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private void UndoToggle()
    {
        if (_toggledId != null && _toggledPrevState != null)
        {
            var member = _staff.FirstOrDefault(s => s.Id == _toggledId);
            if (member != null) member.Estado = _toggledPrevState;
            _staff = StaffSvc.GetStaff();
        }
        _undoToggleCts?.Cancel();
        _showToggledToast = false; _undoToggleAvailable = false;
        _toggledId = null; _toggledPrevState = null;
        StateHasChanged();
    }

    // Eliminar
    private void AskDelete(string id) { _pendingDeleteId = id; _showDeleteConfirm = true; }
    private void CancelDelete()       { _showDeleteConfirm = false; _pendingDeleteId = null; }
    private async Task ConfirmDelete()
    {
        if (_pendingDeleteId == null) return;
        _deletedBackup = _staff.FirstOrDefault(s => s.Id == _pendingDeleteId);
        StaffSvc.DeleteStaff(_pendingDeleteId);
        _staff = StaffSvc.GetStaff();
        _showDeleteConfirm = false; _pendingDeleteId = null;
        _showDeletedToast = true; _undoAvailable = true; StateHasChanged();
        _undoCts?.Cancel(); _undoCts = new();
        try { await Task.Delay(5000, _undoCts.Token); _showDeletedToast = false; _undoAvailable = false; StateHasChanged(); }
        catch (TaskCanceledException) { }
    }
    private void UndoDelete()
    {
        if (_deletedBackup != null) { StaffSvc.AddStaff(_deletedBackup); _staff = StaffSvc.GetStaff(); _deletedBackup = null; }
        _undoCts?.Cancel(); _showDeletedToast = false; _undoAvailable = false; StateHasChanged();
    }

    private string? GetToggleName() => _staff.FirstOrDefault(s => s.Id == _pendingToggleId)?.Nombre;
    private string? GetToggleAction() => _staff.FirstOrDefault(s => s.Id == _pendingToggleId)?.Estado == "activo" ? "desactivar" : "activar";
}

<PageTitle>Personal – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="page-title mb-0"><i class="fas fa-users me-2 text-primary"></i>Gestión de Personal</h1>
            <p class="page-subtitle">Administra los accesos y roles del staff de trabajadores</p>
        </div>
        <button @onclick="OpenCreate" class="btn btn-primary d-flex align-items-center gap-2 fw-semibold" style="border-radius:var(--radius);">
            <i class="fas fa-plus"></i> Registrar Trabajador
        </button>
    </div>

    <!-- KPI -->
    <div class="row g-3">
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-foreground">@_staff.Count</div><div class="metric-kpi-label">Total Personal</div></div>
                <div class="metric-kpi-icon kpi-icon-primary"><i class="fas fa-users"></i></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-primary">@_staff.Count(s => s.Estado == "activo")</div><div class="metric-kpi-label">Miembros Activos</div></div>
                <div class="metric-kpi-icon kpi-icon-success"><i class="fas fa-user-check"></i></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-foreground">@_staff.Select(s => s.Rol).Distinct().Count()</div><div class="metric-kpi-label">Roles Configurados</div></div>
                <div class="metric-kpi-icon kpi-icon-purple"><i class="fas fa-id-badge"></i></div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card p-4" style="border-radius:12px;">
        <div class="row g-2 align-items-center">
            <div class="col-md-5">
                <div class="position-relative">
                    <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:16px;font-size:14px;"></i>
                    <input type="search" @bind="_search" @bind:event="oninput" @bind:after="OnFilterChange"
                           class="form-control text-foreground" placeholder="Buscar por nombre, DNI o correo..."
                           style="height:56px;border-radius:10px;padding-left:42px;" />
                </div>
            </div>
            <div class="col-md-4">
                <select @bind="_roleFilter" @bind:after="OnFilterChange" class="form-select text-foreground" style="height:56px;border-radius:10px;">
                    <option value="">Todos los roles</option>
                    <option value="administrador">Administradores</option>
                    <option value="trabajador">Trabajadores</option>
                </select>
            </div>
            <div class="col-md-3">
                <select @bind="_estadoFilter" @bind:after="OnFilterChange" class="form-select text-foreground" style="height:56px;border-radius:10px;">
                    <option value="">Todos los estados</option>
                    <option value="activo">Activos</option>
                    <option value="inactivo">Inactivos</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-borderless mb-0 align-middle">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Trabajador</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Rol</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">DNI</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Fecha Ingreso</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Estado</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Paged)
                    {
                        <tr class="border-bottom border-color-default">
                            <td class="px-4 py-3 d-flex align-items-center gap-3">
                                <img src="@s.Avatar" alt="@s.Nombre" class="rounded-circle flex-shrink-0 object-fit-cover" style="width:40px;height:40px;"
                                     onerror="this.src='https://placehold.co/40/e0e0e0/555?text=U'" />
                                <div>
                                    <span class="fw-semibold text-foreground d-block small">@s.Nombre</span>
                                    <span class="text-xs text-muted-foreground">@s.Correo</span>
                                </div>
                            </td>
                            <td class="px-4 py-3 small">
                                <span class="badge @(s.Rol == "administrador" ? "bg-primary-subtle text-primary" : "bg-secondary text-muted-foreground")" style="border-radius:var(--radius);">
                                    @s.Rol
                                </span>
                            </td>
                            <td class="px-4 py-3 text-muted-foreground small d-none d-md-table-cell">@s.Dni</td>
                            <td class="px-4 py-3 text-muted-foreground small d-none d-md-table-cell">@s.FechaIngreso.ToString("dd MMM yyyy")</td>
                            <td class="px-4 py-3">
                                <span class="badge @(s.Estado == "activo" ? "bg-success" : "bg-danger") px-2 py-1" style="border-radius:var(--radius);">@s.Estado</span>
                            </td>
                            <td class="px-4 py-3 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-2">
                                    <button @onclick="@(() => OpenEdit(s))" class="btn btn-sm btn-light text-muted" style="border-radius:var(--radius);" title="Editar">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                    <button @onclick="@(() => AskToggle(s.Id))"
                                            class="btn btn-sm btn-light @(s.Estado == "activo" ? "text-warning" : "text-success")"
                                            style="border-radius:var(--radius);" title="@(s.Estado == "activo" ? "Desactivar" : "Activar")">
                                        <i class="fa-solid @(s.Estado == "activo" ? "fa-eye-slash" : "fa-eye")"></i>
                                    </button>
                                    <button @onclick="@(() => AskDelete(s.Id))" class="btn btn-sm btn-light text-danger" style="border-radius:var(--radius);" title="Eliminar">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Paged.Any())
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted-foreground">No se encontraron miembros del personal</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-2">
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage - 1))" disabled="@(_currentPage == 1)" style="width:36px;height:36px;"><i class="fa-solid fa-chevron-left" style="font-size:.75rem;"></i></button>
            @for (int p = 1; p <= TotalPages; p++) { var pg = p;
                <button class="btn btn-sm rounded-circle pag-btn @(pg == _currentPage ? "pag-active" : "")" @onclick="@(() => GoToPage(pg))" style="width:36px;height:36px;font-size:.85rem;font-weight:600;">@pg</button>
            }
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage + 1))" disabled="@(_currentPage == TotalPages)" style="width:36px;height:36px;"><i class="fa-solid fa-chevron-right" style="font-size:.75rem;"></i></button>
        </div>
    }
</div>

<!-- Modal Crear/Editar -->
@if (_showModal)
{
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="@(() => _showModal = false)">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-header border-border">
                    <h5 class="modal-title text-foreground fw-bold">@(_isEditing ? "Editar Miembro" : "Registrar Miembro")</h5>
                    <button type="button" class="btn-close" @onclick="@(() => _showModal = false)"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="d-flex flex-column gap-3">
                        <div>
                            <label class="form-label small fw-medium text-foreground">Nombre Completo</label>
                            <input type="text" @bind="_form.Nombre" class="form-control text-foreground" placeholder="Marcos Díaz" />
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">DNI <span class="text-danger">*8 dígitos</span></label>
                                <input type="text" @bind="_form.Dni" maxlength="8" class="form-control text-foreground @(_dniError != null ? "is-invalid" : "")" placeholder="45632178" />
                                @if (_dniError != null) { <div class="invalid-feedback d-block" style="font-size:.8rem;">@_dniError</div> }
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Celular <span class="text-danger">*9 dígitos</span></label>
                                <input type="tel" @bind="_form.Telefono" maxlength="9" class="form-control text-foreground @(_telError != null ? "is-invalid" : "")" placeholder="963852741" />
                                @if (_telError != null) { <div class="invalid-feedback d-block" style="font-size:.8rem;">@_telError</div> }
                            </div>
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Correo electrónico</label>
                            <input type="email" @bind="_form.Correo" class="form-control text-foreground" placeholder="marcos@shiligama.com" />
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Rol</label>
                            @if (_isEditing && _form.Id == AdminId)
                            {
                                <input type="text" value="@_form.Rol" disabled class="form-control text-muted-foreground" />
                                <small class="text-muted-foreground">El rol del administrador principal no puede modificarse.</small>
                            }
                            else
                            {
                                <select @bind="_form.Rol" class="form-select text-foreground">
                                    <option value="trabajador">Trabajador</option>
                                    <option value="administrador">Administrador</option>
                                </select>
                            }
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Avatar URL (opcional)</label>
                            <input type="url" @bind="_form.Avatar" class="form-control text-foreground" placeholder="https://..." />
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Estado</label>
                            <select @bind="_form.Estado" class="form-select text-foreground">
                                <option value="activo">Activo</option>
                                <option value="inactivo">Inactivo</option>
                            </select>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-2">
                            <button type="button" @onclick="@(() => _showModal = false)" class="btn btn-secondary" style="border-radius:var(--radius);">Cancelar</button>
                            <button type="button" @onclick="TrySubmit" class="btn btn-primary fw-semibold" style="border-radius:var(--radius);">
                                @(_isEditing ? "Guardar cambios" : "Registrar")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Guardar -->
@if (_showSaveConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">💾</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Guardar cambios?</h5>
                    <p class="text-muted-foreground small mb-4">Se @(_isEditing ? "actualizará" : "registrará") el miembro <strong>@_form.Nombre</strong>.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelSave">Cancelar</button>
                        <button class="btn btn-primary" style="border-radius:var(--radius);" @onclick="ConfirmSave">Guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Toggle -->
@if (_showToggleConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">@(GetToggleAction() == "desactivar" ? "⚠️" : "✅")</div>
                    <h5 class="fw-bold text-foreground mb-1">¿@(GetToggleAction()?.Substring(0,1).ToUpper() + GetToggleAction()?.Substring(1)) miembro?</h5>
                    <p class="text-muted-foreground small mb-4">Se va a <strong>@GetToggleAction()</strong> a <strong>@GetToggleName()</strong>.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelToggle">Cancelar</button>
                        <button class="btn btn-primary" style="border-radius:var(--radius);" @onclick="ConfirmToggle">Confirmar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Eliminar -->
@if (_showDeleteConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">🗑️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Eliminar miembro?</h5>
                    <p class="text-muted-foreground small mb-4">Esta acción eliminará el registro. Podrás deshacer por 5 segundos.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelDelete">Cancelar</button>
                        <button class="btn btn-danger" style="border-radius:var(--radius);" @onclick="ConfirmDelete">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toasts -->
@if (_showSavedToast) {
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:260px;">
            <i class="fa-solid fa-circle-check me-2"></i><span class="small">Miembro @(_isEditing ? "actualizado" : "registrado") correctamente</span>
        </div>
    </div>
}
@if (_showToggledToast) {
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 d-flex align-items-center gap-2 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:280px;">
            <i class="fa-solid fa-circle-check"></i>
            <span class="small flex-grow-1">Estado actualizado correctamente</span>
            @if (_undoToggleAvailable)
            {
                <button class="btn btn-sm btn-link text-white p-0 text-decoration-underline" @onclick="UndoToggle">Deshacer</button>
            }
        </div>
    </div>
}
@if (_showDeletedToast) {
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 d-flex align-items-center gap-2 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:280px;">
            <i class="fa-solid fa-circle-check"></i>
            <span class="small flex-grow-1">Miembro eliminado</span>
            @if (_undoAvailable) { <button class="btn btn-sm btn-link text-white p-0" @onclick="UndoDelete">Deshacer</button> }
        </div>
    </div>
}

<style>
    .pag-btn { background:var(--card); border:1px solid var(--border); color:var(--foreground); transition:all .15s; }
    .pag-btn:hover:not(:disabled) { background:var(--secondary); }
    .pag-btn:disabled { opacity:.4; }
    .pag-active { background:#1A6B3C !important; color:#fff !important; border-color:#1A6B3C !important; }
</style>
