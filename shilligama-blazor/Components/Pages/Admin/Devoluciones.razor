@page "/admin/devoluciones"
@layout AdminLayout
@inject ReturnsService ReturnsSvc
@inject ProductService ProductSvc
@inject AuthService Auth

@code {
    private List<Return> _returns = new();
    private string _search = "";

    // Paginación
    private int _pageSize = 6;
    private int _currentPage = 1;

    // Modal crear/editar
    private bool _showModal = false;
    private bool _isEditing = false;
    private Return _form = new();
    private string _productSearch = "";
    private List<string> _productSuggestions = new();

    // Confirmaciones
    private bool _showSaveConfirm   = false;
    private bool _showDeleteConfirm = false;
    private bool _showSavedToast    = false;
    private bool _showDeletedToast  = false;
    private string? _pendingDeleteId;
    private System.Threading.CancellationTokenSource? _undoCts;
    private bool _undoAvailable = false;
    private Return? _deletedBackup;
    // Undo para guardar/editar
    private bool _undoSaveAvailable = false;
    private Return? _savedBackup;  // estado previo antes de editar
    private System.Threading.CancellationTokenSource? _undoSaveCts;

    protected override void OnInitialized() => _returns = ReturnsSvc.GetReturns();

    private IEnumerable<Return> Filtered => _returns.Where(r =>
        string.IsNullOrEmpty(_search) ||
        r.Product.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        r.Id.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        r.RegisteredBy.Contains(_search, StringComparison.OrdinalIgnoreCase)
    );

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)_pageSize));
    private IEnumerable<Return> Paged => Filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    private void OnFilterChange() { _currentPage = 1; }
    private void GoToPage(int p)  { if (p >= 1 && p <= TotalPages) _currentPage = p; }

    private decimal TotalRefunded => Filtered.Sum(r => r.Amount);

    // Autocompletado de producto
    private void OnProductSearchInput(ChangeEventArgs e)
    {
        _productSearch = e.Value?.ToString() ?? "";
        _form.Product = _productSearch;
        _productSuggestions = string.IsNullOrWhiteSpace(_productSearch)
            ? new()
            : ProductSvc.GetProducts()
                .Where(p => p.Name.Contains(_productSearch, StringComparison.OrdinalIgnoreCase))
                .Select(p => p.Name)
                .Take(5)
                .ToList();
    }
    private void SelectProduct(string name)
    {
        _form.Product = name;
        _productSearch = name;
        _productSuggestions.Clear();
    }

    private void OpenCreate()
    {
        _form = new Return { Quantity = 1, RegisteredBy = Auth.CurrentUser?.Name ?? "Admin Shiligama" };
        _isEditing = false; _productSearch = ""; _productSuggestions.Clear();
        _showModal = true;
    }

    private void OpenEdit(Return r)
    {
        // Guardar copia del estado original para undo
        _savedBackup = new Return
        {
            Id = r.Id, Date = r.Date, OrderId = r.OrderId, Customer = r.Customer,
            Product = r.Product, ProductCode = r.ProductCode, Quantity = r.Quantity,
            Reason = r.Reason, RegisteredBy = r.RegisteredBy, Amount = r.Amount,
            Observations = r.Observations
        };
        _form = new Return
        {
            Id = r.Id, Date = r.Date, OrderId = r.OrderId, Customer = r.Customer,
            Product = r.Product, ProductCode = r.ProductCode, Quantity = r.Quantity,
            Reason = r.Reason, RegisteredBy = r.RegisteredBy, Amount = r.Amount,
            Observations = r.Observations
        };
        _productSearch = r.Product; _productSuggestions.Clear();
        _isEditing = true; _showModal = true;
    }

    private void TrySave() => _showSaveConfirm = true;
    private void CancelSave() => _showSaveConfirm = false;

    private async Task ConfirmSave()
    {
        var prod = ProductSvc.GetProducts().FirstOrDefault(p => p.Name.Equals(_form.Product, StringComparison.OrdinalIgnoreCase));
        if (prod != null) { _form.ProductCode = $"PROD-{prod.Id:D3}"; _form.Amount = prod.Price * _form.Quantity; }
        else { _form.ProductCode = "PROD-GEN"; if (_form.Amount == 0) _form.Amount = 10.00m * _form.Quantity; }

        if (_isEditing) ReturnsSvc.UpdateReturn(_form);
        else { _savedBackup = null; ReturnsSvc.AddReturn(_form); }  // nuevo: no hay estado previo que deshacer
        _returns = ReturnsSvc.GetReturns();
        _showModal = false; _showSaveConfirm = false;
        _showSavedToast = true; _undoSaveAvailable = _isEditing; StateHasChanged();
        _undoSaveCts?.Cancel(); _undoSaveCts = new System.Threading.CancellationTokenSource();
        try
        {
            await Task.Delay(5000, _undoSaveCts.Token);
            _showSavedToast = false; _undoSaveAvailable = false; StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private void UndoSave()
    {
        if (_savedBackup != null)
        {
            ReturnsSvc.UpdateReturn(_savedBackup);
            _returns = ReturnsSvc.GetReturns();
            _savedBackup = null;
        }
        _undoSaveCts?.Cancel();
        _showSavedToast = false; _undoSaveAvailable = false; StateHasChanged();
    }

    private void AskDelete(string id) { _pendingDeleteId = id; _showDeleteConfirm = true; }
    private void CancelDelete()       { _showDeleteConfirm = false; _pendingDeleteId = null; }
    private async Task ConfirmDelete()
    {
        if (_pendingDeleteId == null) return;
        _deletedBackup = _returns.FirstOrDefault(r => r.Id == _pendingDeleteId);
        ReturnsSvc.DeleteReturn(_pendingDeleteId);
        _returns = ReturnsSvc.GetReturns();
        _showDeleteConfirm = false; _pendingDeleteId = null;
        _showDeletedToast = true; _undoAvailable = true; StateHasChanged();
        _undoCts?.Cancel(); _undoCts = new();
        try { await Task.Delay(5000, _undoCts.Token); _showDeletedToast = false; _undoAvailable = false; StateHasChanged(); }
        catch (TaskCanceledException) { }
    }
    private void UndoDelete()
    {
        if (_deletedBackup != null) { ReturnsSvc.AddReturn(_deletedBackup); _returns = ReturnsSvc.GetReturns(); _deletedBackup = null; }
        _undoCts?.Cancel(); _showDeletedToast = false; _undoAvailable = false; StateHasChanged();
    }
}

<PageTitle>Devoluciones – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="page-title mb-0">Devoluciones y Reclamos</h1>
            <p class="page-subtitle">Controla los productos defectuosos, vencidos o errores de despacho</p>
        </div>
        <button @onclick="OpenCreate" class="btn btn-primary d-flex align-items-center gap-2 fw-semibold" style="border-radius:var(--radius);">
            <i class="fa-solid fa-plus"></i> Nueva Devolución
        </button>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card p-4">
                <span class="small text-muted-foreground fw-medium">Valor Total Devuelto</span>
                <span class="fs-3 fw-bold text-danger mt-1">S/. @TotalRefunded.ToString("0.00")</span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-4">
                <span class="small text-muted-foreground fw-medium">Total de Registros</span>
                <span class="fs-3 fw-bold text-foreground mt-1">@Filtered.Count() devoluciones</span>
            </div>
        </div>
    </div>

    <div class="card p-4" style="border-radius:12px;">
        <div class="position-relative">
            <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:16px;font-size:14px;"></i>
            <input type="search" @bind="_search" @bind:event="oninput" @bind:after="OnFilterChange"
                   class="form-control text-foreground" placeholder="Buscar por código, producto o responsable..."
                   style="height:56px;border-radius:10px;padding-left:42px;" />
        </div>
    </div>

    <!-- Tarjetas de devolución (más padding entre ellas) -->
    <div class="d-flex flex-column gap-3">
        @foreach (var dev in Paged)
        {
            <div class="card" style="border-radius:12px;overflow:hidden;">
                <!-- Cabecera de la tarjeta -->
                <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom border-color-default" style="background:color-mix(in srgb,var(--primary) 5%,transparent);">
                    <div class="d-flex align-items-center gap-3">
                        <span class="fw-bold text-primary small">@dev.Id</span>
                        <span class="badge bg-warning-subtle text-warning" style="border-radius:var(--radius);">@dev.Reason</span>
                        <span class="text-muted-foreground small"><i class="fa-regular fa-calendar me-1"></i>@dev.Date.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button @onclick="@(() => OpenEdit(dev))" class="btn btn-ghost btn-sm text-muted-foreground" style="border-radius:var(--radius);" title="Editar">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </button>
                        <button @onclick="@(() => AskDelete(dev.Id))" class="btn btn-ghost btn-sm text-danger" style="border-radius:var(--radius);" title="Eliminar">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
                <!-- Cuerpo -->
                <div class="px-4 py-3">
                    <div class="row g-3 align-items-start">
                        <div class="col-md-6">
                            <p class="small text-muted-foreground mb-1 fw-semibold text-uppercase" style="letter-spacing:.04em;">Producto</p>
                            <p class="fw-semibold text-foreground mb-0">@dev.Product</p>
                            <p class="text-xs text-muted-foreground mb-0">@dev.ProductCode · @dev.Quantity ud.</p>
                        </div>
                        <div class="col-md-3">
                            <p class="small text-muted-foreground mb-1 fw-semibold text-uppercase" style="letter-spacing:.04em;">Responsable</p>
                            <p class="fw-medium text-foreground mb-0 small">@dev.RegisteredBy</p>
                        </div>
                        <div class="col-md-3 text-md-end">
                            <p class="small text-muted-foreground mb-1 fw-semibold text-uppercase" style="letter-spacing:.04em;">Importe</p>
                            <p class="fw-bold text-danger mb-0">S/. @dev.Amount.ToString("0.00")</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(dev.Observations))
                    {
                        <div class="mt-3 px-3 py-2 rounded" style="background:color-mix(in srgb,var(--muted) 40%,transparent);border-left:3px solid var(--primary);">
                            <p class="small text-muted-foreground mb-0"><strong class="text-foreground">Observación:</strong> @dev.Observations</p>
                        </div>
                    }
                </div>
            </div>
        }

        @if (!Paged.Any())
        {
            <div class="card p-5 text-center text-muted-foreground">No se encontraron registros de devoluciones</div>
        }
    </div>

    <!-- Paginación -->
    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-2">
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage - 1))" disabled="@(_currentPage == 1)" style="width:36px;height:36px;"><i class="fa-solid fa-chevron-left" style="font-size:.75rem;"></i></button>
            @for (int p = 1; p <= TotalPages; p++) { var pg = p;
                <button class="btn btn-sm rounded-circle pag-btn @(pg == _currentPage ? "pag-active" : "")" @onclick="@(() => GoToPage(pg))" style="width:36px;height:36px;font-size:.85rem;font-weight:600;">@pg</button>
            }
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage + 1))" disabled="@(_currentPage == TotalPages)" style="width:36px;height:36px;"><i class="fa-solid fa-chevron-right" style="font-size:.75rem;"></i></button>
        </div>
    }
</div>

<!-- Modal Crear/Editar -->
@if (_showModal)
{
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="@(() => _showModal = false)">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-header border-border">
                    <h5 class="modal-title text-foreground fw-bold">@(_isEditing ? "Editar Devolución" : "Registrar Devolución")</h5>
                    <button type="button" class="btn-close" @onclick="@(() => _showModal = false)"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="d-flex flex-column gap-3">
                        <!-- Autocompletado de producto -->
                        <div class="position-relative">
                            <label class="form-label small fw-medium text-foreground">Nombre del Producto</label>
                            <input type="text" value="@_productSearch" @oninput="OnProductSearchInput"
                                   class="form-control text-foreground" placeholder="Escribe para buscar..." autocomplete="off" />
                            @if (_productSuggestions.Any())
                            {
                                <ul class="list-group position-absolute w-100 shadow" style="z-index:1055;top:100%;max-height:160px;overflow-y:auto;">
                                    @foreach (var s in _productSuggestions)
                                    {
                                        var sug = s;
                                        <li class="list-group-item list-group-item-action small py-2 px-3" style="cursor:pointer;" @onclick="@(() => SelectProduct(sug))">@sug</li>
                                    }
                                </ul>
                            }
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Cantidad</label>
                                <input type="number" @bind="_form.Quantity" min="1" class="form-control text-foreground" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Motivo</label>
                                <select @bind="_form.Reason" class="form-select text-foreground">
                                    <option value="">Seleccionar motivo</option>
                                    <option value="Vencido">Vencido</option>
                                    <option value="Dañado">Dañado / Roto</option>
                                    <option value="Error de pedido">Error de pedido</option>
                                    <option value="Otro">Otro</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Observaciones</label>
                            <textarea @bind="_form.Observations" class="form-control text-foreground" rows="3" placeholder="Detalle adicional..."></textarea>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-2">
                            <button type="button" @onclick="@(() => _showModal = false)" class="btn btn-secondary" style="border-radius:var(--radius);">Cancelar</button>
                            <button type="button" @onclick="TrySave" class="btn btn-primary fw-semibold" style="border-radius:var(--radius);">
                                @(_isEditing ? "Guardar cambios" : "Registrar")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Guardar -->
@if (_showSaveConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">💾</div>
                    <h5 class="fw-bold text-foreground mb-1">¿@(_isEditing ? "Guardar cambios" : "Registrar devolución")?</h5>
                    <p class="text-muted-foreground small mb-4">Se @(_isEditing ? "actualizará" : "registrará") la devolución del producto <strong>@_form.Product</strong>.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelSave">Cancelar</button>
                        <button class="btn btn-primary" style="border-radius:var(--radius);" @onclick="ConfirmSave">Confirmar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Eliminar -->
@if (_showDeleteConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">🗑️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Eliminar devolución?</h5>
                    <p class="text-muted-foreground small mb-4">Podrás deshacer esta acción durante 5 segundos.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelDelete">Cancelar</button>
                        <button class="btn btn-danger" style="border-radius:var(--radius);" @onclick="ConfirmDelete">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toast Guardado -->
@if (_showSavedToast) {
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 d-flex align-items-center gap-2 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:280px;">
            <i class="fa-solid fa-circle-check"></i>
            <span class="small flex-grow-1">Devolución @(_isEditing ? "actualizada" : "registrada")</span>
            @if (_undoSaveAvailable)
            {
                <button class="btn btn-sm btn-link text-white p-0 text-decoration-underline" @onclick="UndoSave">Deshacer</button>
            }
        </div>
    </div>
}
<!-- Toast Eliminado -->
@if (_showDeletedToast) {
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 d-flex align-items-center gap-2 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:280px;">
            <i class="fa-solid fa-circle-check"></i>
            <span class="small flex-grow-1">Devolución eliminada</span>
            @if (_undoAvailable) { <button class="btn btn-sm btn-link text-white p-0" @onclick="UndoDelete">Deshacer</button> }
        </div>
    </div>
}

<style>
    .pag-btn { background:var(--card); border:1px solid var(--border); color:var(--foreground); transition:all .15s; }
    .pag-btn:hover:not(:disabled) { background:var(--secondary); }
    .pag-btn:disabled { opacity:.4; }
    .pag-active { background:#1A6B3C !important; color:#fff !important; border-color:#1A6B3C !important; }
</style>
