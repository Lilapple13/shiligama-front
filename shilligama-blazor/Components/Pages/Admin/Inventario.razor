@page "/admin/inventario"
@layout AdminLayout
@inject ProductService ProductSvc

@code {
    private List<Product> _products = new();
    private string _search = "";
    private string _categoryFilter = "";
    private string _stockFilter = ""; // "" | "bajo" | "agotado"

    // Paginación
    private int _pageSize = 10;
    private int _currentPage = 1;

    protected override void OnInitialized()
    {
        _products = ProductSvc.GetProducts();
    }

    private IEnumerable<Product> Filtered => _products.Where(p =>
        (string.IsNullOrEmpty(_search) || p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_categoryFilter) || p.Category.Equals(_categoryFilter, StringComparison.OrdinalIgnoreCase)) &&
        (_stockFilter switch
        {
            "bajo"    => p.Stock > 0 && p.Stock < 10,
            "agotado" => p.Stock == 0,
            _         => true
        })
    );

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)_pageSize));
    private IEnumerable<Product> Paged => Filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);

    private void OnFilterChange() { _currentPage = 1; }
    private void GoToPage(int p)  { if (p >= 1 && p <= TotalPages) _currentPage = p; }

    private void AdjustStock(Product p, int amount)
    {
        p.Stock = Math.Max(0, p.Stock + amount);
        StateHasChanged();
    }
}

<PageTitle>Inventario – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div>
        <h1 class="page-title mb-0">
            <i class="fas fa-warehouse me-2 text-primary"></i>Control de Almacén e Inventario
        </h1>
        <p class="page-subtitle">Monitorea y ajusta las existencias físicas de productos en tiempo real</p>
    </div>

    <!-- KPI Mini-cards -->
    <div class="row g-3">
        <div class="col-6 col-xl-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-foreground">@_products.Count</div><div class="metric-kpi-label">Total Productos</div></div>
                <div class="metric-kpi-icon kpi-icon-primary"><i class="fas fa-box"></i></div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value" style="color:#f59e0b;">@_products.Count(p => p.Stock > 0 && p.Stock < 10)</div><div class="metric-kpi-label">Stock Bajo</div></div>
                <div class="metric-kpi-icon kpi-icon-warning"><i class="fas fa-exclamation-triangle"></i></div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value" style="color:#c62828;">@_products.Count(p => p.Stock == 0)</div><div class="metric-kpi-label">Agotados</div></div>
                <div class="metric-kpi-icon kpi-icon-danger"><i class="fas fa-times-circle"></i></div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-foreground" style="font-size:1rem;">Hoy, @DateTime.Now.ToString("HH:mm")</div><div class="metric-kpi-label">Sincronizado</div></div>
                <div class="metric-kpi-icon kpi-icon-info"><i class="fas fa-clock"></i></div>
            </div>
        </div>
    </div>

    <!-- Alert banner -->
    @if (_products.Any(p => p.Stock < 10))
    {
        <div class="stock-alert-banner">
            <div class="metric-kpi-icon kpi-icon-warning flex-shrink-0"><i class="fas fa-exclamation-triangle"></i></div>
            <div>
                <p class="fw-semibold text-foreground m-0 small">Alerta de Existencias Bajas</p>
                <p class="text-muted-foreground small m-0">Hay <strong>@_products.Count(p => p.Stock < 10)</strong> productos con stock menor a 10 unidades.</p>
                @if (_products.Any(p => p.Stock == 0))
                {
                    <p class="text-muted-foreground small m-0 mt-1">
                        <span class="text-danger fw-medium">Agotados:</span>
                        @string.Join(", ", _products.Where(p => p.Stock == 0).Select(p => p.Name).Take(3))
                    </p>
                }
            </div>
        </div>
    }

    <!-- Filtros -->
    <div class="card p-4" style="border-radius:12px;">
        <div class="row g-2 align-items-center">
            <!-- Búsqueda -->
            <div class="col-md-4">
                <div class="position-relative">
                    <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:16px;font-size:14px;"></i>
                    <input type="search" @bind="_search" @bind:event="oninput" @bind:after="OnFilterChange"
                           class="form-control text-foreground" placeholder="Buscar producto..."
                           style="height:56px;border-radius:10px;padding-left:42px;" />
                </div>
            </div>
            <!-- Categorías -->
            <div class="col-md-3">
                <select @bind="_categoryFilter" @bind:after="OnFilterChange"
                        class="form-select text-foreground" style="height:56px;border-radius:10px;">
                    <option value="">Categorías (todas)</option>
                    @foreach (var cat in ProductSvc.GetCategories())
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>
            <!-- Filtro de stock -->
            <div class="col-md-5">
                <div class="d-flex gap-2">
                    <button type="button" @onclick='@(() => { _stockFilter = ""; OnFilterChange(); })'
                            class="btn btn-sm flex-grow-1 @(_stockFilter == "" ? "btn-primary" : "btn-outline-secondary")"
                            style="border-radius:var(--radius);height:44px;">
                        Todos
                    </button>
                    <button type="button" @onclick='@(() => { _stockFilter = "bajo"; OnFilterChange(); })'
                            class="btn btn-sm flex-grow-1 @(_stockFilter == "bajo" ? "btn-warning text-dark" : "btn-outline-warning")"
                            style="border-radius:var(--radius);height:44px;">
                        <i class="fa-solid fa-triangle-exclamation me-1"></i>Stock bajo
                    </button>
                    <button type="button" @onclick='@(() => { _stockFilter = "agotado"; OnFilterChange(); })'
                            class="btn btn-sm flex-grow-1 @(_stockFilter == "agotado" ? "btn-danger" : "btn-outline-danger")"
                            style="border-radius:var(--radius);height:44px;">
                        <i class="fa-solid fa-circle-xmark me-1"></i>Agotados
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla (sin precio unitario) -->
    <div class="card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-borderless mb-0">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Código</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Producto</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Categoría</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing:.05em;">Stock Actual</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Ajuste Rápido</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Paged)
                    {
                        <tr class="border-bottom border-color-default align-middle">
                            <td class="px-4 py-3 fw-medium text-muted-foreground small">PROD-@product.Id.ToString("D3")</td>
                            <td class="px-4 py-3 d-flex align-items-center gap-3">
                                <img src="@product.Image" alt="@product.Name" class="rounded-3 flex-shrink-0 object-fit-cover" style="width:40px;height:40px;" onerror="this.src='https://placehold.co/40x40/e8f5e9/1A6B3C?text=🛒'" />
                                <span class="fw-medium text-foreground small">@product.Name</span>
                            </td>
                            <td class="px-4 py-3 text-muted-foreground small">@ProductSvc.GetCategoryName(product.Category)</td>
                            <td class="px-4 py-3 text-center">
                                <span class="badge @(product.Stock == 0 ? "bg-danger" : product.Stock < 10 ? "bg-warning text-dark" : "bg-success") py-1 px-3" style="border-radius:var(--radius);font-size:.8rem;">
                                    @product.Stock unidades
                                </span>
                            </td>
                            <td class="px-4 py-3 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <button @onclick="@(() => AdjustStock(product, -1))" disabled="@(product.Stock == 0)" class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width:30px;height:30px;">−</button>
                                    <button @onclick="@(() => AdjustStock(product, 1))" class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width:30px;height:30px;">+</button>
                                    <button @onclick="@(() => AdjustStock(product, 10))" class="btn btn-primary btn-sm px-2 ms-1" style="border-radius:var(--radius);font-size:.75rem;">+10 Lote</button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Paged.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted-foreground">No hay productos con ese filtro</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-2">
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage - 1))" disabled="@(_currentPage == 1)" style="width:36px;height:36px;">
                <i class="fa-solid fa-chevron-left" style="font-size:.75rem;"></i>
            </button>
            @for (int p = 1; p <= TotalPages; p++)
            {
                var pg = p;
                <button class="btn btn-sm rounded-circle pag-btn @(pg == _currentPage ? "pag-active" : "")"
                        @onclick="@(() => GoToPage(pg))" style="width:36px;height:36px;font-size:.85rem;font-weight:600;">@pg</button>
            }
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage + 1))" disabled="@(_currentPage == TotalPages)" style="width:36px;height:36px;">
                <i class="fa-solid fa-chevron-right" style="font-size:.75rem;"></i>
            </button>
        </div>
    }
</div>

<style>
    .pag-btn { background:var(--card); border:1px solid var(--border); color:var(--foreground); transition:all .15s; }
    .pag-btn:hover:not(:disabled) { background:var(--secondary); }
    .pag-btn:disabled { opacity:.4; }
    .pag-active { background:#1A6B3C !important; color:#fff !important; border-color:#1A6B3C !important; }
</style>
