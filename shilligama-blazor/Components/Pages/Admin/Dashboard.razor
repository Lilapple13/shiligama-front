@page "/admin"
@layout AdminLayout
@inject SalesService SalesSvc
@inject ProductService ProductSvc
@inject StaffService StaffSvc
@inject ReturnsService ReturnsSvc
@inject IJSRuntime JS

@code {
    private List<KpiItem> _kpis = new();
    private List<Order> _recentOrders = new();

    private record KpiItem(string Title, string Value, string Subtitle, string FaIcon, string Tone, string Trend, bool TrendUp);

    private static string GetKpiIconClass(string tone) => tone switch
    {
        "warning" => "kpi-icon-warning",
        "danger" => "kpi-icon-danger",
        "info" => "kpi-icon-info",
        _ => "kpi-icon-primary"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var sales = SalesSvc.GetSales();
        var orders = SalesSvc.GetRecentOrders();
        var products = ProductSvc.GetProducts();
        var staff = StaffSvc.GetStaff();
        var returns7d = ReturnsSvc.GetReturns()
                            .Where(r => r.Date >= DateTime.Today.AddDays(-7))
                            .ToList();
        var todaySales = sales.Where(s => s.Fecha.Date == DateTime.Today).Sum(s => s.Total);
        var avgTicket = sales.Any() ? sales.Average(s => s.Total) : 0m;
        var promoCount = products.Count(p => p.IsPromo);
        var pendientes = orders.Count(o => o.Status == "pendiente");
        var bajStock = products.Count(p => p.Stock < 10);
        var agotados = products.Count(p => p.Stock == 0);
        var activeStaff = staff.Count(s => s.Estado == "activo");
        var monthTotal = sales.Sum(s => s.Total);

        _kpis = new()
        {
            // Fila 1 — Ventas
            new("Ventas hoy",
                $"S/. {todaySales:0.00}",
                "transacciones del día",
                "fa-wallet", "primary", "+12.5%", true),
            new("Ingresos del mes",
                $"S/. {monthTotal:0.00}",
                "vs. mes anterior",
                "fa-chart-line", "info", "+8.2%", true),
            new("Ticket promedio",
                $"S/. {avgTicket:0.00}",
                "por transacción",
                "fa-receipt", "info", "+3.1%", true),
            new("Productos en promo",
                $"{promoCount}",
                "con descuento activo",
                "fa-tags", "warning", "", true),

            // Fila 2 — Operaciones
            new("Pedidos pendientes",
                $"{pendientes}",
                "sin despachar aún",
                "fa-clock", "warning", pendientes > 0 ? $"+{pendientes}" : "0", pendientes == 0),
            new("Stock bajo",
                $"{bajStock}",
                "productos < 10 unidades",
                "fa-box-open", "danger", $"-{bajStock}", false),
            new("Productos agotados",
                $"{agotados}",
                "sin stock disponible",
                "fa-times-circle", "danger", agotados > 0 ? $"{agotados}" : "0", false),
            new("Personal activo",
                $"{activeStaff}",
                $"de {staff.Count} registrados",
                "fa-users", "primary", "", true),
        };

        // Ordenar pedidos: pendiente → preparando → en_camino → entregado → cancelado
        var statusOrder = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
        {
            {"pendiente",0}, {"preparando",1}, {"en_camino",2}, {"entregado",3}, {"cancelado",4}
        };
        _recentOrders = orders
            .OrderBy(o => statusOrder.TryGetValue(o.Status, out var r) ? r : 99)
            .ThenByDescending(o => o.Date)
            .Take(6)
            .ToList();

        StateHasChanged();
        await RenderCharts();
    }

    private async Task RenderCharts()
    {
        var labels = Enumerable.Range(-6, 7).Select(d => DateTime.Today.AddDays(d).ToString("dd/MM")).ToArray();
        var data = Enumerable.Range(-6, 7).Select(d =>
            SalesSvc.GetSales().Where(s => s.Fecha.Date == DateTime.Today.AddDays(d)).Sum(s => s.Total)
        ).ToArray();
        await JS.InvokeVoidAsync("chartHelper.renderSalesChart", "salesChart", labels, data);

        var presencialData = new[] { 8, 10, 9, 12, 15, 18, 14 };
        var onlineData = new[] { 5, 7, 6, 8, 10, 12, 9 };
        await JS.InvokeVoidAsync("chartHelper.renderChannelsChart", "channelsChart",
            Enumerable.Range(-6, 7).Select(d => DateTime.Today.AddDays(d).ToString("ddd")).ToArray(),
            presencialData, onlineData);
    }

    private string GetStatusClass(string status) => status.ToLower() switch
    {
        "entregado" => "bg-success-subtle text-success",
        "en_camino" => "bg-primary-subtle text-primary",
        "preparando" => "bg-warning-subtle text-warning",
        "pendiente" => "bg-secondary text-muted-foreground",
        "cancelado" => "bg-danger-subtle text-danger",
        _ => "bg-light text-dark"
    };

    private string GetStatusLabel(string status) => status.ToLower() switch
    {
        "entregado" => "Entregado",
        "en_camino" => "En Camino",
        "preparando" => "Preparando",
        "pendiente" => "Pendiente",
        "cancelado" => "Cancelado",
        _ => status
    };
}

<PageTitle>Dashboard – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div>
        <h1 class="page-title mb-0">
            <i class="fas fa-store me-2 text-primary"></i>Dashboard
        </h1>
        <p class="page-subtitle">Resumen general de operaciones y métricas clave</p>
    </div>

    <!-- KPI Cards — 2 filas de 4 -->
    <div class="row g-3">
        @foreach (var kpi in _kpis)
        {
            <div class="col-6 col-lg-3">
                <div class="metric-card-kpi">
                    <div class="flex-grow-1">
                        <div class="metric-kpi-label mb-1">@kpi.Title</div>
                        <div class="metric-kpi-value text-foreground lh-1 mb-1">@kpi.Value</div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted-foreground" style="font-size:0.75rem;">@kpi.Subtitle</span>
                            @if (!string.IsNullOrEmpty(kpi.Trend))
                            {
                                <span class="badge small py-1 @(kpi.TrendUp ? "trend-up" : "trend-down")">
                                    <i class="fas @(kpi.TrendUp ? "fa-arrow-up" : "fa-arrow-down") me-1" style="font-size:0.6rem;"></i>@kpi.Trend
                                </span>
                            }
                        </div>
                    </div>
                    <div class="metric-kpi-icon @GetKpiIconClass(kpi.Tone)">
                        <i class="fas @kpi.FaIcon"></i>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Separador de sección -->
    <div class="d-flex align-items-center gap-2 mt-1">
        <span class="small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.06em;">Análisis de ventas</span>
        <div class="flex-grow-1" style="height:1px;background:var(--border);"></div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card p-4 h-100">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div>
                        <h2 class="section-title mb-0">
                            <i class="fas fa-chart-line me-2 text-primary"></i>Ventas de la Semana
                        </h2>
                        <p class="text-muted-foreground small m-0">Resumen de ventas diarias en soles (S/.)</p>
                    </div>
                    <span class="badge small py-1 px-2 trend-up">En tiempo real</span>
                </div>
                <div style="height:240px; position:relative;">
                    <canvas id="salesChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card p-4 h-100">
                <div class="mb-3">
                    <h2 class="fs-5 fw-semibold text-foreground mb-0">
                        <i class="fas fa-chart-bar me-2" style="color:#e67e22;"></i>Pedidos: Presencial vs Online
                    </h2>
                    <p class="text-muted-foreground small m-0">Distribución de canales esta semana</p>
                </div>
                <div style="height:240px; position:relative;">
                    <canvas id="channelsChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Separador -->
    <div class="d-flex align-items-center gap-2 mt-1">
        <span class="small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.06em;">Actividad reciente</span>
        <div class="flex-grow-1" style="height:1px;background:var(--border);"></div>
    </div>

    <!-- Recent Orders -->
    <div class="card overflow-hidden">
        <div class="d-flex align-items-center justify-content-between p-4 border-bottom border-color-default">
            <div>
                <h2 class="fs-5 fw-semibold text-foreground mb-0">Pedidos Recientes</h2>
                <p class="text-muted-foreground small m-0">Últimos pedidos ordenados por estado activo</p>
            </div>
            <a href="/admin/pedidos" class="btn btn-secondary btn-sm" style="border-radius:var(--radius);">Ver todos</a>
        </div>
        <div class="table-responsive">
            <table class="table table-borderless mb-0 align-middle">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Pedido</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Cliente</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Total</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Canal</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_recentOrders.Any())
                    {
                        @foreach (var order in _recentOrders)
                        {
                            <tr class="border-bottom border-color-default">
                                <td class="px-4 py-3 fw-bold text-primary small">@order.Id</td>
                                <td class="px-4 py-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="d-flex align-items-center justify-content-center rounded-circle bg-primary text-white flex-shrink-0"
                                             style="width:28px;height:28px;font-size:.75rem;">
                                            @((order.Customer?.Length > 0 ? order.Customer[0] : 'C').ToString())
                                        </div>
                                        <span class="text-foreground small">@order.Customer</span>
                                    </div>
                                </td>
                                <td class="px-4 py-3 fw-semibold text-foreground small">S/. @order.Total.ToString("0.00")</td>
                                <td class="px-4 py-3">
                                    <span class="badge" style="background:color-mix(in srgb,#1976d2 15%,transparent);color:#1976d2;font-size:0.7rem;border-radius:9999px;">
                                        <i class="fas @(order.Channel?.ToLower() == "presencial" ? "fa-store" : "fa-globe") me-1"></i>@order.Channel
                                    </span>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="badge @(GetStatusClass(order.Status)) py-1 px-2" style="border-radius:var(--radius);font-size:.75rem;">
                                        @GetStatusLabel(order.Status)
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted-foreground">Sin pedidos recientes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
